{
  "qa_gates": [
    {
      "gate_id": "statistical_semantics_preserved",
      "checks": [
        "estimand_matches_claim",
        "axis_units_present",
        "confidence_interval_or_uncertainty_policy_clear"
      ]
    },
    {
      "gate_id": "layout_readability",
      "checks": [
        "no_text_overlap",
        "legend_wrapped_or_shared",
        "panel_labels_visible",
        "long_label_stress_case_passes"
      ]
    },
    {
      "gate_id": "color_accessibility",
      "checks": [
        "colorblind_safe_palette",
        "grayscale_discriminable",
        "sequential_vs_diverging_semantics_match"
      ]
    },
    {
      "gate_id": "journal_export",
      "checks": [
        "final_physical_size_checked",
        "font_size_checked",
        "line_weight_checked",
        "vector_export_available_when_possible"
      ]
    },
    {
      "gate_id": "source_data_traceability",
      "checks": [
        "source_data_refs_present",
        "statistics_refs_present",
        "render_receipt_or_visual_audit_ref_present"
      ]
    },
    {
      "gate_id": "figure_contract_before_render",
      "checks": [
        "core_conclusion_present",
        "evidence_chain_maps_panels_to_claim",
        "figure_archetype_declared",
        "journal_export_contract_declared"
      ]
    },
    {
      "gate_id": "backend_exclusive_export_receipt",
      "checks": [
        "selected_backend_recorded",
        "render_preview_export_and_qa_use_selected_backend",
        "cross_backend_visual_fallback_absent",
        "svg_or_pdf_or_high_resolution_export_recorded"
      ]
    },
    {
      "gate_id": "ai_redesign_trace",
      "checks": [
        "starter_family_recorded",
        "paper_local_modifications_recorded",
        "family_switch_reason_recorded_when_applicable"
      ]
    },
    {
      "gate_id": "publication_polish_visual_audit",
      "checks": [
        "semantic_palette_roles_resolved",
        "legend_or_colorbar_overlap_checked",
        "multipanel_shared_guide_policy_checked",
        "final_size_readability_checked"
      ]
    },
    {
      "gate_id": "paper_use_polish_lifecycle",
      "checks": [
        "core_conclusion_and_evidence_chain_locked",
        "paper_local_data_and_statistics_refs_present",
        "vector_or_high_resolution_export_recorded",
        "visual_audit_receipt_or_residual_item_recorded"
      ]
    },
    {
      "gate_id": "figure_brief_storyboard_workflow_packet",
      "checks": [
        "figure_brief_core_conclusion_present",
        "storyboard_hero_panel_declared",
        "supporting_panel_roles_are_claim_mapped",
        "render_inspect_revise_loop_declared",
        "workflow_packet_nonblocking_for_default_progress"
      ]
    }
  ]
}
