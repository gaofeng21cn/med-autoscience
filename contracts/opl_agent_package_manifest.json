{
  "surface_kind": "opl_agent_package_manifest.v1",
  "agent_id": "mas",
  "package_id": "mas",
  "display_name": "Med Auto Science",
  "publisher": "one-person-lab",
  "version": "0.2.17",
  "release_set_receipt_ref": "contracts/mas_validator_release_set_receipt.json",
  "source": "first_party_repo_local",
  "carrier_source_role": "codex_plugin_default_carrier_not_package_truth",
  "schema_ref": "one-person-lab/contracts/opl-framework/agent-package-manifest.schema.json",
  "domain_descriptor_ref": "contracts/domain_descriptor.json",
  "machine_boundary": "This repo-local sidecar declares the MAS package and its optional professional capability enhancement. OPL owns capability discovery, materialization, lifecycle receipts, update, rollback, and repair; MAS remains runnable without the enhancement and retains domain truth and authority.",
  "codex_surface": {
    "plugin_id": "med-autoscience",
    "standalone_distribution": "repo_carrier_source",
    "required_skill_ids": [
      "med-autoscience"
    ],
    "bundled_capability_package_ids": [
      "mas-scholar-skills"
    ],
    "user_install_action_count": 1
  },
  "capability_dependencies": [
    {
      "module_id": "scholarskills",
      "package_id": "mas-scholar-skills",
      "kind": "framework_capability_package",
      "required": false,
      "dependency_kind": "optional_enhancement",
      "version_requirement": ">=0.2.12 <0.3.0",
      "capability_abi": "mas-scholar-skills.v1",
      "provider_manifest_ref": "mas-scholar-skills/contracts/opl_capability_package_manifest.json",
      "required_export_ids": [
        "mas-scholar-skills",
        "medical-manuscript-writing",
        "medical-manuscript-review",
        "medical-figure-design",
        "medical-figure-style",
        "medical-figure-composer",
        "medical-research-lit",
        "medical-statistical-review",
        "medical-table-design",
        "medical-submission-prep",
        "medical-data-governance"
      ],
      "required_module_ids": [
        "mas-scholar-skills.display",
        "mas-scholar-skills.tables",
        "mas-scholar-skills.stats",
        "mas-scholar-skills.lit",
        "mas-scholar-skills.write",
        "mas-scholar-skills.review",
        "mas-scholar-skills.submit",
        "mas-scholar-skills.data",
        "mas-scholar-skills.reference-provider-adapters",
        "mas-scholar-skills.scientific-search-adapters"
      ],
      "required_for": [
        "preferred_professional_method_support",
        "preferred_medical_research_quality_support"
      ],
      "codex_distribution": "bundled",
      "opl_distribution": "managed_dependency",
      "developer_distribution": "source_checkout",
      "install_owner": "one-person-lab",
      "install_update_source": "ghcr_capability_packages_channel",
      "sync_scopes": [
        "workspace",
        "quest"
      ],
      "sync_command_refs": [
        "opl packages activate mas --scope workspace --target-workspace <workspace-root> --json",
        "opl packages activate mas --scope quest --target-quest <quest-root> --json"
      ],
      "activation_materialization": {
        "required": false,
        "owner": "one-person-lab",
        "trigger": "mas_workspace_or_quest_activation",
        "scopes": [
          "workspace",
          "quest"
        ],
        "required_skill_ids_source": "provider_manifest_exports_core_skill_ids",
        "target_path_template": "<scope-root>/.codex/skills/<skill-id>",
        "receipt_required": false,
        "readiness_policy": "enhancement_currentness_is_diagnostic_not_mas_operational_readiness"
      },
      "missing_or_incompatible_policy": "continue_with_consumer_core_and_record_diagnostic",
      "status_command_templates": {
        "workspace": "opl packages status --package-id mas --json",
        "quest": "opl packages status --package-id mas --json"
      },
      "repair_command_templates": {
        "workspace": "opl packages repair mas --agent-root <agent-root> --json",
        "quest": "opl packages repair mas --agent-root <agent-root> --json"
      },
      "authority_boundary": {
        "can_write_domain_truth": false,
        "can_sign_owner_receipt": false,
        "can_create_typed_blocker": false,
        "can_write_runtime_queue": false
      }
    }
  ]
}
