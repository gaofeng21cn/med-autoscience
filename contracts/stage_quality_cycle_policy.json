  "cross_stage_route_selection": {
    "semantic_route_decision_owner": "decisive_codex_attempt",
    "stage_transition_materialization_owner": "opl_stage_run_controller",
    "primary_only_decisive_attempt_role": "producer",
    "formal_review_decisive_attempt_roles": [
      "reviewer",
      "re_reviewer"
    ],
    "producer_can_be_decisive_attempt_in_formal_review": false,
    "repairer_can_be_decisive_attempt": false,
    "same_stage_repair_required_with_budget_remaining_continues_quality_loop": true,
    "repair_required_review_or_re_review_may_select_cross_stage_route_back_before_budget_exhaustion": true,
    "repair_required_cross_stage_route_back_requires_target_different_from_current_stage": true,
    "cross_stage_route_back_requires_narrowest_canonical_owner_stage": true,
    "repair_required_review_or_re_review_may_select_other_terminal_route_before_budget_exhaustion": false,
    "repair_required_review_or_re_review_may_select_terminal_route_after_budget_exhaustion": true,
    "repair_budget_exhaustion_terminal_status": "completed_with_quality_debt",
    "hard_stop_or_zero_consumable_artifact_route_output": "none"
  },
  "quality_cycle_defaults": {
    "in_thread_refinement": {
      "allowed": true,
      "authoritative": false,
      "can_emit_review_receipt": false,
      "can_close_formal_review": false
    },
    "formal_review": {
      "required": true,
      "same_stage_run_required": true,
      "new_stage_attempt_required": true,
      "new_execution_session_required": true,
      "no_context_inheritance": true,
      "reviewer_session_must_differ_from_producer_session": true,
      "re_reviewer_session_must_differ_from_repairer_session": true,
      "same_base_model_allowed": true
    },
    "attempt_roles": [
      "producer",
      "reviewer",
      "repairer",
      "re_reviewer"
    ],
    "role_prompt_refs": {
      "producer": "agent/quality_gates/stage_quality_cycle_roles.md#producer",
      "reviewer": "agent/quality_gates/stage_quality_cycle_roles.md#reviewer",
      "repairer": "agent/quality_gates/stage_quality_cycle_roles.md#repairer",
      "re_reviewer": "agent/quality_gates/stage_quality_cycle_roles.md#re-reviewer"
    },
    "quality_revision_budget": {
      "max_repair_rounds": 3,
      "initial_producer_attempt_counts_as_repair_round": false,
      "round_unit": "repairer_plus_re_reviewer",
      "provider_retry_consumes_budget": false,
      "protocol_closeout_resume_consumes_budget": false,
      "owner_callable_dispatch_retry_consumes_budget": false,
      "on_exhausted_with_consumable_artifact": "completed_with_quality_debt",
      "on_exhausted_without_consumable_artifact": "typed_blocker"
    },
    "review_context_manifest": {
      "allowed_ref_families": [
        "stage_goal_or_task_brief_ref",
        "exact_artifact_ref_and_hash",
        "source_ref_and_fingerprint",
        "quality_rubric_ref",
        "necessary_artifact_lineage_ref",
        "prior_finding_ref_for_re_review"
      ],
      "forbidden_inputs": [
        "producer_conversation_history",
        "producer_thread_resume",
        "producer_reasoning_trace",
        "undeclared_ephemeral_context"
      ]
    },
    "attempt_output_contract": {
      "envelope_path": "route_impact.stage_quality_cycle",
      "outcome_field": "outcome",
      "outcome_required_for_roles": [
        "reviewer",
        "re_reviewer"
      ],
      "outcome_values": [
        "pass",
        "repair_required",
        "quality_debt",
        "blocked",
        "human_gate"
      ],
      "attempts_must_not_emit_receipt_verdict": true,
      "receipt_materializer_owner": "opl_stage_run_controller",
      "review_receipt_verdict_mapping": {
        "pass": "pass",
        "repair_required": "repair_required",
        "quality_debt": "quality_debt",
        "blocked": "hard_stop",
        "human_gate": "hard_stop"
      }
    },
    "review_receipt_required_fields": [
      "stage_run_id",
      "producer_attempt_ref",
      "reviewer_attempt_ref",
      "producer_session_ref",
      "reviewer_session_ref",
      "no_context_inheritance",
      "reviewed_artifact_refs",
      "reviewed_artifact_hashes",
      "rubric_refs",
      "verdict",
      "finding_refs"
    ],
    "review_receipt_fail_closed_conditions": [
      "reviewer_session_equals_producer_session",
      "no_context_inheritance_not_true",
      "reviewed_artifact_hash_mismatch",
      "reviewer_attempt_missing_or_not_independent"
    ],
    "initial_review_findings": {
      "required_outputs": [
        "route_impact.stage_quality_cycle.outcome",
        "route_impact.stage_quality_cycle.findings"
      ],
      "required_fields": [
        "finding_id",
        "severity",
        "required",
        "evidence_refs",
        "repair_expectation",
        "acceptance_criteria",
        "defect_owner_stage_id",
        "reviewed_artifact_ref_and_hash"
      ],
      "reviewer_can_repair_inline": false,
      "reviewer_can_create_repair_map": false,
      "route_to_earliest_root_cause_owner": true
    },
    "repair_map": {
      "required_fields": [
        "finding_id",
        "repair_status",
        "changed_artifact_refs",
        "repair_evidence_refs",
        "repairer_attempt_ref",
        "repaired_artifact_ref_and_hash"
      ],
      "one_entry_per_accepted_finding": true,
      "repairer_can_close_finding": false,
      "repairer_can_make_terminal_route_decision": false
    },
    "re_review_closure": {
      "fresh_re_reviewer_attempt_required": true,
      "reviewed_hash_must_equal_repaired_artifact_hash": true,
      "required_outputs": [
        "finding_id_closure_status_refs",
        "route_impact.stage_quality_cycle.outcome",
        "evidence_refs",
        "remaining_quality_debt_refs"
      ],
      "closure_status_values": [
        "closed",
        "partially_closed",
        "still_open"
      ],
      "next_repair_round_triggers": [
        "required_finding_not_closed",
        "repair_regression",
        "critical_new_finding"
      ],
      "ordinary_new_suggestion_policy": "optional_observation_or_quality_debt_without_reopening_loop",
      "attempt_outcome_values": [
        "pass",
        "repair_required",
        "quality_debt",
        "blocked",
        "human_gate"
      ]
    }
  },
