{
  "surface_kind": "mas_paper_study_stage_pack",
  "schema_version": 1,
  "pack_id": "mas-paper-study-domain-authority-stage-pack",
  "version": "mas-paper-study-stage-pack.v1",
  "stage_model": "paper_study_artifact_stage_pack",
  "current_truth_surface": "paper_study_stage_pack",
  "machine_boundary": {
    "role": "declarative_domain_pack_and_migration_manifest",
    "physical_study_file_migration_required": true,
    "physical_study_file_migration_target": "artifacts/stage_outputs/_body_authority/paper_authority_cutover",
    "artifact_refs_are_locators_only": true,
    "artifact_role_is_interface": true,
    "file_name_is_not_interface": true,
    "workbench_must_not_display_two_current_truths": true,
    "physical_stage_folder_kernel_source": "contracts/opl-framework/stage-artifact-runtime-contract.json",
    "legacy_declared_refs_role": "migration_historical_projection_only"
  },
  "physical_stage_folder_kernel": {
    "surface_kind": "mas_opl_physical_stage_folder_kernel_adoption",
    "contract_ref": "contracts/opl-framework/stage-artifact-runtime-contract.json",
    "source_of_truth": "OPL physical Stage Folder Kernel",
    "locator": {
      "domain_id": "med-autoscience",
      "program_id": "mas-paper-study",
      "topic_id_template": "{study_id}",
      "deliverable_id": "paper-study"
    },
    "projection_refs": [
      "deliverable_root",
      "stage_folder_ref",
      "attempt_root",
      "current_pointer_ref",
      "latest_pointer_ref",
      "manifest_ref",
      "receipt_ref",
      "manifest_hash_refs",
      "owner_receipt_refs",
      "conformance_refs"
    ],
    "legacy_declared_refs_fallback": "migration_historical_projection_only",
    "body_included": false,
    "authority_boundary": {
      "opl_can_write_mas_truth": false,
      "opl_can_create_mas_owner_receipt": false,
      "mas_keeps_domain_authority": true
    }
  },
  "authority_boundary": {
    "mas_authority_functions": [
      "study_truth",
      "source_readiness",
      "reviewer_quality",
      "publication_gate",
      "artifact_package_authority",
      "memory_accept_reject",
      "typed_blocker",
      "medical_owner_receipt"
    ],
    "opl_allowed": [
      "projection",
      "dispatch",
      "read_refs"
    ],
    "opl_forbidden": [
      "write_study_truth",
      "authorize_source_readiness",
      "authorize_reviewer_quality",
      "authorize_publication_gate",
      "authorize_artifact_package",
      "accept_or_reject_memory",
      "sign_medical_owner_receipt",
      "replace_typed_blocker"
    ],
    "artifact_first_can_determine_stage_progress": true,
    "can_write_mas_truth": false,
    "can_authorize_quality_verdict": false,
    "can_authorize_publication_readiness": false,
    "can_authorize_submission_readiness": false,
    "provider_completion_is_paper_progress": false
  },
  "mission_first_non_advancing_route_back_policy": {
    "surface_kind": "mas_mission_first_non_advancing_route_back_policy",
    "policy_id": "mas.paper_mission.non_advancing_route_back_escalation.v1",
    "version": "mission-first-non-advancing-route-back.v1",
    "applies_to_terminal_shapes": [
      "route_back",
      "domain_gate",
      "non_advancing_apply",
      "owner_answer_shape=route_back_evidence_ref",
      "paper_mission_stage_route_domain_gate_pending"
    ],
    "semantic_progress_signature": {
      "purpose": "Detect repeated route_back/domain_gate loops that do not change the mission artifact, owner answer, or next executable work unit.",
      "identity_fields": [
        "study_id",
        "paper_mission_run_id",
        "stage_id",
        "current_owner",
        "action_type",
        "work_unit_id",
        "work_unit_fingerprint",
        "route_identity_key",
        "attempt_idempotency_key",
        "required_output_surface",
        "accepted_answer_shape",
        "canonical_mission_id",
        "candidate_semantic_fingerprint",
        "normalized_route_back_reason",
        "normalized_repair_scope"
      ],
      "semantic_delta_fields": [
        "paper_facing_delta_ref",
        "owner_decision_ref",
        "owner_receipt_ref",
        "stable_typed_blocker_ref",
        "human_gate_ref",
        "route_back_evidence_ref",
        "canonical_paper_or_artifact_delta_ref",
        "ai_reviewer_or_publication_gate_delta_ref",
        "successor_work_unit_ref",
        "carry_forward_risk_receipt_ref",
        "scope_reduction_decision_ref",
        "evidence_substitution_decision_ref",
        "research_pivot_decision_ref",
        "stop_loss_decision_ref",
        "owner_decision_packet_ref",
        "claim_decision_ref",
        "scope_decision_ref",
        "evidence_decision_ref",
        "pivot_decision_ref",
        "carry_forward_decision_ref",
        "mission_executor_continuation_ref"
      ],
      "transport_only_fields_do_not_change_signature": [
        "observed_at",
        "queue_id",
        "stage_attempt_id",
        "active_run_id",
        "worker_readiness",
        "provider_liveness",
        "retry_count",
        "read_model_generated_at",
        "focused_test_result",
        "docs_or_contract_commit",
        "run_id",
        "quest_id",
        "temporal_workflow_id",
        "opl_attempt_ledger_row_id"
      ],
      "repeated_signature_without_semantic_delta_is_non_advancing": true
    },
    "budget_and_escalation_policy": {
      "first_same_signature_route_back": "record_route_back_and_require_mission_executor_next_delta",
      "second_same_signature_route_back_without_semantic_delta": "escalate_to_mas_owned_codex_executor_stage",
      "same_signature_opl_redrive_budget_after_escalation": 0,
      "transport_repair_budget_after_worker_ready": 0,
      "budget_exhaustion_is_not_completion": true,
      "opl_redrive_is_default_after_budget_exhaustion": false,
      "mas_mission_executor_fallback_priority_order": [
        "paper_facing_delta",
        "owner_decision",
        "carry_forward_risk_receipt",
        "scope_or_evidence_or_research_pivot_decision",
        "narrow_stop_loss_or_human_gate"
      ],
      "allowed_escalation_outcomes": [
        "paper_facing_delta",
        "owner_decision_ref",
        "canonical_paper_or_artifact_delta",
        "owner_receipt_ref",
        "stable_typed_blocker_ref",
        "human_gate_ref",
        "route_back_evidence_ref_with_successor_work_unit",
        "carry_forward_risk_receipt_ref",
        "scope_reduction_decision_ref",
        "evidence_substitution_decision_ref",
        "research_pivot_decision_ref",
        "stop_loss_decision_ref",
        "open_repair_lane_proposal",
        "owner_decision_packet_ref",
        "claim_decision_ref",
        "scope_decision_ref",
        "evidence_decision_ref",
        "pivot_decision_ref",
        "carry_forward_decision_ref",
        "mission_executor_continuation_ref"
      ],
      "mas_mission_executor_fallback_auto_continue": true,
      "fallback_entry_after_synonymous_budget": "mission_executor_continue_same_stage_until_semantic_delta_or_narrow_gate",
      "forbidden_budget_reset_evidence": [
        "run_id",
        "quest_id",
        "queue_id",
        "stage_attempt_id",
        "active_run_id",
        "temporal_workflow_id",
        "worker_readiness",
        "provider_liveness",
        "retry_count",
        "read_model_generated_at",
        "focused_test_result",
        "docs_or_contract_commit"
      ]
    },
    "typed_blocker_and_human_gate_narrowing_policy": {
      "typed_blocker_is_default_after_budget_exhaustion": false,
      "human_gate_is_default_after_budget_exhaustion": false,
      "missing_ideal_evidence_must_try_before_blocker": [
        "claim_strength_adjustment",
        "scope_reduction",
        "evidence_substitution",
        "carry_forward_risk_receipt",
        "research_pivot_decision"
      ],
      "typed_blocker_allowed_only_for": [
        "required_source_or_data_unavailable",
        "privacy_ethics_permission_or_credential_boundary",
        "core_publishable_result_absent",
        "no_supported_claim_scope_proxy_or_pivot_remains"
      ],
      "human_gate_allowed_only_for": [
        "human_preference_required",
        "ethics_or_permission_decision_required",
        "target_journal_or_submission_risk_tolerance_required",
        "irreversible_artifact_or_external_submission_authorization_required"
      ],
      "typed_blocker_requires_failed_fallback_attempts": [
        "claim_strength_adjustment",
        "scope_reduction",
        "evidence_substitution",
        "carry_forward_risk_receipt",
        "research_pivot_decision"
      ],
      "human_gate_requires_decision_owner_question": true,
      "typed_blocker_must_name_smallest_owner_surface": true,
      "forbidden_blocker_reasons": [
        "missing_ideal_evidence_without_scope_or_evidence_attempt",
        "queue_empty",
        "worker_not_running_without_same_identity_runtime_requirement",
        "focused_tests_only",
        "docs_or_contract_only",
        "repeated_route_back_budget_exhausted_only"
      ]
    },
    "mas_owned_codex_executor_stage": {
      "stage_type": "paper_mission_semantic_progress_executor",
      "owner": "MedAutoScience",
      "executor": "Codex CLI",
      "entry_condition": "same semantic_progress_signature repeats through route_back/domain_gate without a new semantic_delta_fields value",
      "required_output": "one of semantic artifact delta, owner receipt, stable typed blocker, human gate, route-back evidence with successor work unit, or repair-lane proposal",
      "opl_role": "transport_refs_attempts_queue_and_stage_run_lifecycle_only",
      "auto_continue_after_synonymous_budget": true,
      "fallback_stop_condition": "semantic_delta_owner_decision_narrow_typed_blocker_human_gate_or_repair_lane_proposal",
      "required_product_refs": [
        "paper_facing_delta_ref",
        "owner_decision_packet_ref",
        "claim_decision_ref",
        "scope_decision_ref",
        "evidence_decision_ref",
        "pivot_decision_ref",
        "carry_forward_decision_ref",
        "stable_typed_blocker_ref",
        "human_gate_ref",
        "mission_executor_continuation_ref"
      ]
    },
    "completion_and_readiness_forbidden_claims": [
      "DM002_ready",
      "DM003_ready",
      "submission_ready",
      "publication_ready",
      "runtime_ready",
      "provider_running",
      "paper_progress_from_repeated_route_back",
      "paper_progress_from_domain_gate_only",
      "paper_progress_from_focused_tests_or_docs",
      "paper_progress_from_canary_contract_only",
      "paper_progress_from_queue_empty",
      "paper_progress_from_opl_hydrate_only"
    ],
    "authority_boundary": {
      "mas_owns_semantic_progress_detection": true,
      "mas_owns_executor_stage_type": true,
      "opl_can_transport_route_back_refs": true,
      "opl_can_decide_semantic_progress": false,
      "opl_transport_or_worker_ready_counts_as_semantic_progress": false,
      "policy_can_write_authority_surfaces": false,
      "canary_contract_can_write_runtime_or_authority": false,
      "fallback_contract_can_write_owner_receipt_or_gate": false
    },
    "synonymous_route_back_budget_ledger": {
      "ledger_scope": "cross_run_same_study_mission_signature",
      "ledger_key_fields": [
        "study_id",
        "canonical_mission_id",
        "paper_mission_run_id",
        "stage_id",
        "current_owner",
        "action_type",
        "work_unit_id",
        "work_unit_fingerprint",
        "route_identity_key",
        "attempt_idempotency_key",
        "required_output_surface",
        "accepted_answer_shape",
        "candidate_semantic_fingerprint",
        "normalized_route_back_reason",
        "normalized_repair_scope"
      ],
      "cross_run_synonyms": [
        "route_back",
        "domain_gate",
        "owner_answer_shape=route_back_evidence_ref",
        "paper_mission_stage_route_domain_gate_pending",
        "non_advancing_apply"
      ],
      "fields_that_do_not_reset_budget": [
        "run_id",
        "quest_id",
        "queue_id",
        "stage_attempt_id",
        "active_run_id",
        "temporal_workflow_id",
        "worker_readiness",
        "provider_liveness",
        "retry_count",
        "read_model_generated_at",
        "focused_test_result",
        "docs_or_contract_commit"
      ],
      "budget_reset_requires_one_of": [
        "new_candidate_semantic_fingerprint",
        "paper_facing_delta_ref",
        "owner_decision_packet_ref",
        "claim_decision_ref",
        "scope_decision_ref",
        "evidence_decision_ref",
        "pivot_decision_ref",
        "carry_forward_decision_ref",
        "owner_receipt_ref",
        "stable_typed_blocker_ref",
        "human_gate_ref",
        "successor_work_unit_ref",
        "mission_executor_continuation_ref"
      ],
      "second_synonymous_route_back_without_reset": "enter_mas_mission_executor_fallback",
      "budget_exhaustion_result": "mas_mission_executor_must_continue_or_emit_narrow_owner_gate",
      "budget_exhaustion_can_claim_completion": false
    },
    "ai_owner_decision_product_refs": {
      "surface_kind": "mas_ai_owner_decision_product_ref_family",
      "required_when_fallback_selects_owner_decision": true,
      "ref_families": [
        "claim_decision_ref",
        "scope_decision_ref",
        "evidence_decision_ref",
        "pivot_decision_ref",
        "carry_forward_decision_ref"
      ],
      "minimum_packet_fields": [
        "study_id",
        "paper_mission_run_id",
        "decision_kind",
        "affected_claims_or_scope",
        "evidence_basis_refs",
        "residual_risk_statement",
        "next_owner",
        "successor_work_unit_ref",
        "forbidden_authority_writes"
      ],
      "decision_kind_to_ref": {
        "claim_strength_adjustment": "claim_decision_ref",
        "scope_reduction": "scope_decision_ref",
        "evidence_substitution": "evidence_decision_ref",
        "research_pivot": "pivot_decision_ref",
        "carry_forward_with_residual_risk": "carry_forward_decision_ref"
      },
      "can_authorize_submission_or_publication_ready": false,
      "can_replace_owner_receipt_or_quality_gate": false
    },
    "dm002_dm003_canary_acceptance": {
      "surface_kind": "mas_paper_mission_owner_fallback_canary_acceptance",
      "applies_to_studies": [
        "002-dm-china-us-mortality-attribution",
        "003-dpcc-primary-care-phenotype-treatment-gap"
      ],
      "success_requires_fresh_readback_one_of": [
        "paper_mission_inspect_exposes_mas_owner_fallback_semantic_ref",
        "artifact_delta_refs_include_changed_paper_facing_candidate",
        "synonymous_route_back_budget_ledger_enters_mission_executor_fallback",
        "mission_executor_outputs_ai_owner_decision_product_ref",
        "opl_stale_running_rows_rejected_as_running_proof"
      ],
      "failure_cases": [
        "tests_only",
        "queue_empty_only",
        "opl_hydrate_only",
        "docs_or_contract_only",
        "route_back_packet_without_changed_owner_answer_shape",
        "stale_opl_running_row_counted_as_provider_running"
      ],
      "canary_can_claim_submission_ready": false,
      "canary_can_claim_publication_ready": false,
      "canary_can_claim_runtime_ready": false
    }
  },
  "reviewer_revision_default_mechanism": {
    "surface_kind": "mas_reviewer_revision_default_mechanism",
    "schema_version": 1,
    "trigger": {
      "task_intake_kind": "reviewer_revision",
      "large_revision_not_fast_lane": true,
      "fast_lane_allowed_only_for": [
        "typo_or_local_wording",
        "single_formatting_or_caption_microfix",
        "existing_evidence_text_only_microfix"
      ],
      "large_revision_routes": [
        "structured_revision_checklist",
        "agent_lab_external_suite",
        "OPL FeedbackOps",
        "OMA developer work order or refs-only improvement proposal",
        "PaperMission owner closeout readback"
      ]
    },
    "structured_revision_checklist_required_items": [
      "text_revisions",
      "methods_completeness",
      "statistical_analysis",
      "tables_figures",
      "follow_up_evidence",
      "scientific_finding_pattern",
      "analysis_gap_route_back",
      "discussion_claim_guardrails",
      "figure_table_terminology_retention",
      "coverage_audit",
      "handoff_evidence_surface"
    ],
    "stage_attempt_readback_contract": {
      "must_preserve_professional_skill_invocation_refs": true,
      "professional_skill_ref_families": [
        "medical-manuscript-writing",
        "medical-manuscript-review",
        "medical-statistical-review",
        "medical-table-design",
        "medical-figure-design",
        "medical-submission-prep"
      ],
      "required_observability_fields": [
        "duration",
        "token_usage",
        "cost"
      ],
      "missing_reason_fields": [
        "missing_duration_reason",
        "missing_token_usage_reason",
        "missing_cost_reason"
      ],
      "missing_reason_policy": "typed_missing_reason_required; do_not_coerce_to_zero"
    },
    "specialist_skill_writeback_contract": {
      "surface_kind": "mas_reviewer_revision_specialist_skill_writeback_contract",
      "route": "OMA developer work order or refs-only improvement proposal",
      "target_source_of_truth": "external_repo:mas-scholar-skills",
      "target_skill_ref_families": [
        "medical-manuscript-writing",
        "medical-manuscript-review",
        "medical-statistical-review",
        "medical-table-design",
        "medical-figure-design",
        "medical-submission-prep"
      ],
      "mas_copies_professional_skill_body": false,
      "writes_study_truth": false,
      "writes_owner_receipt": false,
      "writes_typed_blocker": false,
      "writes_human_gate": false
    },
    "coverage_audit_closeout_requirement": {
      "required_for_closeout": true,
      "minimum_fields": [
        "feedback_item_id",
        "requested_change",
        "revision_action",
        "status",
        "evidence_refs",
        "remaining_gap_or_not_applicable_reason",
        "owner_readback_ref"
      ],
      "accepted_statuses": [
        "covered",
        "not_applicable_with_reason",
        "blocked_with_owner"
      ],
      "closeout_without_audit_allowed": false
    },
    "authority_boundary": {
      "mas_keeps_study_truth_and_publication_authority": true,
      "feedbackops_or_oma_can_write_study_truth": false,
      "feedbackops_or_oma_can_authorize_publication_ready": false,
      "coverage_audit_is_acceptance_evidence_not_owner_receipt": true
    }
  },
  "stages": [
    {
      "stage_id": "01-study_intake",
      "display_name": "Study Intake",
      "purpose": "Freeze the study question, source boundary, owner route, and first MAS-owned receipt surface.",
      "next_stage_ids": [
        "02-protocol_and_analysis_plan"
      ],
      "stable_artifact_roles": [
        {
          "role": "study_truth_snapshot",
          "artifact_ref": "artifacts/stage_outputs/01-study_intake/study_truth_snapshot.json"
        },
        {
          "role": "source_readiness_assessment",
          "artifact_ref": "artifacts/stage_outputs/01-study_intake/source_readiness_assessment.json"
        },
        {
          "role": "study_intake_owner_receipt",
          "artifact_ref": "artifacts/stage_outputs/01-study_intake/study_intake_owner_receipt.json"
        }
      ]
    },
    {
      "stage_id": "02-protocol_and_analysis_plan",
      "display_name": "Protocol And Analysis Plan",
      "purpose": "Materialize the protocol, endpoint/cohort lock, and statistical analysis plan before data or compute work.",
      "next_stage_ids": [
        "03-data_asset_and_cohort_build"
      ],
      "stable_artifact_roles": [
        {
          "role": "protocol_specification",
          "artifact_ref": "artifacts/stage_outputs/02-protocol_and_analysis_plan/protocol_specification.json"
        },
        {
          "role": "statistical_analysis_plan",
          "artifact_ref": "artifacts/stage_outputs/02-protocol_and_analysis_plan/statistical_analysis_plan.json"
        },
        {
          "role": "protocol_owner_receipt",
          "artifact_ref": "artifacts/stage_outputs/02-protocol_and_analysis_plan/protocol_owner_receipt.json"
        }
      ]
    },
    {
      "stage_id": "03-data_asset_and_cohort_build",
      "display_name": "Data Asset And Cohort Build",
      "purpose": "Lock data assets, cohort construction, inclusion/exclusion, and source-readiness receipt refs.",
      "next_stage_ids": [
        "04-analysis_execution"
      ],
      "stable_artifact_roles": [
        {
          "role": "data_asset_manifest",
          "artifact_ref": "artifacts/stage_outputs/03-data_asset_and_cohort_build/data_asset_manifest.json"
        },
        {
          "role": "cohort_definition_lock",
          "artifact_ref": "artifacts/stage_outputs/03-data_asset_and_cohort_build/cohort_definition_lock.json"
        },
        {
          "role": "source_readiness_receipt",
          "artifact_ref": "artifacts/stage_outputs/03-data_asset_and_cohort_build/source_readiness_receipt.json"
        }
      ]
    },
    {
      "stage_id": "04-analysis_execution",
      "display_name": "Analysis Execution",
      "purpose": "Run and record reproducible analysis execution against the locked protocol and cohort boundary.",
      "next_stage_ids": [
        "05-evidence_synthesis"
      ],
      "stable_artifact_roles": [
        {
          "role": "analysis_run_record",
          "artifact_ref": "artifacts/stage_outputs/04-analysis_execution/analysis_run_record.json"
        },
        {
          "role": "primary_results_artifact_set",
          "artifact_ref": "artifacts/stage_outputs/04-analysis_execution/primary_results_artifact_set.json"
        },
        {
          "role": "reproducibility_lineage",
          "artifact_ref": "artifacts/stage_outputs/04-analysis_execution/reproducibility_lineage.json"
        }
      ]
    },
    {
      "stage_id": "05-evidence_synthesis",
      "display_name": "Evidence Synthesis",
      "purpose": "Synthesize claim evidence, route memory decisions, and remaining gaps before authoring.",
      "next_stage_ids": [
        "06-manuscript_authoring"
      ],
      "stable_artifact_roles": [
        {
          "role": "evidence_synthesis_matrix",
          "artifact_ref": "artifacts/stage_outputs/05-evidence_synthesis/evidence_synthesis_matrix.json"
        },
        {
          "role": "claim_evidence_map",
          "artifact_ref": "artifacts/stage_outputs/05-evidence_synthesis/claim_evidence_map.json"
        },
        {
          "role": "memory_accept_reject_receipts",
          "artifact_ref": "artifacts/stage_outputs/05-evidence_synthesis/memory_accept_reject_receipts.json"
        }
      ]
    },
    {
      "stage_id": "06-manuscript_authoring",
      "display_name": "Manuscript Authoring",
      "purpose": "Produce manuscript/package refs and artifact authority receipts without making file names the interface.",
      "next_stage_ids": [
        "07-independent_review_and_revision"
      ],
      "stable_artifact_roles": [
        {
          "role": "manuscript_draft_package",
          "artifact_ref": "artifacts/stage_outputs/06-manuscript_authoring/manuscript_draft_package.json"
        },
        {
          "role": "manuscript_claim_trace",
          "artifact_ref": "artifacts/stage_outputs/06-manuscript_authoring/manuscript_claim_trace.json"
        },
