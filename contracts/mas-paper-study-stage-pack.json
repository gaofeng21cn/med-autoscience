  },
  "authority_boundary": {
    "mas_authority_functions": [
      "study_truth",
      "source_readiness",
      "reviewer_quality",
      "publication_gate",
      "artifact_package_authority",
      "memory_accept_reject",
      "typed_blocker",
      "medical_owner_receipt"
    ],
    "opl_allowed": [
      "projection",
      "dispatch",
      "read_refs"
    ],
    "opl_forbidden": [
      "write_study_truth",
      "authorize_source_readiness",
      "authorize_reviewer_quality",
      "authorize_publication_gate",
      "authorize_artifact_package",
      "accept_or_reject_memory",
      "sign_medical_owner_receipt",
