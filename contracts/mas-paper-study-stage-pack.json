      "domain_id": "med-autoscience",
      "program_id": "mas-paper-study",
      "topic_id_template": "{study_id}",
      "deliverable_id": "paper-study"
    },
    "projection_refs": [
      "deliverable_root",
      "stage_folder_ref",
      "attempt_root",
      "current_pointer_ref",
      "latest_pointer_ref",
      "manifest_ref",
      "receipt_ref",
      "manifest_hash_refs",
      "owner_receipt_refs",
      "conformance_refs"
    ],
    "legacy_declared_refs_fallback": "migration_historical_projection_only",
    "body_included": false,
    "authority_boundary": {
      "opl_can_write_mas_truth": false,
      "opl_can_create_mas_owner_receipt": false,
      "mas_keeps_domain_authority": true
