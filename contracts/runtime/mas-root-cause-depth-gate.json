{
  "surface_kind": "mas_root_cause_depth_gate",
  "version": "mas-root-cause-depth-gate.v1",
  "owner": "MedAutoScience",
  "purpose": "Machine-readable guardrail for MAS supervision, repair-lane, currentness, blocker, heartbeat, and absorption reports so they cannot close at symptom depth.",
  "machine_boundary": "This contract validates report shape and claim boundaries only. It does not create owner receipts, typed blockers, human gates, route-back evidence, runtime commands, OPL StageRun identity, provider attempts, paper deltas, publication readiness, package authority, or live runtime readiness.",
  "required_report_fields": [
    "symptom",
    "failing_boundary",
    "root_cause",
    "owner_surface",
    "fix_or_next_action",
    "proof"
  ],
  "proof_required_fields": [
    "evidence_refs",
    "proves",
    "does_not_prove"
  ],
  "depth_ladder": [
    {
      "depth": "L0_symptom",
      "meaning": "Visible status, label, blocker reason, queue state, heartbeat state, no-live-session state, or user-facing stall.",
      "can_close_repeated_or_repair_claim": false
    },
    {
      "depth": "L1_failing_boundary",
      "meaning": "The command, read model, projection, owner route, authority boundary, materializer, gate, queue, or runtime dependency that emitted the symptom.",
      "can_close_repeated_or_repair_claim": false
    },
    {
      "depth": "L2_cross_surface_evidence",
      "meaning": "At least one adjacent source of truth confirms or contradicts the boundary, such as live OPL state versus MAS projection, owner receipt versus pending candidate, source contract versus generated view, or terminal closeout versus live readback.",
      "can_close_repeated_or_repair_claim": false
    },
    {
      "depth": "L3_owner_repair_path",
      "meaning": "Names the legal owner surface, allowed and forbidden write sets, fix or next action, verification/readback, and whether the action is code repair, contract repair, owner consumption, human gate, route-back, or typed blocker.",
      "can_close_repeated_or_repair_claim": true
    },
    {
      "depth": "L4_prevention_writeback",
      "meaning": "Explains why existing workflow allowed recurrence and identifies the prompt, runbook, contract, test, automation, or owner surface that prevents the same false closeout.",
      "can_close_repeated_or_repair_claim": true
    }
  ],
  "minimum_depth_by_context": {
    "one_off_status_audit": "L2_cross_surface_evidence",
    "repeated_stall": "L3_owner_repair_path",
    "supervisor_heartbeat": "L3_owner_repair_path",
    "currentness_drift": "L3_owner_repair_path",
    "false_progress_or_readiness_claim": "L3_owner_repair_path",
    "repair_lane_proposal": "L3_owner_repair_path",
    "candidate_absorption": "L3_owner_repair_path",
    "mission_closeout": "L3_owner_repair_path",
    "thorough_root_cause_request": "L4_prevention_writeback"
  },
  "symptom_only_statuses": [
    "blocked",
    "domain_blocked",
    "waiting_human",
    "not_actionable_without_owner",
    "owner_consumption_saturation_wait",
    "handoff_required",
    "no_live_session",
    "queue_empty",
    "provider_attempt_pending",
    "current_owner_identity_unavailable_for_guard",
    "typed_blocker_required",
    "active_run_id_null",
    "candidate_count_zero"
  ],
  "forbidden_completion_interpretations": [
    "symptom_label_as_root_cause",
    "blocked_reason_as_root_cause",
    "queue_empty_as_progress",
    "domain_diagnostic_dry_run_clean_as_progress",
    "focused_tests_as_runtime_ready",
    "repair_lane_commit_as_paper_progress",
    "candidate_absorption_as_owner_path_unblocked",
    "owner_consumption_saturation_wait_as_mission_closeout",
    "current_owner_identity_unavailable_for_guard_as_owner_path_repaired",
    "provider_completion_or_transport_refs_as_paper_progress"
  ],
  "paper_progress_accounting": {
    "required_report_split": [
      "paper_or_mission_delta",
      "platform_or_observability_delta",
      "main_absorption_status",
      "root_cause_depth_status"
    ],
    "paper_progress_requires_one_of": [
      "owner_receipt_ref",
      "canonical_paper_or_artifact_delta_ref",
      "ai_reviewer_or_publication_gate_delta_ref",
      "human_gate_ref",
      "route_back_evidence_ref",
      "stable_typed_blocker_ref",
      "owner_handoff_ref"
    ],
    "platform_repair_alone_can_claim_paper_progress": false
  },
  "repair_lane_claim_boundary": {
    "absorption_statuses": [
      "absorbed_to_main",
      "candidate_ready_for_absorption",
      "open_repair_lane_proposal",
      "not_actionable_without_owner",
      "not_blocking_mission_progress"
    ],
    "absorbed_to_main_requires": [
      "target_ref_contains_repair",
      "fresh_target_ref_readback",
      "fresh_target_behavior_readback_or_focused_verification",
      "mission_impact_classification"
    ],
    "candidate_ready_for_absorption_requires": [
      "isolated_worktree_or_branch",
      "diff_or_commit_ref",
      "focused_verification",
      "fresh_readback",
      "residual_risk",
      "absorption_packet"
    ],
    "cannot_claim_owner_path_unblocked_from_guardrail_only_fix": true
  },
  "b002_b003_guardrail": {
    "current_owner_identity_unavailable_for_guard": {
      "interpretation": "guarded no-write precheck or diagnostic guard only",
      "allowed_claim": "precheck_does_not_write_forbidden_surfaces",
      "forbidden_claims": [
        "B002_owner_path_repaired",
        "owner_consumption_unblocked",
        "paper_progress",
        "publication_ready"
      ],
      "required_next_root_cause_boundary": "trace why current owner identity is not produced or transmitted by current_owner_delta, current_work_unit, owner-route read model, owner-answer, or OPL live readback surface"
    },
    "owner_consumption_saturation_wait": {
      "interpretation": "foreground package saturation symptom",
      "allowed_claim": "manual materials need owner consumption, human decision, route-back, typed blocker, or repair candidate",
      "forbidden_claims": [
        "mission_closeout",
        "paper_ready",
        "platform_repair_complete"
      ],
      "required_next_root_cause_boundary": "identify why saturated materials did not become owner receipt, route-back, typed blocker, human gate, or canonical delta"
    }
  },
  "readback_ref": "policy:mas-root-cause-depth-gate",
  "report_template": {
    "context": "repair_lane_proposal",
    "symptom": "<visible blocker/status/stall>",
    "failing_boundary": "<command/projection/owner route/authority/materializer/runtime boundary>",
    "root_cause": "<causal mechanism beyond the status label>",
    "owner_surface": "<MAS/OPL/human/source/artifact/publication/runtime owner>",
    "fix_or_next_action": "<legal repair, owner consumption, human gate, route-back, or typed blocker action>",
    "proof": {
      "evidence_refs": [
        "<fresh command/readback/test/receipt ref>"
      ],
      "proves": "<what the evidence proves>",
      "does_not_prove": "<what must not be claimed from this evidence>"
    }
  },
  "completion_claim_boundary": {
    "root_cause_depth_gate_validation_can_claim_runtime_ready": false,
    "root_cause_depth_gate_validation_can_claim_paper_progress": false,
    "audit_record_missing_required_fields_result_status": "typed_blocker_required",
    "audit_record_symptom_only_result_status": "typed_blocker_required",
    "audit_record_without_cross_surface_evidence_result_status": "typed_blocker_required",
    "repair_lane_or_closeout_below_owner_repair_path_can_close": false,
    "guardrail_only_fix_can_claim_owner_path_unblocked": false
  }
}
