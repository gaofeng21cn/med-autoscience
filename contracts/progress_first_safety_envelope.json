{
  "surface_kind": "mas_progress_first_safety_envelope",
  "version": "progress-first-safety-envelope.v1",
  "owner": "MedAutoScience",
  "state": "active_contract",
  "purpose": "Machine-readable safety envelope for Progress-first MAS/OPL operation and Light/Co-Scientist/Evo-style advisory acceleration.",
  "machine_boundary": "This contract defines false-completion prevention, currentness, receipt identity, artifact authority, and advisory sidecar boundaries. It cannot declare study truth, paper closure, publication readiness, submission readiness, quality verdicts, artifact mutation authority, memory accept/reject decisions, domain readiness, production readiness, or provider liveness.",
  "ordinary_progress_spine": [
    "current_owner_delta",
    "current_medical_stage_goal",
    "concrete_paper_evidence_reviewer_gate_delta",
    "ProgressDeltaReceipt_or_OwnerReceipt_or_TypedBlocker",
    "next_current_owner_delta"
  ],
  "global_non_authority_signals": [
    "script_success",
    "test_pass",
    "file_presence",
    "queue_completion",
    "provider_completion",
    "provider_running_proof_without_matching_owner_answer",
    "generated_surface_ready",
    "descriptor_ready",
    "zero_open_worklist",
    "read_model_currentness",
    "portal_or_workbench_projection",
    "score_or_weighted_verdict",
    "ranking_or_tournament_win",
    "opportunistic_prefetch_complete",
    "external_skill_checklist_complete",
    "sidecar_observation_memory_written",
    "same_invocation_self_review"
  ],
  "external_learning_adoption_closure_policy": {
