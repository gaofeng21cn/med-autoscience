      "Nature-skills",
      "Academic Research Skills",
      "AutoSci/OmegaWiki",
      "EvoScientist/EvoSkills",
      "ARK",
      "ARIS",
      "PaperSpine",
      "PaperOrchestra",
      "Open Auto Research",
      "Light0305/Light"
    ],
    "accepted_landing_statuses": [
      "owner_surface_landed",
      "read_model_landed",
      "sidecar_or_worker_landed",
      "sidecar_execution_slot_landed",
      "contract_projection_landed"
    ],
    "gap_statuses": [
      "contract_only_gap",
      "projection_only_gap",
      "thin_projection_landed_worker_scaleout_gap",
      "history_only_gap",
      "not_landed_gap"
    ],
    "non_landing_signals": [
      "adopt_contract",
      "reference_intake_recorded",
      "design_doc_recorded",
      "external_score_or_ranking_available",
      "checklist_or_skill_inventory_available",
      "generated_descriptor_without_consumer",
      "read_model_projection_without_owner_or_worker_consumption"
    ],
    "functional_landing_requires_one_of": [
      "mas_owner_surface_consumes_pattern",
      "generated_or_read_model_projection_is_consumed_by_owner",
      "worker_or_sidecar_execution_slot_declared",
      "single_nonblocking_external_learning_sidecar_action_declared",
      "callable_or_action_catalog_entry_declared",
      "quality_pack_consumer_declared",
      "controller_authorized_soak_declared"
    ],
    "worker_or_sidecar_boundary_requires": [
      "required_inputs",
      "allowed_writes",
      "forbidden_authority",
      "output_refs",
      "nonblocking_or_fail_open_policy",
      "verification_gate"
    ],
    "single_sidecar_action_catalog": {
      "action_type": "run_external_learning_sidecar",
      "owner": "external_learning_sidecar",
      "callable_surface": "external_learning_sidecar.run_external_learning_sidecar",
      "execution_model": "single_nonblocking_current_owner_following_sidecar",
      "allowed_writes": [
        "artifacts/supervision/requests/external_learning_sidecar/latest.json",
        "artifacts/advisory/external_learning_sidecar/latest.json"
      ],
      "forbidden_authority": [
        "external_runtime_landed",
        "admission_gate",
        "current_owner_blocker",
        "study_truth",
        "paper_body",
        "publication_eval",
        "controller_decisions",
        "current_package",
        "owner_receipt",
        "typed_blocker",
        "quality_verdict",
        "artifact_authority"
      ],
      "mainline_waits_for_sidecar": false,
      "missing_sidecar_blocks_current_owner_action": false,
      "sidecar_failure_blocks_current_owner_action": false,
      "advisory_refs_count_as_paper_progress": false,
      "candidate_source_families": [
        {
          "source_id": "PaperSpine",
          "source_status": "sidecar_or_worker_landed_refs_only_authoring_worker",
          "worker_callable_ref": "med_autoscience.external_learning_authoring_advisory.build_paperspine_manuscript_advisory",
          "candidate_ref_families": [
            "motivation_spine_ref",
