          ]
        },
        {
          "source_id": "Academic Research Skills",
          "source_status": "sidecar_or_worker_landed_refs_only_claim_support_worker",
          "worker_callable_ref": "med_autoscience.external_learning_review_advisory.build_ars_claim_support_advisory",
          "candidate_ref_families": [
