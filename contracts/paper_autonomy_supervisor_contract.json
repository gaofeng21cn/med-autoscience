{
  "surface_kind": "mas_paper_progress_policy_adapter_contract",
  "version": "paper-autonomy-supervisor.v1",
  "owner": "MedAutoScience / OPL Framework",
  "state": "active_contract",
  "purpose": "Machine-readable contract for the MAS paper progress policy adapter obligation, decision taxonomy, recovery materialization, progress accounting, and OPL substrate split.",
  "machine_boundary": "This contract defines the MAS paper progress policy adapter handshake with OPL DomainProgressTransitionRuntime. It does not declare live study truth, paper closure, publication readiness, submission readiness, quality verdicts, artifact mutation authority, current package freshness, runtime production readiness, or OPL provider liveness.",
  "source_design_ref": "docs/runtime/designs/paper_autonomy_supervisor_target.md",
  "related_contract_refs": [
    "contracts/stage_route_reconcile_contract.json",
    "contracts/paper_recovery_kernel_contract.json",
    "contracts/stage_run_kernel_profile.json",
    "contracts/progress_first_safety_envelope.json",
    "contracts/owner_receipt_contract.json",
    "contracts/stage_control_plane.json"
  ],
  "external_engineering_patterns": {
    "surface_kind": "paper_autonomy_external_engineering_patterns",
    "purpose": "Map mature workflow supervision, callback, durable state, and human-in-the-loop patterns to MAS/OPL without importing foreign runtime authority.",
    "source_refs": [
      {
        "label": "Temporal Workflow message passing",
        "url": "https://docs.temporal.io/encyclopedia/workflow-message-passing",
        "mapped_rule": "separate query, signal, and update semantics so read-model queries cannot mutate MAS truth and identity-bound updates/signals carry current workflow state"
      },
      {
        "label": "AWS Step Functions callback task token",
        "url": "https://docs.aws.amazon.com/step-functions/latest/dg/connect-to-resource.html",
        "mapped_rule": "OPL HumanGateTransport must persist the callback/resume token; MAS may only consume the token and accepted answer shape for the same current identity"
      },
      {
        "label": "Azure Scheduler Agent Supervisor",
        "url": "https://learn.microsoft.com/en-us/azure/architecture/patterns/scheduler-agent-supervisor",
        "mapped_rule": "scheduler and supervisor use a durable state store to detect failed steps while domain owner keeps authority"
      },
      {
        "label": "LangGraph interrupts and persistence",
        "url": "https://docs.langchain.com/oss/python/langgraph/interrupts",
        "mapped_rule": "human-in-the-loop interruptions must persist state and resume execution against the same current identity"
      }
    ],
    "adoption_mode": "pattern_only_no_foreign_runtime_dependency",
    "adopted_rules": [
      "query_signal_update_split",
      "opl_owned_durable_callback_resume_token",
      "scheduler_agent_supervisor_state_store",
      "persistent_interrupt_resume_same_identity",
      "identity_bound_idempotent_redrive"
    ],
    "forbidden_imports": [
      "Temporal runtime as MAS-owned scheduler",
      "Step Functions state machine as MAS authority",
      "LangGraph graph state as publication truth",
      "Azure pattern prose as machine contract"
    ]
  },
  "planning_root": {
    "desired_root": "current_owner_delta",
    "obligation_surface": "paper_autonomy_obligation",
    "decision_surface": "supervisor_decision",
    "one_obligation_per_current_owner_delta": true,
    "read_models_can_create_obligations": false,
    "query_surfaces": [
      "study_progress",
      "domain_health_diagnostic",
      "progress_portal",
      "OPL current_control_state",
      "stage_artifact_index"
    ],
    "update_surfaces": [
      "domain-health-diagnostic apply closeout consumer",
      "domain-handler dispatch",
      "owner-gate decision intake",
      "recovery materializer"
    ],
    "signal_surfaces": [
      "OPL human gate resume token",
      "owner answer callback",
      "stable typed blocker acknowledge or successor identity"
    ],
    "forbidden_roots": [
      "operator_decision_required prose",
      "queue empty",
      "provider transport succeeded",
      "trace span",
      "portal text",
      "stage index file presence"
    ]
  },
  "paper_autonomy_obligation": {
    "surface_kind": "paper_autonomy_obligation_contract",
    "id_policy": "paper-autonomy::<study_id>::<stage_id>::<action_type>::<work_unit_id>::<work_unit_fingerprint>",
    "required_identity_fields": [
      "study_id",
      "quest_id",
      "stage_id",
      "action_type",
      "work_unit_id",
      "work_unit_fingerprint",
      "route_identity_key",
      "attempt_idempotency_key",
      "owner_route_currentness_basis"
    ],
    "desired_delta_required_fields": [
      "owner",
      "target_surface",
      "required_output_ref_family"
    ],
    "expected_next_evidence_allowed": [
      "provider_admission_identity",
      "running_proof",
      "terminal_closeout",
      "owner_receipt",
      "typed_blocker",
      "human_gate_ref",
      "route_back_evidence_ref",
      "migration_receipt"
    ],
    "timeout_policy_required_fields": [
      "heartbeat_budget",
      "wall_clock_budget_seconds",
      "on_timeout"
    ],
    "pending_states_forbidden_as_terminal": [
      "operator_decision_required",
      "human_gate",
      "typed_blocker",
      "provider_admission_pending_count=0",
      "action_queue=[]"
    ],
    "same_identity_no_progress_effect": "supervisor_must_emit_recovery_human_gate_or_stable_blocker",
    "read_model_projection_policy": {
      "can_project_obligation_id": true,
      "can_project_decision_id": true,
      "can_project_next_owner": true,
      "can_mutate_obligation": false,
      "can_mark_paper_progress": false
    }
  },
  "supervisor_decision_taxonomy": {
    "surface_kind": "paper_autonomy_supervisor_decision_taxonomy",
    "decision_field": "decision",
    "allowed_decisions": [
      "execute_current_owner_delta",
      "consume_terminal_closeout",
      "materialize_recovery_action",
      "wait_for_owner_with_resume_token",
      "stop_with_stable_typed_blocker",
      "stop_with_owner_receipt"
    ],
    "decision_required_fields": [
      "identity_match",
      "evidence_refs",
      "forbidden_interpretations",
      "next_owner",
      "next_safe_action",
      "paper_progress_classification",
      "platform_repair_classification"
    ],
    "decision_cases": [
      {
        "decision": "execute_current_owner_delta",
        "next_owner": "OPL Framework",
        "next_safe_action": "admit_or_resume_stage_run",
        "required_evidence_refs": [
          "paper_autonomy_obligation_ref",
          "provider_admission_identity",
          "no_terminal_closeout_for_same_identity"
        ],
        "post_admission_evidence_refs": [
          "stage_run_identity_packet",
          "running_proof"
        ],
        "paper_progress_classification": "none_until_mas_owner_result",
        "platform_repair_classification": "transport_execution"
      },
      {
        "decision": "consume_terminal_closeout",
        "next_owner": "MedAutoScience",
        "next_safe_action": "consume_or_reject_terminal_closeout",
        "required_evidence_refs": [
          "paper_autonomy_obligation_ref",
          "terminal_closeout_packet",
          "stage_run_identity_packet",
          "same_current_identity"
        ],
        "paper_progress_classification": "depends_on_mas_closeout_consumer_output",
        "platform_repair_classification": "transport_closeout_consumption"
      },
      {
        "decision": "materialize_recovery_action",
        "next_owner": "Recovery owner",
        "next_safe_action": "materialize_recovery_work_unit_or_receipt",
        "required_evidence_refs": [
          "paper_autonomy_obligation_ref",
          "no_progress_or_inconsistency_ref",
          "recovery_kind"
        ],
        "paper_progress_classification": "none_until_owner_receipt_or_stable_blocker",
        "platform_repair_classification": "platform_repair_delta"
      },
      {
        "decision": "wait_for_owner_with_resume_token",
        "next_owner": "Human or named owner",
        "next_safe_action": "consume_opl_human_gate_resume_token",
        "required_evidence_refs": [
          "paper_autonomy_obligation_ref",
          "human_gate_ref"
        ],
        "required_resume_fields": [
          "human_gate_ref",
          "resume_token",
          "resume_token_owner",
          "mas_can_generate_resume_token",
          "allowed_decisions",
          "timeout_policy",
          "default_safe_branch",
          "current_identity"
        ],
        "resume_token_owner": "OPL Framework",
        "mas_resume_token_generation_allowed": false,
        "missing_opl_token_effect": "MAS must not synthesize a resume token; the wait state remains diagnostic-only until OPL HumanGateTransport provides the durable token/readback.",
        "paper_progress_classification": "human_gate_pending_no_credit",
        "platform_repair_classification": "wait_state"
      },
      {
        "decision": "stop_with_stable_typed_blocker",
        "next_owner": "MedAutoScience / OPL Framework",
        "next_safe_action": "publish_stable_blocker_and_stop_same_identity_redrive",
        "required_evidence_refs": [
          "paper_autonomy_obligation_ref",
          "stable_typed_blocker_ref",
          "budget_or_missing_evidence_ref"
        ],
        "paper_progress_classification": "stable_stop_loss_credit",
        "platform_repair_classification": "stop_loss"
      },
      {
        "decision": "stop_with_owner_receipt",
        "next_owner": "MedAutoScience",
        "next_safe_action": "consume_owner_receipt",
        "required_evidence_refs": [
          "paper_autonomy_obligation_ref",
          "owner_receipt_ref"
        ],
        "paper_progress_classification": "mas_owner_receipt_credit",
        "platform_repair_classification": "none"
      }
    ],
    "forbidden_decisions": [
      "operator_decision_required",
      "observe_only",
      "idle",
      "queue_empty",
      "provider_healthy",
      "read_model_refreshed"
    ]
  },
  "recovery_action_contract": {
