{
  "surface_kind": "mas_opl_stage_run_kernel_profile",
  "version": "stage-run-kernel-profile.v1",
  "domain_id": "med-autoscience",
  "owner": "MedAutoScience / OPL Framework",
  "state": "active_contract",
  "purpose": "Machine-readable StageRun Kernel profile for Stage Native execution: stage folder, stage_manifest, role artifacts, and MAS owner receipt or typed blocker.",
  "machine_boundary": "This profile defines a minimal StageRun state shell and authority boundary. It does not declare paper closure, publication readiness, domain readiness, quality readiness, artifact readiness, current_package freshness, or production readiness.",
  "source_design_ref": "human_doc:mas_opl_stage_native_state_machine",
  "stage_artifact_kernel_adoption_ref": "contracts/stage_artifact_kernel_adoption.json",
  "stage_folder_contract_ref": "contracts/opl-framework/stage-artifact-runtime-contract.json",
  "owner_receipt_contract_ref": "contracts/owner_receipt_contract.json",
  "opl_contract_refs": {
    "owner": "one-person-lab",
    "domain_repo_role": "consumer_profile_ref_only",
    "repo_local_file_required": false,
    "local_resolution_policy": "do_not_copy_opl_framework_contracts_into_domain_repo",
    "refs": [
      "contracts/opl-framework/stage-run-kernel-contract.json",
      "contracts/opl-framework/stage-manifest.schema.json",
      "contracts/opl-framework/role-artifact-ref.schema.json",
      "contracts/opl-framework/stage-owner-receipt.schema.json",
      "contracts/opl-framework/stage-typed-blocker.schema.json",
      "contracts/opl-framework/stage-artifact-runtime-contract.json"
    ]
  },
  "stage_native_unit": [
    "stage_folder",
    "stage_manifest",
    "role_artifacts",
    "owner_receipt_or_typed_blocker"
  ],
  "kernel_role": "minimal_state_shell_not_mas_controller_system",
  "stage_folder_manifest_role": "artifact_evidence_and_structure_contract",
  "transition_authority": "mas_owner_receipt_or_typed_blocker_only",
  "required_object_models": [
    "StageRun",
    "ArtifactRef",
    "OwnerReceipt",
    "TypedBlocker",
    "ReadModel"
  ],
  "stage_folder_manifest": {
    "manifest_file_name": "stage_manifest.json",
    "stage_folder_contract_ref": "contracts/opl-framework/stage-artifact-runtime-contract.json",
    "required_directories": [
      "inputs",
      "outputs",
      "receipts",
      "lineage",
      "projection"
    ],
    "required_manifest_sections": [
      "stage_run_ref",
      "required_input_artifact_refs",
      "required_role_artifacts",
      "produced_artifact_refs",
      "owner_receipt_refs",
      "typed_blocker_refs",
      "lineage_refs",
      "projection_refs"
    ],
    "role_artifact_contract": {
      "role_is_interface": true,
      "file_name_is_interface": false,
      "artifact_ref_body_included": false,
      "artifact_ref_must_include_hash": true,
      "artifact_ref_must_include_lineage": true
    },
    "closeout_contract": {
      "requires_owner_receipt_or_typed_blocker": true,
      "owner_receipt_ref_role": "domain_success_or_route_handoff_authority",
      "typed_blocker_ref_role": "domain_blocked_or_deferred_authority",
      "output_only_stage_folder_is_orphan": true
    },
    "projection_contract": {
      "projection_directory_is_authority": false,
      "projection_rebuild_source": "stage_run_event_log_and_manifest_receipt_refs",
      "current_owner_delta_ref_allowed": true
    }
  },
  "stage_run_state_machine": {
    "main_chain": [
      "Declared",
      "InputsReady",
      "Admitted",
      "Running",
      "Terminalizing",
      "DomainAccepted",
      "NextStageReady"
    ],
    "exception_states": [
      "NeedsHumanDecision",
      "NeedsExternalResource",
      "RetryScheduled",
      "TypedBlocked",
      "InfrastructureCrashed",
      "Superseded"
    ],
    "state_meanings": {
      "Declared": "Stage spec exists and input refs are not yet satisfied.",
      "InputsReady": "Required role artifacts and knowledge packet refs satisfy the entry contract.",
      "Admitted": "OPL accepted a WorkUnitRun and created task, lease, or attempt refs.",
      "Running": "Provider attempt has live proof.",
      "Terminalizing": "Provider wrote a closeout packet and OPL is ingesting terminal refs.",
      "DomainAccepted": "MAS consumed closeout and signed OwnerReceipt or TypedBlocker.",
      "NextStageReady": "Route emitted next StageRun spec, human gate, or owner action from accepted receipt/blocker."
    },
    "terminal_transition_authority": {
      "DomainAccepted": "MAS consumes closeout and signs OwnerReceipt or TypedBlocker",
      "NextStageReady": "route emitted from accepted OwnerReceipt or stable TypedBlocker"
    },
    "provider_completion_counts_as_domain_accepted": false,
    "stage_folder_files_count_as_next_stage_ready": false,
    "latest_json_counts_as_domain_accepted": false,
    "active_run_id_counts_as_paper_progress": false
  },
  "launch_admission_policy": {
    "hard_blockers": [
      "identity",
      "owner",
      "scope",
      "selected_executor",
      "authority_boundary",
      "required_role_artifacts",
      "receipt_or_blocker_shape",
      "forbidden_write",
      "replay_audit_lineage"
    ],
    "advisory_refs": [
      "prompt_refs",
      "skill_refs",
      "tool_affordance_refs",
      "knowledge_refs",
      "rubric_refs",
      "evaluation_refs"
    ],
    "advisory_refs_can_block_launch": false
  },
  "default_read_surface": {
    "root": "stage_run_current_owner_delta",
    "raw_worklist_default": false,
    "readiness_default": false,
    "replay_packet_default": false
  },
  "ordinary_progress_handoff": {
    "surface_kind": "mas_ordinary_progress_handoff_policy",
    "version": "ordinary-progress-handoff.v1",
    "default_progress_root": "current_owner_delta",
    "stage_goal_source": "stage_run_current_owner_delta",
    "executor_output_requirement": "concrete_delta",
    "accepted_closeout_shapes": [
      "ProgressDeltaReceipt",
      "OwnerReceipt",
      "TypedBlocker",
      "human_gate_ref",
      "route_back_ref"
    ],
    "progress_delta_receipt": {
      "receipt_kind": "ProgressDeltaReceipt",
      "artifact_tier": "T0_progress_delta",
      "role": "ordinary_step_handoff_not_stage_completion",
      "required_fields": [
        "receipt_kind",
        "delta_id",
        "stage_run_id",
        "stage_id",
        "current_owner",
        "changed_surface_refs",
        "produced_refs",
        "consumed_refs",
        "progress_delta_classification",
        "deliverable_progress_delta",
        "platform_repair_delta",
        "next_owner",
        "next_required_delta"
      ],
      "cannot_authorize": [
        "domain_ready",
        "publication_ready",
        "submission_ready",
        "quality_or_export_ready",
        "artifact_body_mutation",
        "artifact_authority",
        "memory_accept_reject",
        "production_ready",
        "physical_delete"
      ]
    },
    "artifact_tier_policy": {
      "tiers": [
        "T0_progress_delta",
        "T1_stage_transition",
        "T2_delivery_artifact",
        "T3_production_evidence"
      ],
      "default_tier": "T0_progress_delta",
      "ordinary_delta_requires_full_stage_artifact_manifest": false,
      "delivery_or_publication_claim_requires_tier": [
        "T2_delivery_artifact",
        "T3_production_evidence"
      ]
    },
    "readiness_jit_policy": {
      "default_mode": "just_in_time_for_current_delta",
      "check_scope_source": "stage_run_current_owner_delta.next_required_delta",
      "full_readiness_inventory_role": "audit_or_terminal_gate_only",
      "ordinary_progress_blocking_policy": "block_only_when_current_delta_needs_the_missing_readiness_or_when_safety_authority_irreversible_mutation_publication_or_submission_claim_is_at_risk",
      "cannot_require_all_surfaces_before_writing_analysis_or_review_delta": true
    },
    "audit_sidecar_policy": {
      "role": "passive_drilldown_until_folded_to_owner_delta_owner_receipt_typed_blocker_human_gate_or_route_back",
      "can_generate_default_next_action": false,
      "can_close_stage": false,
      "can_claim_domain_ready": false
    }
  },
  "coscientist_stage_strategy_boundary": {
    "stage_scope": "within_stage_execution_strategy_and_evidence_refs",
    "strategy_refs": [
      "candidate_generation_refs",
      "reflection_refs",
      "review_refs",
      "meta_review_refs",
      "ranking_refs",
      "proximity_refs",
      "evolution_refs"
    ],
    "strategy_refs_are_advisory": true,
    "strategy_refs_can_define_hardcoded_workflow": false,
    "strategy_refs_can_close_quality_gate": false,
    "strategy_refs_can_promote_stage": false,
    "quality_gate_requires_independent_reviewer_or_auditor_receipt": true,
    "promotion_requires_owner_receipt_or_stable_typed_blocker": true,
    "progress_enhancement_role": "advisory_progress_accelerator_not_control_surface",
    "progress_enhancement_mechanisms": [
      "next_delta_tournament",
      "bounded_micro_candidate_generation",
      "critique_as_repair_hint",
      "budgeted_memory_writeback",
      "triggered_meta_review",
      "opportunistic_knowledge_prefetch"
    ],
    "progress_enhancement_can_block_attempt_when_missing": false,
    "next_delta_tournament_authorizes": "single_next_attempt_only",
    "micro_candidate_unselected_branch_blocks_route": false,
    "critique_hint_can_close_quality_gate": false,
    "budgeted_memory_max_reusable_lesson_refs_per_attempt": 1,
    "meta_review_triggered_only_by": [
      "stop_loss_candidate",
      "repeated_failure",
      "human_gate_pressure",
      "claim_boundary_drift",
      "no_loop_budget_exhausted"
    ],
    "opportunistic_prefetch_mainline_waits": false,
    "platform_repair_or_prefetch_counts_as_paper_progress": false
  },
  "object_models": {
    "StageRun": {
      "owner": "opl_runtime_with_mas_stage_spec",
      "role": "minimal_stage_state_shell",
      "required_fields": [
        "stage_run_id",
        "program_id",
        "study_id",
        "stage_id",
        "generation",
        "spec_ref",
        "status",
        "observed_generation",
        "stage_folder_ref",
        "stage_manifest_ref",
        "event_log_ref"
      ],
      "authority_boundary": {
        "owns_medical_quality": false,
        "can_mutate_domain_artifact_body": false,
        "can_sign_owner_receipt": false,
        "can_replace_typed_blocker": false
      }
    },
    "ArtifactRef": {
      "owner": "mas_authority_or_opl_locator",
      "role": "immutable_role_artifact_locator_with_lineage",
      "required_fields": [
        "artifact_ref",
        "role",
        "content_hash",
        "lineage_ref",
        "stage_manifest_ref",
        "body_included"
      ],
      "body_included": false,
      "file_presence_counts_as_completion": false
    },
    "OwnerReceipt": {
      "owner": "med-autoscience",
      "role": "domain_success_or_route_handoff_receipt",
      "transition_authority": "success_or_route_handoff",
      "required_fields": [
        "receipt_id",
        "stage_run_id",
        "stage_id",
        "generation",
        "domain_owner",
        "consumed_artifact_refs",
        "produced_artifact_refs",
        "lineage_refs",
        "next_owner_delta_ref"
      ]
    },
    "TypedBlocker": {
      "owner": "med-autoscience",
      "role": "stable_domain_blocker_or_deferred_outcome",
      "transition_authority": "blocked_or_deferred_domain_outcome",
      "required_fields": [
        "blocker_id",
        "stage_run_id",
        "stage_id",
        "generation",
        "blocker_type",
        "blocking_owner",
        "blocked_surface",
        "required_input_refs",
        "next_safe_action_ref"
      ]
    },
    "ReadModel": {
      "owner": "opl_or_product_projection",
      "role": "refs_only_rebuildable_projection",
      "required_fields": [
        "projection_id",
        "stage_run_ref",
        "observed_generation",
        "source_event_log_ref",
        "owner_receipt_refs",
        "typed_blocker_refs",
        "current_owner_delta_ref"
      ],
      "authority_boundary": {
        "rebuildable_projection": true,
        "can_write_transition": false,
        "can_promote_latest_to_authority": false,
        "can_write_mas_truth": false
      }
    }
  },
  "opl_mas_boundary": {
    "opl_owns": [
      "stage_run_spec_status",
      "event_log",
      "queue",
      "hold",
      "admission",
      "lease",
      "attempt",
      "retry_dead_letter",
      "projection_rebuild"
    ],
    "mas_owns": [
      "stage_semantics",
      "study_truth",
      "publication_quality_verdict",
      "artifact_authority",
      "memory_accept_reject",
      "owner_receipt",
      "typed_blocker",
      "route_decision"
    ],
    "forbidden_opl_authority": [
      "write_mas_study_truth",
      "write_publication_eval_as_authority",
      "write_controller_decision_as_authority",
      "mutate_domain_artifact_body",
      "authorize_publication_quality",
      "sign_mas_owner_receipt",
      "replace_mas_typed_blocker"
    ],
    "forbidden_mas_claims": [
      "mas_owns_generic_queue",
      "mas_owns_generic_attempt_ledger",
      "mas_owns_generic_state_machine_runner",
      "mas_owns_generic_read_model_shell",
      "mas_controller_system_required_for_stage_run_kernel"
    ]
  },
  "legacy_runtime_wrapper_retirement": {
    "retired_mas_local_surfaces": [
      "generic_scheduler",
      "generic_runner",
      "generic_session_store",
      "generic_status_shell",
      "generic_workbench_wrapper",
      "generic_lifecycle_wrapper",
      "generic_attempt_ledger",
      "generic_queue"
    ],
    "allowed_roles": [
      "migration_input",
      "diagnostic_projection",
      "provenance_tombstone",
      "domain_authority_function_target"
    ],
    "allowed_domain_retained_surfaces": [
      "study_truth",
      "publication_quality_verdict",
      "artifact_authority",
      "owner_receipt",
      "typed_blocker",
      "domain_knowledge",
      "domain_skill",
      "domain_tool",
      "domain_quality_gate",
      "safe_action_ref"
    ],
    "forbidden_resurrection_claims": [
      "mas_owns_hosted_scheduler",
      "mas_owns_generic_runner",
      "mas_owns_session_store",
      "mas_owns_status_shell",
      "mas_owns_workbench_wrapper",
      "mas_workbench_status_can_authorize_stage_transition"
    ],
    "new_mas_local_wrapper_requires": [
      "mas_domain_authority_reason",
      "active_caller_ref",
      "no_opl_generated_parity_ref",
      "receipt_or_blocker_output_boundary",
      "retirement_gate_ref"
    ]
  },
  "projection_boundary": {
    "read_models_are_rebuildable": true,
    "latest_progress_portal_and_workbench_are_projection_only": true,
    "forbidden_transition_authority": [
      "publication_eval/latest.json",
      "controller_decisions/latest.json",
      "study_progress_projection",
      "runtime_watch_projection",
      "portal_or_workbench_status",
      "stage_folder_file_presence",
      "provider_completion",
      "active_run_id_presence"
    ],
    "allowed_projection_inputs": [
      "StageRun_event_log",
      "stage_manifest_ref",
      "artifact_refs",
      "owner_receipt_refs",
      "typed_blocker_refs",
      "current_owner_delta_ref"
    ],
    "projection_can_write_truth": false,
    "projection_can_authorize_next_stage": false
  },
  "canary_scope": {
    "first_stage_spec_id": "ai_reviewer_publication_eval_rebuild",
    "controlled_canary_evidence_ref": "contracts/stage_run_canary_evidence.json",
    "controlled_canary_evidence_scope": "controlled_fixture_not_live_domain_progress",
    "target_studies": [
      "DM002",
      "DM003"
    ],
    "coscientist_strategy_refs_required": [
      "candidate_generation_refs",
      "reflection_refs",
      "review_refs",
      "meta_review_refs"
    ],
    "coscientist_strategy_refs_authority": "advisory_within_stage_only",
    "canary_success_requires": [
      "fresh_owner_receipt_or_stable_typed_blocker",
      "stage_run_status_matches_stage_manifest",
      "study_progress_projects_stage_run_status",
      "latest_json_is_projection_not_route_authority",
      "no_legacy_scheduler_runner_session_store_status_shell_or_workbench_wrapper_authority"
    ]
  },
  "controlled_canary_operator_summary_contract": {
    "summary_ref": "contracts/stage_run_canary_evidence.json#/controlled_canary_operator_summary",
    "summary_role": "operator_read_model_summary_not_domain_truth",
    "required_sections": [
      "controlled_canary_operator_summary",
      "overclaim_boundary",
      "legacy_runtime_residue_guard"
    ],
    "required_completion_classification": "platform_repair_controlled_fixture",
    "allowed_operator_claims_are_closed_set": true,
    "forbidden_operator_claims_must_include": [
      "live_dm002_dm003_domain_progress",
      "paper_closure",
      "publication_ready",
      "artifact_mutation_authorized",
      "current_package_updated",
      "legacy_runtime_residue_authorizes_transition"
    ],
    "legacy_runtime_residue_can_authorize_transition": false,
    "operator_summary_can_write_domain_truth": false,
    "operator_summary_can_close_stage": false,
    "operator_summary_can_resume_dm002_dm003": false
  }
}
