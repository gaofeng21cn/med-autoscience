{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://one-person-lab.local/med-autoscience/mas-paper-mission-authority.input.schema.json",
  "title": "MAS paper mission authority request",
  "description": "Exact generation, accepted candidate receipts and current independent review receipts required for MAS paper-mission authority.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "surface_kind",
    "schema_version",
    "host_context",
    "mission",
    "medical_evidence",
    "generation_manifest",
    "generation_manifest_ref",
    "candidate_admissions",
    "review_authority",
    "repair_state",
    "hard_gate"
  ],
  "properties": {
    "surface_kind": {
      "const": "mas_paper_mission_authority_request"
    },
    "schema_version": {
      "const": 2
    },
    "host_context": {
      "$ref": "#/$defs/host_context"
    },
    "mission": {
      "$ref": "#/$defs/mission_identity"
    },
    "medical_evidence": {
      "$ref": "#/$defs/medical_evidence"
    },
    "generation_manifest": {
      "$ref": "mas-evidence-generation-manifest.schema.json"
    },
    "generation_manifest_ref": {
      "allOf": [
        {
          "$ref": "#/$defs/exact_ref"
        },
        {
          "properties": {
            "kind": {
              "const": "mas_generation_manifest"
            }
          },
          "type": "object"
        }
      ]
    },
    "candidate_admissions": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/candidate_admission"
      }
    },
    "review_authority": {
      "$ref": "#/$defs/review_authority"
    },
    "repair_state": {
      "$ref": "#/$defs/repair_state"
    },
    "hard_gate": {
      "$ref": "#/$defs/hard_gate"
    }
  },
  "$defs": {
    "non_empty_text": {
      "type": "string",
      "minLength": 1,
      "pattern": ".*\\S.*"
    },
    "nullable_non_empty_text": {
      "anyOf": [
        {
          "type": "null"
        },
        {
          "$ref": "#/$defs/non_empty_text"
        }
      ]
    },
    "sha256": {
      "type": "string",
      "pattern": "^(?:sha256:)?[0-9a-fA-F]{64}$"
    },
    "typed_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "ref",
        "sha256"
      ],
      "properties": {
        "kind": {
          "enum": [
            "opl_stage_run",
            "opl_stage_attempt",
            "opl_action_output",
            "mas_stage_goal",
            "mas_artifact",
            "mas_evidence",
            "mas_negative_result",
            "mas_failed_path",
            "mas_artifact_lineage",
            "mas_reproducibility",
            "mas_source_readiness_receipt",
            "mas_claim_boundary",
            "mas_review_defect",
            "mas_gate_evidence"
          ]
        },
        "ref": {
          "$ref": "#/$defs/non_empty_text"
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "exact_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "ref",
        "size_bytes",
        "sha256"
      ],
      "properties": {
        "kind": {
          "enum": [
            "opl_action_output",
            "mas_candidate_admission_receipt",
            "mas_generation_manifest",
            "mas_review_currentness_receipt",
            "mas_reviewer_receipt"
          ]
        },
        "ref": {
          "$ref": "#/$defs/non_empty_text"
        },
        "size_bytes": {
          "type": "integer",
          "minimum": 0
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "host_context": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "action_id",
        "run_ref",
        "producer_attempt_ref",
        "output_ref",
        "output_state"
      ],
      "properties": {
        "action_id": {
          "const": "paper_mission"
        },
        "run_ref": {
          "allOf": [
            {
              "$ref": "#/$defs/typed_ref"
            },
            {
              "properties": {
                "kind": {
                  "const": "opl_stage_run"
                }
              },
              "type": "object"
            }
          ]
        },
        "producer_attempt_ref": {
          "allOf": [
            {
              "$ref": "#/$defs/typed_ref"
            },
            {
              "properties": {
                "kind": {
                  "const": "opl_stage_attempt"
                }
              },
              "type": "object"
            }
          ]
        },
        "output_ref": {
          "allOf": [
            {
              "$ref": "#/$defs/exact_ref"
            },
            {
              "properties": {
                "kind": {
                  "const": "opl_action_output"
                }
              },
              "type": "object"
            }
          ]
        },
        "output_state": {
          "enum": [
            "consumable",
            "no_output",
            "damaged",
            "failed"
          ]
        }
      }
    },
    "mission_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "program_id",
        "study_id",
        "mission_id",
        "stage_id",
        "stage_goal_ref"
      ],
      "properties": {
        "program_id": {
          "$ref": "#/$defs/non_empty_text"
        },
        "study_id": {
          "$ref": "#/$defs/non_empty_text"
        },
        "mission_id": {
          "$ref": "#/$defs/non_empty_text"
        },
        "stage_id": {
          "enum": [
            "direction_and_route_selection",
            "baseline_and_evidence_setup",
            "bounded_analysis_campaign",
            "manuscript_authoring",
            "review_and_quality_gate",
            "finalize_and_publication_handoff"
          ]
        },
        "stage_goal_ref": {
          "allOf": [
            {
              "$ref": "#/$defs/typed_ref"
            },
            {
              "properties": {
                "kind": {
                  "const": "mas_stage_goal"
                }
              },
              "type": "object"
            }
          ]
        }
      }
    },
    "medical_evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_readiness_status",
        "source_readiness_receipt_ref",
        "claim_evidence_status",
        "claim_boundary_ref",
        "candidate_artifact_refs",
        "evidence_refs",
        "negative_result_refs",
        "failed_path_refs",
        "artifact_lineage_refs",
        "reproducibility_refs"
      ],
      "properties": {
        "source_readiness_status": {
          "enum": [
            "ready",
            "not_ready",
            "unknown"
          ]
        },
        "source_readiness_receipt_ref": {
          "anyOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/typed_ref"
            }
          ]
        },
        "claim_evidence_status": {
          "enum": [
            "aligned",
            "revision_required",
            "unsafe",
            "unknown"
          ]
        },
        "claim_boundary_ref": {
          "$ref": "#/$defs/typed_ref"
        },
        "candidate_artifact_refs": {
          "$ref": "#/$defs/typed_ref_array"
        },
        "evidence_refs": {
          "$ref": "#/$defs/typed_ref_array"
        },
        "negative_result_refs": {
          "$ref": "#/$defs/typed_ref_array"
        },
        "failed_path_refs": {
          "$ref": "#/$defs/typed_ref_array"
        },
        "artifact_lineage_refs": {
          "$ref": "#/$defs/typed_ref_array"
        },
        "reproducibility_refs": {
          "$ref": "#/$defs/typed_ref_array"
        }
      }
    },
    "typed_ref_array": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/typed_ref"
      }
    },
    "exact_ref_array": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/exact_ref"
      }
    },
    "candidate_admission": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "receipt_ref",
        "receipt"
      ],
      "properties": {
        "receipt_ref": {
          "allOf": [
            {
              "$ref": "#/$defs/exact_ref"
            },
            {
              "properties": {
                "kind": {
                  "const": "mas_candidate_admission_receipt"
                }
              },
              "type": "object"
            }
          ]
        },
        "receipt": {
          "$ref": "mas-candidate-admission-authority.output.schema.json#/$defs/accepted_receipt"
        }
      }
    },
    "review_authority": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "review_request_ref",
        "currentness_receipt_ref",
        "currentness_receipt"
      ],
      "properties": {
        "review_request_ref": {
          "$ref": "#/$defs/exact_ref"
        },
        "currentness_receipt_ref": {
          "$ref": "#/$defs/exact_ref"
        },
        "currentness_receipt": {
          "$ref": "#/$defs/review_currentness_receipt"
        }
      }
    },
    "review_currentness_receipt": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "receipt_kind",
        "schema_version",
        "owner",
        "authority_role",
        "authority_epoch",
        "current_generation_id",
        "current_generation_manifest_ref",
        "current_review_request_ref",
        "current_candidate_admission_receipt_refs",
        "current_review_receipt_refs",
        "superseded_generation_ids",
        "superseded_review_request_refs",
        "receipt_id",
        "receipt_size_bytes",
        "receipt_fingerprint"
      ],
      "properties": {
        "receipt_kind": {
          "const": "mas_review_currentness_receipt"
        },
        "schema_version": {
          "const": 1
        },
        "owner": {
          "const": "MedAutoScience"
        },
        "authority_role": {
          "const": "review_currentness_owner"
        },
        "authority_epoch": {
          "$ref": "#/$defs/non_empty_text"
        },
        "current_generation_id": {
          "$ref": "#/$defs/non_empty_text"
        },
        "current_generation_manifest_ref": {
          "$ref": "#/$defs/exact_ref"
        },
        "current_review_request_ref": {
          "$ref": "#/$defs/exact_ref"
        },
        "current_candidate_admission_receipt_refs": {
          "$ref": "#/$defs/exact_ref_array"
        },
        "current_review_receipt_refs": {
          "$ref": "#/$defs/exact_ref_array"
        },
        "superseded_generation_ids": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/non_empty_text"
          }
        },
        "superseded_review_request_refs": {
          "$ref": "#/$defs/exact_ref_array"
        },
        "receipt_id": {
          "type": "string",
          "pattern": "^mas-review-currentness:[0-9a-f]{64}$"
        },
        "receipt_size_bytes": {
          "type": "integer",
          "minimum": 1
        },
        "receipt_fingerprint": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "repair_state": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "attempts_used",
        "max_attempts",
        "repair_attempt_refs",
        "latest_repair_output_ref"
      ],
      "properties": {
        "status": {
          "enum": [
            "not_required",
            "pending",
            "completed",
            "exhausted",
            "failed"
          ]
        },
        "attempts_used": {
          "type": "integer",
          "minimum": 0
        },
        "max_attempts": {
          "type": "integer",
          "minimum": 0
        },
        "repair_attempt_refs": {
          "$ref": "#/$defs/typed_ref_array"
        },
        "latest_repair_output_ref": {
          "anyOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/typed_ref"
            }
          ]
        }
      }
    },
    "hard_gate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "reason_code",
        "evidence_refs",
        "next_owner",
        "resume_condition"
      ],
      "properties": {
        "kind": {
          "enum": [
            "none",
            "human_decision",
            "medical_safety",
            "source_identity",
            "source_currentness",
            "domain_authority",
            "credential",
            "irreversible_action"
          ]
        },
        "reason_code": {
          "$ref": "#/$defs/nullable_non_empty_text"
        },
        "evidence_refs": {
          "$ref": "#/$defs/typed_ref_array"
        },
        "next_owner": {
          "$ref": "#/$defs/nullable_non_empty_text"
        },
        "resume_condition": {
          "$ref": "#/$defs/nullable_non_empty_text"
        }
      }
    }
  }
}
