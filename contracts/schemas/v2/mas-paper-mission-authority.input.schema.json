{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://one-person-lab.local/med-autoscience/mas-paper-mission-authority.input.schema.json",
  "title": "MAS paper mission authority request",
  "description": "Exact typed refs and MAS medical records injected by the OPL v2 host. Paths, profiles, commands, queues, sessions, runtime ledgers and artifact bodies are intentionally absent.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "surface_kind",
    "schema_version",
    "host_context",
    "mission",
    "medical_evidence",
    "independent_review",
    "repair_state",
    "hard_gate"
  ],
  "properties": {
    "surface_kind": {
      "const": "mas_paper_mission_authority_request"
    },
    "schema_version": {
      "const": 1
    },
    "host_context": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "action_id",
        "run_ref",
        "producer_attempt_ref",
        "output_ref",
        "output_state"
      ],
      "properties": {
        "action_id": {
          "const": "paper_mission"
        },
        "run_ref": {
          "allOf": [
            {
              "$ref": "#/$defs/typed_ref"
            },
            {
              "properties": {
                "kind": {
                  "const": "opl_stage_run"
                }
              }
            }
          ]
        },
        "producer_attempt_ref": {
          "allOf": [
            {
              "$ref": "#/$defs/typed_ref"
            },
            {
              "properties": {
                "kind": {
                  "const": "opl_stage_attempt"
                }
              }
            }
          ]
        },
        "output_ref": {
          "allOf": [
            {
              "$ref": "#/$defs/typed_ref"
            },
            {
              "properties": {
                "kind": {
                  "const": "opl_action_output"
                }
              }
            }
          ]
        },
        "output_state": {
          "enum": [
            "consumable",
            "no_output",
            "damaged",
            "failed"
          ]
        }
      }
    },
    "mission": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "program_id",
        "study_id",
        "mission_id",
        "stage_id",
        "stage_goal_ref"
      ],
      "properties": {
        "program_id": {
          "$ref": "#/$defs/non_empty_text"
        },
        "study_id": {
          "$ref": "#/$defs/non_empty_text"
        },
        "mission_id": {
          "$ref": "#/$defs/non_empty_text"
        },
        "stage_id": {
          "$ref": "#/$defs/non_empty_text"
        },
        "stage_goal_ref": {
          "allOf": [
            {
              "$ref": "#/$defs/typed_ref"
            },
            {
              "properties": {
                "kind": {
                  "const": "mas_stage_goal"
                }
              }
            }
          ]
        }
      }
    },
    "medical_evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_readiness_status",
        "source_readiness_receipt_ref",
        "claim_evidence_status",
        "claim_boundary_ref",
        "candidate_artifact_refs",
        "evidence_refs",
        "negative_result_refs",
        "failed_path_refs",
        "artifact_lineage_refs",
        "reproducibility_refs"
      ],
      "properties": {
        "source_readiness_status": {
          "enum": [
            "ready",
            "not_ready",
            "unknown"
          ]
        },
        "source_readiness_receipt_ref": {
          "anyOf": [
            {
              "type": "null"
            },
            {
              "allOf": [
                {
                  "$ref": "#/$defs/typed_ref"
                },
                {
                  "properties": {
                    "kind": {
                      "const": "mas_source_readiness_receipt"
                    }
                  }
                }
              ]
            }
          ]
        },
        "claim_evidence_status": {
          "enum": [
            "aligned",
            "revision_required",
            "unsafe",
            "unknown"
          ]
        },
        "claim_boundary_ref": {
          "allOf": [
            {
              "$ref": "#/$defs/typed_ref"
            },
            {
              "properties": {
                "kind": {
                  "const": "mas_claim_boundary"
                }
              }
            }
          ]
        },
        "candidate_artifact_refs": {
          "$ref": "#/$defs/mas_artifact_refs"
        },
        "evidence_refs": {
          "$ref": "#/$defs/mas_evidence_refs"
        },
        "negative_result_refs": {
          "$ref": "#/$defs/mas_negative_result_refs"
        },
        "failed_path_refs": {
          "$ref": "#/$defs/mas_failed_path_refs"
        },
        "artifact_lineage_refs": {
          "$ref": "#/$defs/mas_artifact_lineage_refs"
        },
        "reproducibility_refs": {
          "$ref": "#/$defs/mas_reproducibility_refs"
        }
      }
    },
    "independent_review": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "reviewer_attempt_ref",
        "reviewer_receipt_ref",
        "rubric_ref",
        "reviewed_output_sha256",
        "defect_refs",
        "quality_debt_codes"
      ],
      "properties": {
        "status": {
          "enum": [
            "passed",
            "revision_required",
            "rejected",
            "not_run",
            "unavailable"
          ]
        },
        "reviewer_attempt_ref": {
          "$ref": "#/$defs/nullable_opl_stage_attempt_ref"
        },
        "reviewer_receipt_ref": {
          "$ref": "#/$defs/nullable_mas_reviewer_receipt_ref"
        },
        "rubric_ref": {
          "$ref": "#/$defs/nullable_mas_quality_rubric_ref"
        },
        "reviewed_output_sha256": {
          "anyOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/sha256"
            }
          ]
        },
        "defect_refs": {
          "$ref": "#/$defs/mas_review_defect_refs"
        },
        "quality_debt_codes": {
          "$ref": "#/$defs/unique_text_array"
        }
      }
    },
    "repair_state": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "attempts_used",
        "max_attempts",
        "repair_attempt_refs",
        "latest_repair_output_ref"
      ],
      "properties": {
        "status": {
          "enum": [
            "not_required",
            "pending",
            "completed",
            "exhausted",
            "failed"
          ]
        },
        "attempts_used": {
          "type": "integer",
          "minimum": 0
        },
        "max_attempts": {
          "type": "integer",
          "minimum": 0
        },
        "repair_attempt_refs": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "allOf": [
              {
                "$ref": "#/$defs/typed_ref"
              },
              {
                "properties": {
                  "kind": {
                    "const": "opl_stage_attempt"
                  }
                }
              }
            ]
          }
        },
        "latest_repair_output_ref": {
          "$ref": "#/$defs/nullable_opl_action_output_ref"
        }
      }
    },
    "hard_gate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "reason_code",
        "evidence_refs",
        "next_owner",
        "resume_condition"
      ],
      "properties": {
        "kind": {
          "enum": [
            "none",
            "human_decision",
            "medical_safety",
            "source_identity",
            "source_currentness",
            "domain_authority",
            "credential",
            "irreversible_action"
          ]
        },
        "reason_code": {
          "$ref": "#/$defs/nullable_non_empty_text"
        },
        "evidence_refs": {
          "$ref": "#/$defs/mas_gate_evidence_refs"
        },
        "next_owner": {
          "$ref": "#/$defs/nullable_non_empty_text"
        },
        "resume_condition": {
          "$ref": "#/$defs/nullable_non_empty_text"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "kind": {
                "const": "none"
              }
            },
            "required": [
              "kind"
            ]
          },
          "then": {
            "properties": {
              "reason_code": {
                "type": "null"
              },
              "evidence_refs": {
                "maxItems": 0
              },
              "next_owner": {
                "type": "null"
              },
              "resume_condition": {
                "type": "null"
              }
            }
          },
          "else": {
            "properties": {
              "reason_code": {
                "$ref": "#/$defs/non_empty_text"
              },
              "evidence_refs": {
                "minItems": 1
              },
              "next_owner": {
                "$ref": "#/$defs/non_empty_text"
              },
              "resume_condition": {
                "$ref": "#/$defs/non_empty_text"
              }
            }
          }
        }
      ]
    }
  },
  "$defs": {
    "non_empty_text": {
      "type": "string",
      "minLength": 1
    },
    "nullable_non_empty_text": {
      "anyOf": [
        {
          "type": "null"
        },
        {
          "$ref": "#/$defs/non_empty_text"
        }
      ]
    },
    "sha256": {
      "type": "string",
      "pattern": "^(?:sha256:)?[0-9a-fA-F]{64}$"
    },
    "typed_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "ref",
        "sha256"
      ],
      "properties": {
        "kind": {
          "enum": [
            "opl_stage_run",
            "opl_stage_attempt",
            "opl_action_output",
            "mas_stage_goal",
            "mas_artifact",
            "mas_evidence",
            "mas_negative_result",
            "mas_failed_path",
            "mas_artifact_lineage",
            "mas_reproducibility",
            "mas_source_readiness_receipt",
            "mas_claim_boundary",
            "mas_reviewer_receipt",
            "mas_quality_rubric",
            "mas_review_defect",
            "mas_gate_evidence"
          ]
        },
        "ref": {
          "$ref": "#/$defs/non_empty_text"
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "unique_text_array": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/non_empty_text"
      }
    },
    "nullable_opl_stage_attempt_ref": {
      "anyOf": [
        {
          "type": "null"
        },
        {
          "allOf": [
            {
              "$ref": "#/$defs/typed_ref"
            },
            {
              "properties": {
                "kind": {
                  "const": "opl_stage_attempt"
                }
              }
            }
          ]
        }
      ]
    },
    "nullable_opl_action_output_ref": {
      "anyOf": [
        {
          "type": "null"
        },
        {
          "allOf": [
            {
              "$ref": "#/$defs/typed_ref"
            },
            {
              "properties": {
                "kind": {
                  "const": "opl_action_output"
                }
              }
            }
          ]
        }
      ]
    },
    "nullable_mas_reviewer_receipt_ref": {
      "anyOf": [
        {
          "type": "null"
        },
        {
          "allOf": [
            {
              "$ref": "#/$defs/typed_ref"
            },
            {
              "properties": {
                "kind": {
                  "const": "mas_reviewer_receipt"
                }
              }
            }
          ]
        }
      ]
    },
    "nullable_mas_quality_rubric_ref": {
      "anyOf": [
        {
          "type": "null"
        },
        {
          "allOf": [
            {
              "$ref": "#/$defs/typed_ref"
            },
            {
              "properties": {
                "kind": {
                  "const": "mas_quality_rubric"
                }
              }
            }
          ]
        }
      ]
    },
    "mas_artifact_refs": {
      "$ref": "#/$defs/mas_artifact_ref_array"
    },
    "mas_artifact_ref_array": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "allOf": [
          {
            "$ref": "#/$defs/typed_ref"
          },
          {
            "properties": {
              "kind": {
                "const": "mas_artifact"
              }
            }
          }
        ]
      }
    },
    "mas_evidence_refs": {
      "$ref": "#/$defs/mas_evidence_ref_array"
    },
    "mas_evidence_ref_array": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "allOf": [
          {
            "$ref": "#/$defs/typed_ref"
          },
          {
            "properties": {
              "kind": {
                "const": "mas_evidence"
              }
            }
          }
        ]
      }
    },
    "mas_negative_result_refs": {
      "$ref": "#/$defs/mas_negative_result_ref_array"
    },
    "mas_negative_result_ref_array": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "allOf": [
          {
            "$ref": "#/$defs/typed_ref"
          },
          {
            "properties": {
              "kind": {
                "const": "mas_negative_result"
              }
            }
          }
        ]
      }
    },
    "mas_failed_path_refs": {
      "$ref": "#/$defs/mas_failed_path_ref_array"
    },
    "mas_failed_path_ref_array": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "allOf": [
          {
            "$ref": "#/$defs/typed_ref"
          },
          {
            "properties": {
              "kind": {
                "const": "mas_failed_path"
              }
            }
          }
        ]
      }
    },
    "mas_artifact_lineage_refs": {
      "$ref": "#/$defs/mas_artifact_lineage_ref_array"
    },
    "mas_artifact_lineage_ref_array": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "allOf": [
          {
            "$ref": "#/$defs/typed_ref"
          },
          {
            "properties": {
              "kind": {
                "const": "mas_artifact_lineage"
              }
            }
          }
        ]
      }
    },
    "mas_reproducibility_refs": {
      "$ref": "#/$defs/mas_reproducibility_ref_array"
    },
    "mas_reproducibility_ref_array": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "allOf": [
          {
            "$ref": "#/$defs/typed_ref"
          },
          {
            "properties": {
              "kind": {
                "const": "mas_reproducibility"
              }
            }
          }
        ]
      }
    },
    "mas_review_defect_refs": {
      "$ref": "#/$defs/mas_review_defect_ref_array"
    },
    "mas_review_defect_ref_array": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "allOf": [
          {
            "$ref": "#/$defs/typed_ref"
          },
          {
            "properties": {
              "kind": {
                "const": "mas_review_defect"
              }
            }
          }
        ]
      }
    },
    "mas_gate_evidence_refs": {
      "$ref": "#/$defs/mas_gate_evidence_ref_array"
    },
    "mas_gate_evidence_ref_array": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "allOf": [
          {
            "$ref": "#/$defs/typed_ref"
          },
          {
            "properties": {
              "kind": {
                "const": "mas_gate_evidence"
              }
            }
          }
        ]
      }
    }
  }
}
