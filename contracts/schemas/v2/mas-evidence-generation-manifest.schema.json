{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://one-person-lab.local/med-autoscience/mas-evidence-generation-manifest.schema.json",
  "title": "MAS evidence generation manifest",
  "description": "Canonical generation members plus byte-bound MAS review receipts. Cross-field fingerprints, required roles, scope and receipt inventories are recomputed by the MAS handler.",
  "type": "object",
  "additionalProperties": false,
  "allOf": [
    {
      "if": {
        "properties": {
          "schema_version": {
            "const": 1
          }
        }
      },
      "then": {
        "not": {
          "required": [
            "review_scopes"
          ]
        },
        "properties": {
          "artifacts": {
            "items": {
              "$ref": "#/$defs/generation_artifact_v1"
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "schema_version": {
            "const": 2
          }
        }
      },
      "then": {
        "required": [
          "review_scopes"
        ],
        "properties": {
          "artifacts": {
            "items": {
              "$ref": "#/$defs/generation_artifact_v2"
            }
          }
        }
      }
    }
  ],
  "required": [
    "surface_kind",
    "schema_version",
    "generation_id",
    "manifest_scope",
    "generation_manifest_sha256",
    "artifacts",
    "independent_review_receipts"
  ],
  "properties": {
    "surface_kind": {
      "const": "mas_evidence_generation_manifest"
    },
    "schema_version": {
      "enum": [
        1,
        2
      ]
    },
    "generation_id": {
      "$ref": "#/$defs/non_empty_text"
    },
    "manifest_scope": {
      "enum": [
        "analysis_generation",
        "manuscript_generation",
        "publication_generation"
      ]
    },
    "generation_manifest_sha256": {
      "$ref": "#/$defs/sha256"
    },
    "artifacts": {
      "type": "array",
      "minItems": 5,
      "uniqueItems": true,
      "items": {
        "oneOf": [
          {
            "$ref": "#/$defs/generation_artifact_v1"
          },
          {
            "$ref": "#/$defs/generation_artifact_v2"
          }
        ]
      }
    },
    "review_scopes": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/review_scope"
      }
    },
    "professional_skill_invocations": {
      "description": "Optional on legacy v2 manifests. Current manuscript/publication generations carry exact manuscript and Figure Skill candidate receipts. Missing receipts remain quality debt rather than an invalid legacy manifest.",
      "type": "array",
      "uniqueItems": true,
      "items": {
        "oneOf": [
          {
            "$ref": "#/$defs/professional_figure_skill_invocation"
          },
          {
            "$ref": "#/$defs/professional_manuscript_skill_invocation"
          }
        ]
      }
    },
    "independent_review_receipts": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/review_receipt_wrapper"
      }
    }
  },
  "$defs": {
    "non_empty_text": {
      "type": "string",
      "minLength": 1,
      "pattern": ".*\\S.*"
    },
    "sha256": {
      "type": "string",
      "pattern": "^(?:sha256:)?[0-9a-fA-F]{64}$"
    },
    "artifact_role": {
      "enum": [
        "source_input_digest",
        "data_release",
        "denominator_definitions",
        "analysis_script",
        "analysis_output",
        "candidate_admission_receipt",
        "canonical_manuscript",
        "claim_evidence_map",
        "citation_ledger",
        "numeric_trace",
        "reference_library",
        "table_catalog",
        "table_file",
        "figure_catalog",
        "figure_file",
        "render_environment_and_font_manifest",
        "docx",
        "pdf",
        "supplementary_output",
        "final_zip_allowlist",
        "final_zip_member",
        "submission_status",
        "publication_evaluation",
        "next_action_envelope",
        "submission_projection_manifest",
        "candidate_artifact",
        "evidence_record"
      ]
    },
    "generation_artifact_v1": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "role",
        "ref",
        "size_bytes",
        "sha256"
      ],
      "properties": {
        "role": {
          "$ref": "#/$defs/artifact_role"
        },
        "ref": {
          "$ref": "#/$defs/non_empty_text"
        },
        "size_bytes": {
          "type": "integer",
          "minimum": 0
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "generation_artifact_v2": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "member_id",
        "role",
        "ref",
        "size_bytes",
        "sha256"
      ],
      "properties": {
        "member_id": {
          "$ref": "#/$defs/non_empty_text",
          "description": "Opaque stable identity assigned by the MAS owner. It MUST NOT be derived from, or changed solely because of, ref/path/locator values. The MAS handler rejects duplicate member_id values across a v2 root inventory and within review members."
        },
        "role": {
          "$ref": "#/$defs/artifact_role"
        },
        "ref": {
          "$ref": "#/$defs/non_empty_text",
          "description": "Current locator retained for inventory, snapshot transport, and provenance. Every epistemic review-lane topology identity excludes this locator, including exact_byte_package."
        },
        "size_bytes": {
          "type": "integer",
          "minimum": 0
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "professional_figure_artifact_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "member_id",
        "role",
        "ref",
        "size_bytes",
        "sha256"
      ],
      "properties": {
        "member_id": {
          "$ref": "#/$defs/non_empty_text"
        },
        "role": {
          "const": "figure_file"
        },
        "ref": {
          "$ref": "#/$defs/non_empty_text"
        },
        "size_bytes": {
          "type": "integer",
          "minimum": 1
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "figure_template_usage": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "used",
            "decision_reason"
          ],
          "properties": {
            "used": {
              "const": false
            },
            "decision_reason": {
              "$ref": "#/$defs/non_empty_text"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "used",
            "template_id",
            "template_ref",
            "adaptation_mode",
            "semantic_match_ref",
            "transform_delta_ref"
          ],
          "properties": {
            "used": {
              "const": true
            },
            "template_id": {
              "$ref": "#/$defs/non_empty_text"
            },
            "template_ref": {
              "$ref": "#/$defs/non_empty_text"
            },
            "adaptation_mode": {
              "enum": [
                "declared_template",
                "schema_adapted_template",
                "reference_guided_new_render"
              ]
            },
            "semantic_match_ref": {
              "$ref": "#/$defs/non_empty_text"
            },
            "transform_delta_ref": {
              "$ref": "#/$defs/non_empty_text"
            }
          }
        }
      ]
    },
    "figure_text_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "embedded_title",
        "embedded_subtitle",
        "embedded_prose_footer",
        "allowed_text_roles"
      ],
      "properties": {
        "embedded_title": {
          "type": "boolean"
        },
        "embedded_subtitle": {
          "type": "boolean"
        },
        "embedded_prose_footer": {
          "type": "boolean"
        },
        "allowed_text_roles": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "enum": [
              "panel_label",
              "axis_label",
              "tick_label",
              "legend",
              "necessary_statistical_annotation",
              "graphical_abstract_copy"
            ]
          }
        }
      }
    },
    "professional_figure_skill_invocation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface_kind",
        "schema_version",
        "receipt_id",
        "figure_id",
        "figure_kind",
        "composition_mode",
        "skill_id",
        "package_id",
        "package_version",
        "package_source_ref",
        "package_source_sha256",
        "skill_source_ref",
        "skill_source_sha256",
        "invocation_id",
        "input_contract_ref",
        "input_sha256",
        "consumed_rule_refs",
        "output_artifact_bindings",
        "status",
        "refs_only",
        "authority",
        "publication_ready"
      ],
      "properties": {
        "surface_kind": {
          "const": "mas_professional_figure_skill_invocation_candidate"
        },
        "schema_version": {
          "const": 1
        },
        "receipt_id": {
          "$ref": "#/$defs/non_empty_text"
        },
        "figure_id": {
          "$ref": "#/$defs/non_empty_text"
        },
        "figure_kind": {
          "enum": [
            "evidence_figure",
            "graphical_abstract"
          ]
        },
        "composition_mode": {
          "enum": [
            "single_canvas_direct",
            "assembled_panels"
          ]
        },
        "skill_id": {
          "enum": [
            "medical-figure-design",
            "medical-figure-style",
            "medical-figure-composer"
          ]
        },
        "package_id": {
          "const": "mas-scholar-skills"
        },
        "package_version": {
          "$ref": "#/$defs/non_empty_text"
        },
        "package_source_ref": {
          "$ref": "#/$defs/non_empty_text"
        },
        "package_source_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "skill_source_ref": {
          "$ref": "#/$defs/non_empty_text"
        },
        "skill_source_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "invocation_id": {
          "$ref": "#/$defs/non_empty_text"
        },
        "input_contract_ref": {
          "$ref": "#/$defs/non_empty_text"
        },
        "input_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "consumed_rule_refs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/non_empty_text"
          }
        },
        "output_artifact_bindings": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/professional_figure_artifact_binding"
          }
        },
        "template_usage": {
          "$ref": "#/$defs/figure_template_usage"
        },
        "figure_text_policy": {
          "$ref": "#/$defs/figure_text_policy"
        },
        "status": {
          "const": "completed"
        },
        "refs_only": {
          "const": true
        },
        "authority": {
          "const": false
        },
        "publication_ready": {
          "const": false
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "skill_id": {
                "const": "medical-figure-design"
              }
            }
          },
          "then": {
            "required": [
              "template_usage",
              "figure_text_policy"
            ]
          },
          "else": {
            "not": {
              "anyOf": [
                {
                  "required": [
                    "template_usage"
                  ]
                },
                {
                  "required": [
                    "figure_text_policy"
                  ]
                }
              ]
            }
          }
        }
      ]
    },
    "professional_manuscript_skill_invocation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface_kind",
        "schema_version",
        "receipt_id",
        "skill_id",
        "package_id",
        "package_version",
        "package_source_ref",
        "package_source_sha256",
        "skill_source_ref",
        "skill_source_sha256",
        "invocation_id",
        "input_contract_ref",
        "input_sha256",
        "consumed_rule_refs",
        "output_artifact_bindings",
        "template_substitution",
        "status",
        "refs_only",
        "authority",
        "publication_ready"
      ],
      "properties": {
        "surface_kind": {
          "const": "mas_professional_manuscript_skill_invocation_candidate"
        },
        "schema_version": {
          "const": 1
        },
        "receipt_id": {
          "$ref": "#/$defs/non_empty_text"
        },
        "skill_id": {
          "enum": [
            "medical-manuscript-writing",
            "medical-registry-atlas-story-architect",
            "medical-statistical-review",
            "medical-table-design",
            "medical-submission-prep"
          ]
        },
        "package_id": {
          "const": "mas-scholar-skills"
        },
        "package_version": {
          "$ref": "#/$defs/non_empty_text"
        },
        "package_source_ref": {
          "$ref": "#/$defs/non_empty_text"
        },
        "package_source_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "skill_source_ref": {
          "$ref": "#/$defs/non_empty_text"
        },
        "skill_source_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "invocation_id": {
          "$ref": "#/$defs/non_empty_text"
        },
        "input_contract_ref": {
          "$ref": "#/$defs/non_empty_text"
        },
        "input_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "consumed_rule_refs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/non_empty_text"
          }
        },
        "output_artifact_bindings": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/generation_artifact_v2"
          }
        },
        "template_substitution": {
          "const": false
        },
        "status": {
          "const": "completed"
        },
        "refs_only": {
          "const": true
        },
        "authority": {
          "const": false
        },
        "publication_ready": {
          "const": false
        },
        "table_quality_application": {
          "$ref": "#/$defs/table_quality_application"
        }
      }
    },
    "table_quality_application": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "policy_ref",
        "template_policy",
        "coverage_status",
        "main_tables"
      ],
      "properties": {
        "schema_version": {"const": 1},
        "policy_ref": {"const": "medical-table-design#main-table-information-budget"},
        "template_policy": {"const": "reference_floor_not_required"},
        "coverage_status": {"const": "all_main_tables_assessed"},
        "main_tables": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/main_table_quality_assessment"}
        }
      }
    },
    "main_table_quality_assessment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "table_id",
        "role",
        "reader_question",
        "row_count",
        "column_count",
        "body_word_count",
        "max_cell_word_count",
        "footnote_word_count",
        "supplementary_detail_refs",
        "budget_status",
        "exception_reason",
        "final_embedding_status",
        "final_embedding_page_span",
        "standalone_notes_heading_present"
      ],
      "properties": {
        "table_id": {"$ref": "#/$defs/non_empty_text"},
        "role": {"const": "main_text"},
        "reader_question": {"$ref": "#/$defs/non_empty_text"},
        "row_count": {"type": "integer", "minimum": 0},
        "column_count": {"type": "integer", "minimum": 0},
        "body_word_count": {"type": "integer", "minimum": 0},
        "max_cell_word_count": {"type": "integer", "minimum": 0},
        "footnote_word_count": {"type": "integer", "minimum": 0},
        "supplementary_detail_refs": {
          "type": "array",
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/non_empty_text"}
        },
        "budget_status": {
          "enum": ["within_default_budget", "documented_exception"]
        },
        "exception_reason": {
          "type": ["string", "null"],
          "minLength": 1
        },
        "final_embedding_status": {"enum": ["pending", "passed"]},
        "final_embedding_page_span": {"type": "integer", "minimum": 0},
        "standalone_notes_heading_present": {"type": "boolean"}
      }
    },
    "review_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scope_policy_id",
        "scope_policy_version",
        "review_lane",
        "review_scope_sha256",
        "reviewed_members",
        "epistemic_scope"
      ],
      "properties": {
        "scope_policy_id": {
          "const": "mas_review_scope_dependency_map"
        },
        "scope_policy_version": {
          "const": 2
        },
        "review_lane": {
          "enum": [
            "medical",
            "statistical",
            "reference",
            "display",
            "publication",
            "exact_byte_package"
          ]
        },
        "review_scope_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "reviewed_members": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/generation_artifact_v2"
          }
        },
        "epistemic_scope": {
          "$ref": "#/$defs/epistemic_review_scope"
        }
      }
    },
    "epistemic_review_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface_kind",
        "version",
        "scope_id",
        "scope_kind",
        "evidence_profile",
        "trust_model",
        "reviewed_node_refs",
        "nodes",
        "dependency_edges",
        "authority_boundary"
      ],
      "properties": {
        "surface_kind": {
          "const": "opl_epistemic_review_scope"
        },
        "version": {
          "const": "opl-epistemic-review-scope.v2"
        },
        "scope_id": {
          "pattern": "^mas:(medical|statistical|reference|display|publication|exact_byte_package)$"
        },
        "scope_kind": {
          "enum": [
            "content",
            "reference",
            "display",
            "package"
          ]
        },
        "evidence_profile": {
          "const": "epistemic_provenance"
        },
        "trust_model": {
          "const": "trusted_local_workspace"
        },
        "reviewed_node_refs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/non_empty_text"
          }
        },
        "nodes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/epistemic_review_node"
          }
        },
        "dependency_edges": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/epistemic_review_edge"
          }
        },
        "authority_boundary": {
          "$ref": "#/$defs/epistemic_review_authority_boundary"
        }
      },
      "description": "MAS supplies only its domain dependency graph. Generic validation and currentness evaluation remain owned by the OPL Framework canonical contract."
    },
    "epistemic_review_node": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "node_ref",
        "node_kind",
        "role",
        "locator"
      ],
      "properties": {
        "node_ref": {
          "$ref": "#/$defs/non_empty_text"
        },
        "node_kind": {
          "enum": [
            "artifact",
            "claim",
            "provenance"
          ]
        },
        "role": {
          "enum": [
            "source_data",
            "context",
            "analysis_code",
            "analysis_parameters",
            "analysis_result",
            "claim",
            "reference_source",
            "citation_linkage",
            "visual_content",
            "render_template",
            "package_content",
            "package_wrapper"
          ]
        },
        "locator": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "ref",
            "sha256"
          ],
          "properties": {
            "ref": {
              "$ref": "#/$defs/non_empty_text"
            },
            "sha256": {
              "$ref": "#/$defs/sha256"
            }
          }
        }
      }
    },
    "epistemic_review_edge": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_ref",
        "dependent_ref",
        "relation"
      ],
      "properties": {
        "source_ref": {
          "$ref": "#/$defs/non_empty_text"
        },
        "dependent_ref": {
          "$ref": "#/$defs/non_empty_text"
        },
        "relation": {
          "enum": [
            "derived_from",
            "supports",
            "cites",
            "renders",
            "packages"
          ]
        }
      }
    },
    "epistemic_review_authority_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "hash_is_locator_or_stale_hint_only",
        "hash_is_content_authority",
        "release_integrity_is_separate",
        "framework_can_issue_domain_verdict"
      ],
      "properties": {
        "hash_is_locator_or_stale_hint_only": {
          "const": true
        },
        "hash_is_content_authority": {
          "const": false
        },
        "release_integrity_is_separate": {
          "const": true
        },
        "framework_can_issue_domain_verdict": {
          "const": false
        }
      }
    },
    "review_input_snapshot_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface_kind",
        "schema_version",
        "snapshot_manifest_ref",
        "owner_authority_ref",
        "producer_attempt_ref",
        "execution_content_binding_sha256"
      ],
      "properties": {
        "surface_kind": {
          "const": "opl_reviewer_input_snapshot_binding"
        },
        "schema_version": {
          "const": 3
        },
        "snapshot_manifest_ref": {
          "allOf": [
            {
              "$ref": "#/$defs/exact_ref"
            },
            {
              "type": "object",
              "properties": {
                "kind": {
                  "const": "opl_reviewer_input_snapshot_manifest"
                }
              }
            }
          ]
        },
        "owner_authority_ref": {
          "allOf": [
            {
              "$ref": "#/$defs/exact_ref"
            },
            {
              "type": "object",
              "properties": {
                "kind": {
                  "const": "mas_review_input_snapshot_authority"
                },
                "ref": {
                  "pattern": "^mas-review-input-snapshot-authority:[a-f0-9]{64}$"
