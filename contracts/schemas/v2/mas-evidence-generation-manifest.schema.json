{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://one-person-lab.local/med-autoscience/mas-evidence-generation-manifest.schema.json",
  "title": "MAS evidence generation manifest",
  "description": "Canonical generation members plus byte-bound MAS review receipts. Cross-field fingerprints, required roles, scope and receipt inventories are recomputed by the MAS handler.",
  "type": "object",
  "additionalProperties": false,
  "allOf": [
    {
      "if": {
        "properties": {
          "schema_version": {
            "const": 1
          }
        }
      },
      "then": {
        "not": {
          "required": [
            "review_scopes"
          ]
        },
        "properties": {
          "artifacts": {
            "items": {
              "$ref": "#/$defs/generation_artifact_v1"
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "schema_version": {
            "const": 2
          }
        }
      },
      "then": {
        "required": [
          "review_scopes"
        ],
        "properties": {
          "artifacts": {
            "items": {
              "$ref": "#/$defs/generation_artifact_v2"
            }
          }
        }
      }
    }
  ],
  "required": [
    "surface_kind",
    "schema_version",
    "generation_id",
    "manifest_scope",
    "generation_manifest_sha256",
    "artifacts",
    "independent_review_receipts"
  ],
  "properties": {
    "surface_kind": {
      "const": "mas_evidence_generation_manifest"
    },
    "schema_version": {
      "enum": [
        1,
        2
      ]
    },
    "generation_id": {
      "$ref": "#/$defs/non_empty_text"
    },
    "manifest_scope": {
      "enum": [
        "analysis_generation",
        "manuscript_generation",
        "publication_generation"
      ]
    },
    "generation_manifest_sha256": {
      "$ref": "#/$defs/sha256"
    },
    "artifacts": {
      "type": "array",
      "minItems": 5,
      "uniqueItems": true,
      "items": {
        "oneOf": [
          {
            "$ref": "#/$defs/generation_artifact_v1"
          },
          {
            "$ref": "#/$defs/generation_artifact_v2"
          }
        ]
      }
    },
    "review_scopes": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/review_scope"
      }
    },
    "professional_skill_invocations": {
      "description": "Optional on legacy v2 manifests. Current manuscript/publication generations carry exact manuscript and Figure Skill candidate receipts. Missing receipts remain quality debt rather than an invalid legacy manifest.",
      "type": "array",
      "uniqueItems": true,
      "items": {
        "oneOf": [
          {
            "$ref": "#/$defs/professional_figure_skill_invocation"
          },
          {
            "$ref": "#/$defs/professional_manuscript_skill_invocation"
          }
        ]
      }
    },
    "independent_review_receipts": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/review_receipt_wrapper"
      }
    }
  },
  "$defs": {
    "non_empty_text": {
      "type": "string",
      "minLength": 1,
      "pattern": ".*\\S.*"
    },
    "sha256": {
      "type": "string",
      "pattern": "^(?:sha256:)?[0-9a-fA-F]{64}$"
    },
    "artifact_role": {
      "enum": [
        "source_input_digest",
        "data_release",
        "denominator_definitions",
        "analysis_script",
        "analysis_output",
        "candidate_admission_receipt",
        "canonical_manuscript",
        "claim_evidence_map",
        "citation_ledger",
        "numeric_trace",
        "reference_library",
        "table_catalog",
        "table_file",
        "figure_catalog",
        "figure_file",
        "render_environment_and_font_manifest",
        "docx",
        "pdf",
        "supplementary_output",
        "final_zip_allowlist",
        "final_zip_member",
        "submission_status",
        "publication_evaluation",
        "next_action_envelope",
        "submission_projection_manifest",
        "candidate_artifact",
        "evidence_record"
      ]
    },
    "generation_artifact_v1": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "role",
        "ref",
        "size_bytes",
        "sha256"
      ],
      "properties": {
        "role": {
          "$ref": "#/$defs/artifact_role"
        },
        "ref": {
          "$ref": "#/$defs/non_empty_text"
        },
        "size_bytes": {
          "type": "integer",
          "minimum": 0
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "generation_artifact_v2": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "member_id",
        "role",
        "ref",
        "size_bytes",
        "sha256"
      ],
      "properties": {
        "member_id": {
          "$ref": "#/$defs/non_empty_text",
          "description": "Opaque stable identity assigned by the MAS owner. It MUST NOT be derived from, or changed solely because of, ref/path/locator values. The MAS handler rejects duplicate member_id values across a v2 root inventory and within review members."
        },
        "role": {
          "$ref": "#/$defs/artifact_role"
        },
        "ref": {
          "$ref": "#/$defs/non_empty_text",
          "description": "Current locator retained for inventory and provenance. Professional review-lane scope identity excludes this locator; exact_byte_package includes it."
        },
        "size_bytes": {
          "type": "integer",
          "minimum": 0
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "professional_figure_artifact_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "member_id",
        "role",
        "ref",
        "size_bytes",
        "sha256"
      ],
      "properties": {
        "member_id": {
          "$ref": "#/$defs/non_empty_text"
        },
        "role": {
          "const": "figure_file"
        },
        "ref": {
          "$ref": "#/$defs/non_empty_text"
        },
        "size_bytes": {
          "type": "integer",
          "minimum": 1
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "figure_template_usage": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "used",
            "decision_reason"
          ],
          "properties": {
            "used": {
              "const": false
            },
            "decision_reason": {
              "$ref": "#/$defs/non_empty_text"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "used",
            "template_id",
            "template_ref",
            "adaptation_mode",
            "semantic_match_ref",
            "transform_delta_ref"
          ],
          "properties": {
            "used": {
              "const": true
            },
            "template_id": {
              "$ref": "#/$defs/non_empty_text"
            },
            "template_ref": {
              "$ref": "#/$defs/non_empty_text"
            },
            "adaptation_mode": {
              "enum": [
                "declared_template",
                "schema_adapted_template",
                "reference_guided_new_render"
              ]
            },
            "semantic_match_ref": {
              "$ref": "#/$defs/non_empty_text"
            },
            "transform_delta_ref": {
              "$ref": "#/$defs/non_empty_text"
            }
          }
        }
      ]
    },
    "figure_text_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "embedded_title",
        "embedded_subtitle",
        "embedded_prose_footer",
        "allowed_text_roles"
      ],
      "properties": {
        "embedded_title": {
          "type": "boolean"
        },
        "embedded_subtitle": {
          "type": "boolean"
        },
        "embedded_prose_footer": {
          "type": "boolean"
        },
        "allowed_text_roles": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "enum": [
              "panel_label",
              "axis_label",
              "tick_label",
              "legend",
              "necessary_statistical_annotation",
              "graphical_abstract_copy"
            ]
          }
        }
      }
    },
    "professional_figure_skill_invocation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface_kind",
        "schema_version",
        "receipt_id",
        "figure_id",
        "figure_kind",
        "composition_mode",
        "skill_id",
        "package_id",
        "package_version",
        "package_source_ref",
        "package_source_sha256",
        "skill_source_ref",
        "skill_source_sha256",
        "invocation_id",
        "input_contract_ref",
        "input_sha256",
        "consumed_rule_refs",
        "output_artifact_bindings",
        "status",
        "refs_only",
        "authority",
        "publication_ready"
      ],
      "properties": {
        "surface_kind": {
          "const": "mas_professional_figure_skill_invocation_candidate"
        },
        "schema_version": {
          "const": 1
        },
        "receipt_id": {
          "$ref": "#/$defs/non_empty_text"
        },
        "figure_id": {
          "$ref": "#/$defs/non_empty_text"
        },
        "figure_kind": {
          "enum": [
            "evidence_figure",
            "graphical_abstract"
          ]
        },
        "composition_mode": {
          "enum": [
            "single_canvas_direct",
            "assembled_panels"
          ]
        },
        "skill_id": {
          "enum": [
            "medical-figure-design",
            "medical-figure-style",
            "medical-figure-composer"
          ]
        },
        "package_id": {
          "const": "mas-scholar-skills"
        },
        "package_version": {
          "$ref": "#/$defs/non_empty_text"
        },
        "package_source_ref": {
          "$ref": "#/$defs/non_empty_text"
        },
        "package_source_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "skill_source_ref": {
          "$ref": "#/$defs/non_empty_text"
        },
        "skill_source_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "invocation_id": {
          "$ref": "#/$defs/non_empty_text"
        },
        "input_contract_ref": {
          "$ref": "#/$defs/non_empty_text"
        },
        "input_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "consumed_rule_refs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/non_empty_text"
          }
        },
        "output_artifact_bindings": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/professional_figure_artifact_binding"
          }
        },
        "template_usage": {
          "$ref": "#/$defs/figure_template_usage"
        },
        "figure_text_policy": {
          "$ref": "#/$defs/figure_text_policy"
        },
        "status": {
          "const": "completed"
        },
        "refs_only": {
          "const": true
        },
        "authority": {
          "const": false
        },
        "publication_ready": {
          "const": false
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "skill_id": {
                "const": "medical-figure-design"
              }
            }
          },
          "then": {
            "required": [
              "template_usage",
              "figure_text_policy"
            ]
          },
          "else": {
            "not": {
              "anyOf": [
                {
                  "required": [
                    "template_usage"
                  ]
                },
                {
                  "required": [
                    "figure_text_policy"
                  ]
                }
              ]
            }
          }
        }
      ]
    },
    "professional_manuscript_skill_invocation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface_kind",
        "schema_version",
        "receipt_id",
        "skill_id",
        "package_id",
        "package_version",
        "package_source_ref",
        "package_source_sha256",
        "skill_source_ref",
        "skill_source_sha256",
        "invocation_id",
        "input_contract_ref",
        "input_sha256",
        "consumed_rule_refs",
        "output_artifact_bindings",
        "template_substitution",
        "status",
        "refs_only",
        "authority",
        "publication_ready"
      ],
      "properties": {
        "surface_kind": {
          "const": "mas_professional_manuscript_skill_invocation_candidate"
        },
        "schema_version": {
          "const": 1
        },
        "receipt_id": {
          "$ref": "#/$defs/non_empty_text"
        },
        "skill_id": {
          "enum": [
            "medical-manuscript-writing",
            "medical-registry-atlas-story-architect",
            "medical-statistical-review",
            "medical-table-design"
          ]
        },
        "package_id": {
          "const": "mas-scholar-skills"
        },
        "package_version": {
          "$ref": "#/$defs/non_empty_text"
        },
        "package_source_ref": {
          "$ref": "#/$defs/non_empty_text"
        },
        "package_source_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "skill_source_ref": {
          "$ref": "#/$defs/non_empty_text"
        },
        "skill_source_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "invocation_id": {
          "$ref": "#/$defs/non_empty_text"
        },
        "input_contract_ref": {
          "$ref": "#/$defs/non_empty_text"
        },
        "input_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "consumed_rule_refs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/non_empty_text"
          }
        },
        "output_artifact_bindings": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/generation_artifact_v2"
          }
        },
        "template_substitution": {
          "const": false
        },
        "status": {
          "const": "completed"
        },
        "refs_only": {
          "const": true
        },
        "authority": {
          "const": false
        },
        "publication_ready": {
          "const": false
        }
      }
    },
    "review_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scope_policy_id",
        "scope_policy_version",
        "review_lane",
        "review_scope_sha256",
        "reviewed_members"
      ],
      "properties": {
        "scope_policy_id": {
          "const": "mas_review_scope_dependency_map"
        },
        "scope_policy_version": {
          "const": 1
        },
        "review_lane": {
          "enum": [
            "medical",
            "statistical",
            "reference",
            "display",
            "publication",
            "exact_byte_package"
          ]
        },
        "review_scope_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "reviewed_members": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/generation_artifact_v2"
          }
        }
      }
    },
    "review_input_snapshot_member": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "member_id",
        "role",
        "sha256",
        "size_bytes"
      ],
      "properties": {
        "member_id": {
          "$ref": "#/$defs/non_empty_text"
        },
        "role": {
          "$ref": "#/$defs/artifact_role"
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        },
        "size_bytes": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "review_input_snapshot_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface_kind",
        "schema_version",
        "snapshot_manifest_ref",
        "review_lane",
        "review_scope_sha256",
        "members"
      ],
      "properties": {
        "surface_kind": {
          "const": "mas_review_input_snapshot_binding"
        },
        "schema_version": {
          "const": 1
        },
        "generation_ref": {
          "$ref": "#/$defs/non_empty_text"
        },
        "mas_authority_record_ref": {
          "allOf": [
            {
              "$ref": "#/$defs/exact_ref"
            },
            {
              "type": "object",
              "properties": {
                "kind": {
                  "const": "mas_review_input_snapshot_authority"
                },
                "ref": {
                  "pattern": "^mas-review-input-snapshot-authority:[a-f0-9]{64}$"
                },
                "size_bytes": {
                  "minimum": 1
                }
              }
            }
          ]
        },
        "materialization_owner": {
          "const": "one-person-lab"
        },
        "snapshot_manifest_ref": {
          "allOf": [
            {
              "$ref": "#/$defs/exact_ref"
            },
            {
              "properties": {
                "kind": {
                  "const": "opl_reviewer_input_snapshot_manifest"
                }
              },
              "type": "object"
            }
          ]
        },
        "review_lane": {
          "enum": [
            "medical",
            "statistical",
            "reference",
            "display",
            "publication",
            "exact_byte_package"
          ]
        },
        "review_scope_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "members": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/review_input_snapshot_member"
          }
        },
        "authority_boundary": {
          "$ref": "#/$defs/review_input_snapshot_authority_boundary"
        }
      },
      "dependentRequired": {
        "materialization_owner": [
          "authority_boundary"
        ],
        "authority_boundary": [
          "materialization_owner"
        ],
        "generation_ref": [
          "mas_authority_record_ref"
        ],
        "mas_authority_record_ref": [
          "generation_ref"
        ]
      },
      "description": "Optional only for byte compatibility with legacy v2 receipts. A v2 receipt without the immutable OPL snapshot binding, or with a legacy binding that omits materialization owner metadata, is lane-specific quality debt and cannot produce an owner receipt."
    },
    "review_input_snapshot_authority_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "storage_role",
        "mas_selects_review_lane_scope_and_members",
        "framework_can_select_or_narrow_members",
        "framework_can_interpret_member_roles",
        "framework_can_write_domain_truth",
        "framework_can_sign_reviewer_receipt",
        "framework_can_sign_owner_receipt",
        "framework_can_create_typed_blocker",
        "framework_can_claim_quality_readiness",
        "framework_can_claim_publication_readiness",
        "framework_can_claim_artifact_authority"
      ],
      "properties": {
        "storage_role": {
          "const": "immutable_reviewer_input_transport"
        },
        "mas_selects_review_lane_scope_and_members": {
          "const": true
        },
        "framework_can_select_or_narrow_members": {
          "const": false
        },
        "framework_can_interpret_member_roles": {
          "const": false
        },
        "framework_can_write_domain_truth": {
          "const": false
        },
        "framework_can_sign_reviewer_receipt": {
          "const": false
        },
        "framework_can_sign_owner_receipt": {
          "const": false
        },
        "framework_can_create_typed_blocker": {
          "const": false
        },
        "framework_can_claim_quality_readiness": {
          "const": false
        },
        "framework_can_claim_publication_readiness": {
          "const": false
        },
        "framework_can_claim_artifact_authority": {
          "const": false
        }
      }
    },
    "typed_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "ref",
        "sha256"
      ],
      "properties": {
        "kind": {
          "enum": [
            "opl_stage_attempt",
            "mas_quality_rubric",
            "mas_review_defect"
          ]
        },
        "ref": {
          "$ref": "#/$defs/non_empty_text"
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "exact_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "ref",
        "size_bytes",
        "sha256"
      ],
      "properties": {
        "kind": {
          "enum": [
            "opl_action_output",
            "opl_reviewer_input_snapshot_manifest",
            "mas_review_input_snapshot_authority",
            "mas_candidate_admission_receipt",
            "mas_reviewer_receipt"
          ]
        },
        "ref": {
          "$ref": "#/$defs/non_empty_text"
        },
        "size_bytes": {
          "type": "integer",
          "minimum": 0
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "review_receipt_wrapper": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "receipt_ref",
        "receipt"
      ],
      "properties": {
        "receipt_ref": {
          "allOf": [
            {
              "$ref": "#/$defs/exact_ref"
            },
            {
              "properties": {
                "kind": {
                  "const": "mas_reviewer_receipt"
                },
                "ref": {
                  "type": "string",
                  "pattern": "^mas-independent-review-receipt:(medical|statistical|reference|display|publication|exact_byte_package):[0-9a-f]{64}$"
                }
              },
              "type": "object"
            }
          ]
        },
        "receipt": {
          "$ref": "#/$defs/review_receipt"
        }
      }
    },
    "review_receipt": {
      "oneOf": [
        {
          "$ref": "#/$defs/review_receipt_v1"
        },
        {
          "$ref": "#/$defs/review_receipt_v2"
        }
      ]
    },
    "review_receipt_v1": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "receipt_kind",
        "schema_version",
        "issuer",
        "authority_role",
        "authority_epoch",
        "review_lane",
        "verdict",
        "review_request_ref",
        "producer_output_ref",
        "reviewer_attempt_ref",
        "rubric_ref",
        "generation_id",
        "generation_manifest_sha256",
        "reviewed_members",
        "accepted_candidate_receipt_refs",
        "defect_refs",
        "quality_debt_codes"
      ],
      "properties": {
        "receipt_kind": {
          "const": "mas_independent_review_receipt"
        },
        "schema_version": {
          "const": 1
        },
        "issuer": {
          "const": "MedAutoScience"
        },
        "authority_role": {
          "enum": [
