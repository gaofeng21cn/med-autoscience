{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://one-person-lab.local/med-autoscience/mas-paper-mission-authority.output.schema.json",
  "title": "MAS paper mission authority result",
  "description": "Status-discriminated MAS result over exact candidate, generation, review-currentness, and independent-review receipts.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "surface_kind",
    "schema_version",
    "status",
    "mission_identity",
    "host_refs",
    "generation_identity",
    "stage_outcome",
    "owner_receipt",
    "route_back",
    "typed_blocker",
    "human_gate",
    "quality_debt",
    "error",
    "authority_boundary",
    "decision_id",
    "decision_fingerprint"
  ],
  "properties": {
    "surface_kind": {
      "const": "mas_paper_mission_authority_result"
    },
    "schema_version": {
      "const": 2
    },
    "status": {
      "enum": [
        "owner_receipt",
        "route_back",
        "completed_with_quality_debt",
        "typed_blocker",
        "human_gate",
        "invalid_host_input"
      ]
    },
    "mission_identity": {
      "anyOf": [
        {
          "type": "null"
        },
        {
          "$ref": "#/$defs/mission_identity"
        }
      ]
    },
    "host_refs": {
      "anyOf": [
        {
          "type": "null"
        },
        {
          "$ref": "#/$defs/host_refs"
        }
      ]
    },
    "generation_identity": {
      "anyOf": [
        {
          "type": "null"
        },
        {
          "$ref": "#/$defs/generation_identity"
        }
      ]
    },
    "stage_outcome": {
      "$ref": "#/$defs/stage_outcome"
    },
    "owner_receipt": {
      "anyOf": [
        {
          "type": "null"
        },
        {
          "$ref": "#/$defs/owner_receipt"
        }
      ]
    },
    "route_back": {
      "anyOf": [
        {
          "type": "null"
        },
        {
          "$ref": "#/$defs/route_back"
        }
      ]
    },
    "typed_blocker": {
      "anyOf": [
        {
          "type": "null"
        },
        {
          "$ref": "#/$defs/typed_blocker"
        }
      ]
    },
    "human_gate": {
      "anyOf": [
        {
          "type": "null"
        },
        {
          "$ref": "#/$defs/human_gate"
        }
      ]
    },
    "quality_debt": {
      "anyOf": [
        {
          "type": "null"
        },
        {
          "$ref": "#/$defs/quality_debt"
        }
      ]
    },
    "error": {
      "anyOf": [
        {
          "type": "null"
        },
        {
          "$ref": "#/$defs/error"
        }
      ]
    },
    "authority_boundary": {
      "$ref": "#/$defs/authority_boundary"
    },
    "decision_id": {
      "type": "string",
      "pattern": "^mas-paper-mission-authority:[0-9a-f]{64}$"
    },
    "decision_fingerprint": {
      "$ref": "#/$defs/sha256"
    }
  },
  "oneOf": [
    {
      "$ref": "#/$defs/owner_receipt_result"
    },
    {
      "$ref": "#/$defs/route_back_result"
    },
    {
      "$ref": "#/$defs/quality_debt_result"
    },
    {
      "$ref": "#/$defs/typed_blocker_result"
    },
    {
      "$ref": "#/$defs/human_gate_result"
    },
    {
      "$ref": "#/$defs/invalid_host_input_result"
    }
  ],
  "$defs": {
    "non_empty_text": {
      "type": "string",
      "minLength": 1,
      "pattern": ".*\\S.*"
    },
    "sha256": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "text_array": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/non_empty_text"
      }
    },
    "typed_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "ref",
        "sha256"
      ],
      "properties": {
        "kind": {
          "$ref": "#/$defs/non_empty_text"
        },
        "ref": {
          "$ref": "#/$defs/non_empty_text"
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "exact_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "ref",
        "size_bytes",
        "sha256"
      ],
      "properties": {
        "kind": {
          "$ref": "#/$defs/non_empty_text"
        },
        "ref": {
          "$ref": "#/$defs/non_empty_text"
        },
        "size_bytes": {
          "type": "integer",
          "minimum": 0
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "typed_ref_array": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/typed_ref"
      }
    },
    "exact_ref_array": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/exact_ref"
      }
    },
    "mission_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "program_id",
        "study_id",
        "mission_id",
        "stage_id",
        "stage_goal_ref"
      ],
      "properties": {
        "program_id": {
          "$ref": "#/$defs/non_empty_text"
        },
        "study_id": {
          "$ref": "#/$defs/non_empty_text"
        },
        "mission_id": {
          "$ref": "#/$defs/non_empty_text"
        },
        "stage_id": {
          "$ref": "#/$defs/non_empty_text"
        },
        "stage_goal_ref": {
          "$ref": "#/$defs/typed_ref"
        }
      }
    },
    "host_refs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "run_ref",
        "producer_attempt_ref",
        "output_ref"
      ],
      "properties": {
        "run_ref": {
          "$ref": "#/$defs/typed_ref"
        },
        "producer_attempt_ref": {
          "$ref": "#/$defs/typed_ref"
        },
        "output_ref": {
          "$ref": "#/$defs/exact_ref"
        }
      }
    },
    "generation_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "generation_id",
        "manifest_scope",
        "generation_manifest_ref",
        "review_authority_epoch",
        "review_request_ref"
      ],
      "properties": {
        "generation_id": {
          "$ref": "#/$defs/non_empty_text"
        },
        "manifest_scope": {
          "enum": [
            "analysis_generation",
            "manuscript_generation",
            "publication_generation"
          ]
        },
        "generation_manifest_ref": {
          "$ref": "#/$defs/exact_ref"
        },
        "review_authority_epoch": {
          "$ref": "#/$defs/non_empty_text"
        },
        "review_request_ref": {
          "$ref": "#/$defs/exact_ref"
        }
      }
    },
    "stage_outcome": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "stage_transition_allowed",
        "selects_next_stage",
        "publication_or_submission_ready"
      ],
      "properties": {
        "kind": {
          "enum": [
            "completed",
            "route_back",
            "completed_with_quality_debt",
            "typed_blocker",
            "human_gate",
            "invalid_host_input"
          ]
        },
        "stage_transition_allowed": {
          "type": "boolean"
        },
        "selects_next_stage": {
          "const": false
        },
        "publication_or_submission_ready": {
          "const": false
        }
      }
    },
    "claim_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "claim_classes",
        "claim_ids",
        "permitted_sections",
        "required_disclosures",
        "prohibited_claims",
        "sensitivity_only",
        "supplementary_only",
        "abstract_headline_allowed"
      ],
      "properties": {
        "claim_classes": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "enum": [
              "primary",
              "secondary",
              "post_hoc",
              "exploratory",
              "descriptive",
              "sensitivity",
              "supplementary_only",
              "provenance_only"
            ]
          }
        },
        "claim_ids": {
          "$ref": "#/$defs/text_array"
        },
        "permitted_sections": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "enum": [
              "abstract",
              "methods",
              "results",
              "discussion",
              "table",
              "figure",
              "supplement",
              "citation_ledger",
              "numeric_trace"
            ]
          }
        },
        "required_disclosures": {
          "$ref": "#/$defs/text_array"
        },
        "prohibited_claims": {
          "$ref": "#/$defs/text_array"
        },
        "sensitivity_only": {
          "type": "boolean"
        },
        "supplementary_only": {
          "type": "boolean"
        },
        "abstract_headline_allowed": {
          "type": "boolean"
        }
      }
    },
    "accepted_candidate_admission": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "candidate_id",
        "candidate_ref",
        "receipt_ref",
        "claim_scope"
      ],
      "properties": {
        "candidate_id": {
          "$ref": "#/$defs/non_empty_text"
        },
        "candidate_ref": {
          "$ref": "#/$defs/exact_ref"
        },
        "receipt_ref": {
          "$ref": "#/$defs/exact_ref"
        },
        "claim_scope": {
          "$ref": "#/$defs/claim_scope"
        }
      }
    },
    "generation_artifact_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "role",
        "ref",
        "size_bytes",
        "sha256"
      ],
      "properties": {
        "role": {
          "enum": [
            "submission_status",
            "publication_evaluation",
            "next_action_envelope",
            "submission_projection_manifest"
          ]
        },
        "ref": {
          "$ref": "#/$defs/non_empty_text"
        },
        "size_bytes": {
          "type": "integer",
          "minimum": 0
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "artifact_projection_transport": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface_kind",
        "schema_version",
        "transport_owner",
        "transport_action_id",
        "request_contract_ref",
        "receipt_contract_ref",
        "generation_id",
        "generation_manifest_ref",
        "projection_manifest_ref",
        "generation_bound_truth_members",
        "target_role",
        "completion_marker_paths",
        "opl_request_domain_authorization",
        "source_tree_must_match_projection_manifest",
        "atomic_tree_switch_required",
        "transport_can_write_domain_truth"
      ],
      "properties": {
        "surface_kind": {
          "const": "mas_artifact_projection_transport_authorization"
        },
        "schema_version": {
          "const": 1
        },
        "transport_owner": {
          "const": "One Person Lab"
        },
        "transport_action_id": {
          "const": "opl_pack_materialize_artifact_projection"
        },
        "request_contract_ref": {
          "const": "contracts/opl-framework/artifact-projection-materialization-request.schema.json"
        },
        "receipt_contract_ref": {
          "const": "contracts/opl-framework/artifact-projection-materialization-receipt.schema.json"
        },
        "generation_id": {
          "$ref": "#/$defs/non_empty_text"
        },
        "generation_manifest_ref": {
          "$ref": "#/$defs/exact_ref"
        },
        "projection_manifest_ref": {
          "allOf": [
            {
              "$ref": "#/$defs/generation_artifact_identity"
            },
            {
              "properties": {
                "role": {
                  "const": "submission_projection_manifest"
                }
              }
            }
          ]
        },
        "generation_bound_truth_members": {
          "type": "array",
          "prefixItems": [
            {
              "allOf": [
                {
                  "$ref": "#/$defs/generation_artifact_identity"
                },
                {
                  "properties": {
                    "role": {
                      "const": "submission_status"
                    }
                  }
                }
              ]
            },
            {
              "allOf": [
                {
                  "$ref": "#/$defs/generation_artifact_identity"
                },
                {
                  "properties": {
                    "role": {
                      "const": "publication_evaluation"
                    }
                  }
                }
              ]
            },
            {
              "allOf": [
                {
                  "$ref": "#/$defs/generation_artifact_identity"
                },
                {
                  "properties": {
                    "role": {
                      "const": "next_action_envelope"
                    }
                  }
                }
              ]
            }
          ],
          "items": false,
          "minItems": 3,
          "maxItems": 3
        },
        "target_role": {
          "const": "study_submission_root"
        },
        "completion_marker_paths": {
          "type": "array",
          "prefixItems": [
            {
              "const": "STATUS.json"
            },
            {
              "const": "audit/submission_manifest.json"
            }
          ],
          "items": false,
          "minItems": 2,
          "maxItems": 2
        },
        "opl_request_domain_authorization": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "owner",
            "ref_source",
            "scope",
            "artifact_body_write_authorized",
            "authorizes_quality_publication_or_submission"
          ],
          "properties": {
            "owner": {
              "const": "MedAutoScience"
            },
            "ref_source": {
              "const": "owner_receipt.receipt_id"
            },
            "scope": {
              "const": "artifact_projection_only"
            },
            "artifact_body_write_authorized": {
              "const": true
            },
            "authorizes_quality_publication_or_submission": {
              "const": false
            }
          }
        },
        "source_tree_must_match_projection_manifest": {
          "const": true
        },
        "atomic_tree_switch_required": {
          "const": true
        },
        "transport_can_write_domain_truth": {
          "const": false
        }
      }
    },
    "owner_receipt": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "receipt_kind",
        "schema_version",
        "owner",
        "mission_identity",
        "host_refs",
        "generation_identity",
        "review_authority_epoch",
        "review_currentness_receipt_ref",
        "accepted_candidate_admissions",
        "medical_evidence_refs",
        "negative_result_refs",
        "failed_path_refs",
        "artifact_lineage_refs",
        "reproducibility_refs",
        "source_readiness_receipt_ref",
        "claim_boundary_ref",
        "independent_review_receipt_refs",
        "verdict",
        "authorizes_stage_domain_completion",
        "authorizes_publication_or_submission",
        "requires_host_exact_byte_persistence",
        "receipt_id",
        "receipt_size_bytes",
        "receipt_fingerprint"
      ],
      "properties": {
        "receipt_kind": {
          "const": "mas_paper_mission_owner_receipt"
        },
        "schema_version": {
          "const": 2
        },
        "owner": {
          "const": "MedAutoScience"
        },
        "mission_identity": {
          "$ref": "#/$defs/mission_identity"
        },
        "host_refs": {
          "$ref": "#/$defs/host_refs"
        },
        "generation_identity": {
          "$ref": "#/$defs/generation_identity"
        },
        "review_authority_epoch": {
          "$ref": "#/$defs/non_empty_text"
        },
        "review_currentness_receipt_ref": {
          "$ref": "#/$defs/exact_ref"
        },
        "accepted_candidate_admissions": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/accepted_candidate_admission"
          }
        },
        "medical_evidence_refs": {
          "$ref": "#/$defs/typed_ref_array"
        },
        "negative_result_refs": {
          "$ref": "#/$defs/typed_ref_array"
        },
        "failed_path_refs": {
          "$ref": "#/$defs/typed_ref_array"
        },
        "artifact_lineage_refs": {
          "$ref": "#/$defs/typed_ref_array"
        },
        "reproducibility_refs": {
          "$ref": "#/$defs/typed_ref_array"
        },
        "source_readiness_receipt_ref": {
          "$ref": "#/$defs/typed_ref"
        },
        "claim_boundary_ref": {
          "$ref": "#/$defs/typed_ref"
        },
        "independent_review_receipt_refs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/exact_ref"
          }
        },
        "verdict": {
          "const": "accepted_domain_delta"
        },
        "authorizes_stage_domain_completion": {
          "const": true
        },
        "authorizes_publication_or_submission": {
          "const": false
        },
        "requires_host_exact_byte_persistence": {
          "const": true
        },
        "artifact_projection_transport": {
          "$ref": "#/$defs/artifact_projection_transport"
        },
        "receipt_id": {
          "type": "string",
          "pattern": "^mas-paper-mission-owner-receipt:[0-9a-f]{64}$"
        },
        "receipt_size_bytes": {
          "type": "integer",
          "minimum": 1
        },
        "receipt_fingerprint": {
          "$ref": "#/$defs/sha256"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "mission_identity": {
                "type": "object",
                "properties": {
                  "stage_id": {
                    "const": "finalize_and_publication_handoff"
                  }
                },
                "required": [
                  "stage_id"
                ]
              }
            },
            "required": [
              "mission_identity"
            ]
          },
          "then": {
            "required": [
              "artifact_projection_transport"
            ]
          },
          "else": {
            "not": {
              "required": [
                "artifact_projection_transport"
              ]
            }
          }
        }
      ]
    },
    "review_verdict": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "review_lane",
        "verdict"
      ],
      "properties": {
        "review_lane": {
          "enum": [
            "medical",
            "statistical",
            "reference",
            "display",
            "publication",
            "exact_byte_package"
          ]
        },
        "verdict": {
          "enum": [
            "passed",
            "revision_required",
            "rejected"
          ]
        }
      }
    },
    "route_back": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "reason_code",
        "next_owner",
        "resume_condition",
        "review_verdicts",
        "quality_debt_codes",
        "defect_refs",
        "repair_attempt_refs",
        "remaining_repair_attempts",
        "selects_next_stage"
      ],
      "properties": {
        "reason_code": {
          "$ref": "#/$defs/non_empty_text"
        },
        "next_owner": {
          "$ref": "#/$defs/non_empty_text"
        },
        "resume_condition": {
          "$ref": "#/$defs/non_empty_text"
        },
        "review_verdicts": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/review_verdict"
          }
        },
        "quality_debt_codes": {
          "$ref": "#/$defs/text_array"
        },
        "defect_refs": {
          "$ref": "#/$defs/typed_ref_array"
        },
        "repair_attempt_refs": {
          "$ref": "#/$defs/typed_ref_array"
        },
        "remaining_repair_attempts": {
          "type": "integer",
          "minimum": 0
        },
        "selects_next_stage": {
          "const": false
        }
      }
    },
    "typed_blocker": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "blocker_kind",
        "gate_kind",
        "reason_code",
        "evidence_refs",
        "next_owner",
        "resume_condition",
        "blocks_stage_transition",
        "requires_host_exact_byte_persistence"
      ],
      "properties": {
        "blocker_kind": {
          "const": "mas_paper_mission_typed_blocker"
        },
        "gate_kind": {
          "enum": [
            "medical_safety",
            "source_identity",
            "source_currentness",
            "domain_authority",
            "credential",
            "irreversible_action"
          ]
        },
        "reason_code": {
          "$ref": "#/$defs/non_empty_text"
        },
        "evidence_refs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/typed_ref"
          }
        },
        "next_owner": {
          "$ref": "#/$defs/non_empty_text"
        },
        "resume_condition": {
          "$ref": "#/$defs/non_empty_text"
        },
        "blocks_stage_transition": {
          "const": true
        },
        "requires_host_exact_byte_persistence": {
          "const": true
        }
      }
    },
    "human_gate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "gate_kind",
        "reason_code",
        "evidence_refs",
        "next_owner",
        "resume_condition",
        "blocks_stage_transition",
        "requires_host_exact_byte_persistence"
      ],
      "properties": {
        "gate_kind": {
          "const": "mas_paper_mission_human_gate"
        },
        "reason_code": {
          "$ref": "#/$defs/non_empty_text"
        },
        "evidence_refs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/typed_ref"
          }
        },
        "next_owner": {
          "$ref": "#/$defs/non_empty_text"
        },
        "resume_condition": {
          "$ref": "#/$defs/non_empty_text"
        },
        "blocks_stage_transition": {
          "const": true
        },
        "requires_host_exact_byte_persistence": {
          "const": true
        }
      }
    },
    "quality_debt": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "reason_codes",
        "review_verdict",
        "defect_refs",
        "transition_allowed",
        "blocks_quality_publication_export_and_submission_claims",
        "counts_as_owner_acceptance"
      ],
      "properties": {
