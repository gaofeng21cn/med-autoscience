{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://one-person-lab.local/med-autoscience/mas-study-lifecycle-reactivation-authority.output.schema.json",
  "title": "MAS study lifecycle reactivation authority result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "surface_kind", "schema_version", "status", "study_identity", "reactivation_receipt",
    "mas_lifecycle_cas_mutation_authorization", "opl_host_materialization_request",
    "typed_blocker", "error", "authority_boundary", "decision_id", "decision_fingerprint"
  ],
  "properties": {
    "surface_kind": { "const": "mas_study_lifecycle_reactivation_authority_result" },
    "schema_version": { "const": 1 },
    "status": { "enum": ["authorized", "typed_blocker", "invalid_host_input"] },
    "study_identity": { "oneOf": [{ "$ref": "#/$defs/study_identity" }, { "type": "null" }] },
    "reactivation_receipt": { "oneOf": [{ "$ref": "#/$defs/reactivation_receipt" }, { "type": "null" }] },
    "mas_lifecycle_cas_mutation_authorization": { "oneOf": [{ "$ref": "#/$defs/authorization" }, { "type": "null" }] },
    "opl_host_materialization_request": { "oneOf": [{ "$ref": "#/$defs/host_request" }, { "type": "null" }] },
    "typed_blocker": { "oneOf": [{ "type": "object" }, { "type": "null" }] },
    "error": { "oneOf": [{ "type": "object" }, { "type": "null" }] },
    "authority_boundary": { "$ref": "#/$defs/authority_boundary" },
    "decision_id": { "type": "string", "pattern": "^mas-study-lifecycle-reactivation-decision:[a-f0-9]{64}$" },
    "decision_fingerprint": { "$ref": "#/$defs/prefixed_sha256" }
  },
  "$defs": {
    "text": { "type": "string", "minLength": 1 },
    "file_url": { "type": "string", "pattern": "^file:///.+" },
    "sha256": { "type": "string", "pattern": "^(?:sha256:)?[a-f0-9]{64}$" },
    "prefixed_sha256": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "study_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["study_id", "work_item_root_ref", "lifecycle_ref", "descriptor_domain_id"],
      "properties": {
        "study_id": { "$ref": "#/$defs/text" },
        "work_item_root_ref": { "$ref": "#/$defs/file_url" },
        "lifecycle_ref": { "$ref": "#/$defs/file_url" },
        "descriptor_domain_id": { "const": "medautoscience" }
      }
    },
    "reactivation_receipt": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "receipt_kind", "schema_version", "owner", "study_id", "handler_call_ref",
        "owner_ledger_ref", "original_admission_request_ref", "original_admission_request_sha256",
        "admission_scope_id", "requested_action_id", "requested_run_id", "original_invocation_sha256",
        "profile_ref", "profile_sha256", "reviewer_revision_intake_ref",
        "reviewer_revision_intake_sha256", "user_authority_ref", "user_authority_sha256",
        "revision_checklist_ref", "revision_checklist_sha256", "independent_review_packet_ref",
        "independent_review_packet_sha256", "first_owning_stage_id", "allowed_revision_scope",
        "projection_inventory_fingerprint", "from_state", "from_generation", "from_sha256",
        "to_state", "to_generation", "after_sha256", "recorded_at", "explicit_user_wakeup",
        "allow_stopped_relaunch", "satisfied_gate_ids", "authorizes_lifecycle_transition",
        "authorizes_stage_selection", "authorizes_publication_or_submission",
        "authorizes_attempt_admission_without_materialization", "requires_opl_cas_materialization_receipt",
        "requires_no_in_progress_materialization_journal", "materialization_semantics",
        "provider_completion_is_domain_completion", "receipt_ref", "receipt_fingerprint"
      ],
      "properties": {
        "receipt_kind": { "const": "mas_study_lifecycle_reactivation_receipt" },
        "schema_version": { "const": 1 },
        "owner": { "const": "MedAutoScience" },
        "study_id": { "$ref": "#/$defs/text" },
        "handler_call_ref": { "$ref": "#/$defs/text" },
        "owner_ledger_ref": { "$ref": "#/$defs/file_url" },
        "original_admission_request_ref": { "$ref": "#/$defs/file_url" },
        "original_admission_request_sha256": { "$ref": "#/$defs/sha256" },
        "admission_scope_id": { "$ref": "#/$defs/text" },
        "requested_action_id": { "$ref": "#/$defs/text" },
        "requested_run_id": { "$ref": "#/$defs/text" },
        "original_invocation_sha256": { "$ref": "#/$defs/sha256" },
        "profile_ref": { "$ref": "#/$defs/file_url" },
        "profile_sha256": { "$ref": "#/$defs/sha256" },
        "reviewer_revision_intake_ref": { "$ref": "#/$defs/file_url" },
        "reviewer_revision_intake_sha256": { "$ref": "#/$defs/sha256" },
        "user_authority_ref": { "$ref": "#/$defs/file_url" },
        "user_authority_sha256": { "$ref": "#/$defs/sha256" },
        "revision_checklist_ref": { "$ref": "#/$defs/file_url" },
        "revision_checklist_sha256": { "$ref": "#/$defs/sha256" },
        "independent_review_packet_ref": { "$ref": "#/$defs/file_url" },
        "independent_review_packet_sha256": { "$ref": "#/$defs/sha256" },
        "first_owning_stage_id": { "$ref": "#/$defs/text" },
        "allowed_revision_scope": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "$ref": "#/$defs/text" } },
        "projection_inventory_fingerprint": { "$ref": "#/$defs/prefixed_sha256" },
        "from_state": { "enum": ["paused", "delivered_paused", "stopped"] },
        "from_generation": { "type": "integer", "minimum": 1 },
        "from_sha256": { "$ref": "#/$defs/sha256" },
        "to_state": { "const": "active" },
        "to_generation": { "type": "integer", "minimum": 2 },
        "after_sha256": { "$ref": "#/$defs/sha256" },
        "recorded_at": { "type": "string", "format": "date-time" },
        "explicit_user_wakeup": { "const": true },
        "allow_stopped_relaunch": { "type": "boolean" },
        "satisfied_gate_ids": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "$ref": "#/$defs/text" } },
        "authorizes_lifecycle_transition": { "const": true },
        "authorizes_stage_selection": { "const": false },
        "authorizes_publication_or_submission": { "const": false },
        "authorizes_attempt_admission_without_materialization": { "const": false },
        "requires_opl_cas_materialization_receipt": { "const": true },
        "requires_no_in_progress_materialization_journal": { "const": true },
        "materialization_semantics": { "const": "journaled_all_or_rollback" },
        "provider_completion_is_domain_completion": { "const": false },
        "receipt_ref": { "type": "string", "pattern": "^mas-study-lifecycle-reactivation:[a-f0-9]{64}$" },
        "receipt_fingerprint": { "$ref": "#/$defs/prefixed_sha256" }
      }
    },
    "authorization": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface_kind", "version", "capability_id", "request_id", "domain_id",
        "operations_sha256", "authorized", "authority_receipt_ref", "satisfied_gate_ids",
        "authorization_ref", "authorization_fingerprint"
      ],
      "properties": {
        "surface_kind": { "const": "mas_lifecycle_cas_mutation_authorization" },
        "version": { "const": "mas-lifecycle-cas-mutation-authorization.v1" },
        "capability_id": { "const": "opl_domain_artifact_cas_materialization.v1" },
        "request_id": { "$ref": "#/$defs/text" },
        "domain_id": { "const": "medautoscience" },
        "operations_sha256": { "$ref": "#/$defs/sha256" },
        "authorized": { "const": true },
        "authority_receipt_ref": { "$ref": "#/$defs/text" },
        "satisfied_gate_ids": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "$ref": "#/$defs/text" } },
        "authorization_ref": { "type": "string", "pattern": "^mas-lifecycle-cas-authorization:[a-f0-9]{64}$" },
        "authorization_fingerprint": { "$ref": "#/$defs/prefixed_sha256" }
      }
    },
    "host_request": {
      "type": "object",
      "additionalProperties": false,
      "required": ["surface_kind", "version", "capability_id", "request_id", "domain_id", "authorization_ref", "operations_sha256", "operations"],
      "properties": {
        "surface_kind": { "const": "opl_domain_artifact_cas_materialization_request" },
        "version": { "const": "opl-domain-artifact-cas-materialization.v1" },
        "capability_id": { "const": "opl_domain_artifact_cas_materialization.v1" },
        "request_id": { "$ref": "#/$defs/text" },
        "domain_id": { "const": "medautoscience" },
        "authorization_ref": { "$ref": "#/$defs/text" },
        "operations_sha256": { "$ref": "#/$defs/sha256" },
        "operations": { "type": "array", "minItems": 1, "maxItems": 32, "items": { "$ref": "#/$defs/operation" } }
      }
    },
    "operation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["target_relative_path", "precondition", "replacement_bytes_base64", "replacement_sha256", "replacement_byte_size"],
      "properties": {
        "target_relative_path": { "$ref": "#/$defs/text" },
        "precondition": {
          "oneOf": [
            {
              "type": "object", "additionalProperties": false,
              "required": ["kind", "sha256", "byte_size"],
              "properties": {
                "kind": { "const": "existing_exact" },
                "sha256": { "$ref": "#/$defs/sha256" },
                "byte_size": { "type": "integer", "minimum": 1 }
              }
            },
            {
              "type": "object", "additionalProperties": false,
              "required": ["kind"], "properties": { "kind": { "const": "absent" } }
            }
          ]
        },
        "replacement_bytes_base64": { "type": "string", "minLength": 1 },
        "replacement_sha256": { "$ref": "#/$defs/sha256" },
        "replacement_byte_size": { "type": "integer", "minimum": 1 }
      }
    },
    "authority_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "owner", "handler_role", "opl_role", "performs_filesystem_io", "performs_network_io",
        "spawns_process_or_executor", "owns_runtime_or_attempt_lifecycle", "selects_scientific_stage",
        "authorizes_publication_or_submission", "provider_completion_is_domain_completion", "public_action"
      ],
      "properties": {
        "owner": { "const": "MedAutoScience" },
        "handler_role": { "$ref": "#/$defs/text" },
        "opl_role": { "$ref": "#/$defs/text" },
        "performs_filesystem_io": { "const": false },
        "performs_network_io": { "const": false },
        "spawns_process_or_executor": { "const": false },
        "owns_runtime_or_attempt_lifecycle": { "const": false },
        "selects_scientific_stage": { "const": false },
        "authorizes_publication_or_submission": { "const": false },
        "provider_completion_is_domain_completion": { "const": false },
        "public_action": { "const": false }
      }
    }
  }
}
