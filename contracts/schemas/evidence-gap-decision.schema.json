{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "contracts/schemas/evidence-gap-decision.schema.json",
  "title": "MAS EvidenceGapDecision",
  "type": "object",
  "required": [
    "surface_kind",
    "version",
    "decision_id",
    "owner",
    "state",
    "gap_class",
    "gap_id",
    "current_owner_delta_ref",
    "current_owner_delta_identity",
    "evidence_refs",
    "decision",
    "typed_blocker_eligibility",
    "typed_blocker_policy",
    "completion_claim_allowed",
    "claim_boundary",
    "forbidden_claim_terms"
  ],
  "properties": {
    "surface_kind": {
      "const": "mas_evidence_gap_decision"
    },
    "version": {
      "type": "string"
    },
    "decision_id": {
      "type": "string"
    },
    "owner": {
      "const": "MedAutoScience"
    },
    "state": {
      "enum": [
        "active_gap_decision",
        "closed_by_owner_evidence",
        "superseded_by_current_owner_delta"
      ]
    },
    "gap_class": {
      "enum": [
        "authority_gate",
        "human_gate",
        "proceed_with_assumption",
        "soft_quality_gap",
        "observability_backlog",
        "evidence_tail"
      ]
    },
    "gap_id": {
      "type": "string"
    },
    "current_owner_delta_ref": {
      "type": "string"
    },
    "current_owner_delta_identity": {
      "type": "object",
      "required": [
        "study_id",
        "work_unit_id",
        "work_unit_fingerprint"
      ],
      "properties": {
        "study_id": {
          "type": "string"
        },
        "quest_id": {
          "type": "string"
        },
        "work_unit_id": {
          "type": "string"
        },
        "work_unit_fingerprint": {
          "type": "string"
        },
        "route_identity_key": {
          "type": "string"
        },
        "attempt_idempotency_key": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "decision": {
      "enum": [
        "materialize_typed_blocker",
        "open_human_gate",
        "proceed_with_recorded_assumption",
        "continue_with_quality_followup",
        "continue_with_observability_followup",
        "record_evidence_tail"
      ]
    },
    "typed_blocker_eligibility": {
      "type": "boolean"
    },
    "typed_blocker_policy": {
      "type": "object",
      "required": [
        "typed_blocker_countable",
        "materialization_allowed",
        "materialization_reason",
        "typed_blocker_ref"
      ],
      "properties": {
        "typed_blocker_countable": {
          "type": "boolean"
        },
        "materialization_allowed": {
          "type": "boolean"
        },
        "materialization_reason": {
          "enum": [
            "authority_gate",
            "human_gate",
            "forbidden_write_boundary",
            "stop_loss_materialized",
            "not_allowed"
          ]
        },
        "typed_blocker_ref": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": false
    },
    "assumption_ref": {
      "type": "string"
    },
    "followup_work_order_ref": {
      "type": "string"
    },
    "blocks_completion_claim": {
      "type": "boolean"
    },
    "completion_claim_allowed": {
      "type": "boolean"
    },
    "claim_boundary": {
      "type": "object",
      "required": [
        "paper_progress_claim_allowed",
        "live_runtime_readiness_claim_allowed",
        "publication_readiness_claim_allowed",
        "production_readiness_claim_allowed"
      ],
      "properties": {
        "paper_progress_claim_allowed": {
          "type": "boolean"
        },
        "live_runtime_readiness_claim_allowed": {
          "type": "boolean"
        },
        "publication_readiness_claim_allowed": {
          "type": "boolean"
        },
        "production_readiness_claim_allowed": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "forbidden_claim_terms": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    }
  },
  "additionalProperties": false,
  "allOf": [
    {
      "if": {
        "properties": {
          "gap_class": {
            "enum": [
              "authority_gate",
              "human_gate"
            ]
          }
        }
      },
      "then": {
        "properties": {
          "typed_blocker_eligibility": {
            "const": true
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "gap_class": {
            "enum": [
              "proceed_with_assumption",
              "soft_quality_gap",
              "observability_backlog",
              "evidence_tail"
            ]
          }
        }
      },
      "then": {
        "properties": {
          "typed_blocker_eligibility": {
            "const": false
          }
        }
      }
    }
  ]
}
