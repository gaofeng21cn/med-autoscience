{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "med-autoscience/contracts/schemas/v1/product-entry-status.schema.json",
  "title": "MedAutoScience Product Entry Status",
  "type": "object",
  "required": [
    "schema_version",
    "surface_kind",
    "schema_ref",
    "recommended_action",
    "target_domain_id",
    "single_project_boundary",
    "domain_entry_contract",
    "user_interaction_contract",
    "product_entry_surface",
    "operator_loop_surface",
    "product_entry_manifest"
  ],
  "properties": {
    "surface_kind": {
      "const": "product_entry_status"
    },
    "schema_ref": {
      "const": "contracts/schemas/v1/product-entry-status.schema.json"
    },
    "domain_entry_contract": {
      "$ref": "./product-entry-manifest.schema.json#/$defs/domainEntryContract"
    },
    "single_project_boundary": {
      "$ref": "./product-entry-manifest.schema.json#/$defs/singleProjectBoundary"
    },
    "user_interaction_contract": {
      "$ref": "./product-entry-manifest.schema.json#/$defs/userInteractionContract"
    }
  }
}
