{
  "surface_kind": "opl_artifact_operating_contract",
  "contract_id": "opl-artifact-operating-contract.v1",
  "contract_ref": "contracts/opl-framework/artifact-operating-contract.json",
  "domain_id": "med-autoscience",
  "version": 1,
  "owner": "one-person-lab",
  "domain_owner": "MedAutoScience",
  "purpose": "Define the OPL-owned artifact operating rules consumed by MAS stage artifact projections without granting OPL study truth, publication, quality, or artifact mutation authority.",
  "progress_model": {
    "precedence": [
      "current_pointer",
      "accepted_receipt",
      "valid_manifest",
      "existing_artifacts"
    ],
    "rule": "progress_is_current_pointer_over_accepted_receipt_over_valid_manifest_over_existing_artifacts",
    "file_presence_only_counts_as": "historical_or_missing_manifest_or_receipt",
    "provider_completion_counts_as_progress": false
  },
  "manifest_contract": {
    "manifest_ref_template": "artifacts/stage_outputs/{stage_id}/stage_artifact_manifest.json",
    "required_fields": [
      "surface_kind",
      "schema_version",
      "stage_id",
      "artifact_refs"
    ],
    "validity_boundary": {
      "manifest_validity_is_semantic_receipt_validity": false,
      "valid_manifest_means": "declared artifact refs are structurally present and cover required stage outputs",
      "valid_manifest_does_not_mean": [
        "domain receipt accepted",
        "semantic or medical validation complete",
        "quality verdict granted",
        "artifact mutation authorized",
        "publication readiness authorized"
      ]
    }
  },
  "receipt_contract": {
    "receipt_ref_template": "artifacts/stage_outputs/{stage_id}/owner_receipt.json",
    "required_fields": [
      "surface_kind",
      "schema_version",
      "stage_id",
      "owner",
      "receipt_kind",
      "artifact_refs"
    ],
    "accepted_receipt_means": "MAS owner receipt structurally accepts the stage artifact delta refs for projection consumption only",
    "forbidden_receipt_interpretations": [
      "publication_readiness",
      "quality_verdict",
      "submission_readiness",
      "paper_package_mutation_authorization",
      "memory_body_accept_reject"
    ]
  },
  "current_pointer": {
    "pointer_ref_template": "artifacts/stage_outputs/{stage_id}/current_pointer.json",
    "promotion_required": true,
    "promotion_state_values": [
      "attempt_output_required",
      "manifest_required",
      "receipt_required",
      "current_pointer_promoted",
      "projection_blocked"
    ],
    "promotion_requires": [
      "existing_artifacts",
      "manifest_valid",
      "receipt_accepted"
    ],
    "projection_rebuild_required_after_promotion": true
  },
  "promotion_protocol": {
    "ordered_steps": [
      "attempt_output",
      "manifest_valid",
      "receipt_accepted",
      "current_pointer_promoted",
      "projection_rebuilt"
    ],
    "attempt_output_owner": "stage_executor",
    "manifest_validation_owner": "OPL artifact locator projection",
    "receipt_acceptance_owner": "MedAutoScience owner receipt authority",
    "current_pointer_promotion_owner": "OPL artifact operating layer",
    "projection_rebuild_owner": "controller/read-model projection"
  },
  "consumability_gate": {
    "required_checks": [
      "role",
      "hash",
      "source",
      "current_truth",
      "receipt_authority",
      "lineage",
      "retention_restore",
      "domain_validation"
    ],
    "checks": {
      "role": {
        "source": "stage artifact manifest role refs",
        "authority": "opl_projection"
      },
      "hash": {
        "source": "artifact manifest or locator checksum",
        "authority": "opl_artifact_locator"
      },
      "source": {
        "source": "attempt output and artifact source refs",
        "authority": "stage_executor_receipt"
      },
      "current_truth": {
        "source": "current pointer",
        "authority": "opl_artifact_operating_layer"
      },
      "receipt_authority": {
        "source": "MAS owner receipt",
        "authority": "mas_owner_receipt_authority"
      },
      "lineage": {
        "source": "attempt id, source refs, artifact refs, and parent refs",
        "authority": "refs_only_lineage_projection"
      },
      "retention_restore": {
        "source": "restore or retention ledger refs",
        "authority": "opl_restore_retention_shell",
        "required_before_cleanup": true
      },
      "domain_validation": {
        "source": "MAS domain validation or typed blocker",
        "authority": "mas_domain_owner",
        "manifest_validity_is_semantic_receipt_validity": false
      }
    }
  },
  "lineage": {
    "required_ref_families": [
      "attempt_ref",
      "manifest_ref",
      "owner_receipt_ref",
      "artifact_refs",
      "source_refs",
      "parent_artifact_refs"
    ],
    "body_included": false,
    "lineage_authority": "refs_only_projection"
  },
  "retention": {
    "restore_before_cleanup_required": true,
    "physical_cleanup_requires": [
      "restore_index_ref",
      "sha256_or_equivalent_hash",
      "rehydrate_verification",
      "domain_owner_receipt_or_typed_blocker"
    ],
    "report_or_plan_can_authorize_cleanup": false,
    "runtime_projection_can_authorize_cleanup": false
  },
  "controller_read_model_currentness": {
    "role": "repair_projection_diagnostic_only",
    "allowed_roles": [
      "repair",
      "projection",
      "diagnostic"
    ],
    "forbidden_roles": [
      "study_truth",
      "publication_readiness",
      "quality_verdict",
      "submission_readiness",
      "artifact_mutation_authority",
      "domain_receipt_authority"
    ]
  },
  "authority_boundary": {
    "opl_can_index_artifact_refs": true,
    "opl_can_promote_current_pointer_after_mas_receipt": true,
    "opl_can_rebuild_projection": true,
    "opl_can_write_mas_truth": false,
    "opl_can_authorize_quality_verdict": false,
    "opl_can_authorize_publication_readiness": false,
    "opl_can_authorize_submission_readiness": false,
    "opl_can_mutate_paper_package": false,
    "controller_read_model_currentness_can_authorize_progress": false
  }
}
