{
  "schema_version": 1,
  "surface_kind": "opl_dependency_environment_substrate_contract",
  "contract_id": "opl.dependency_environment_substrate.v1",
  "state": "target_contract",
  "owner": "OPL Framework",
  "consumer_domains": [
    "MedAutoScience"
  ],
  "purpose": "Target contract for OPL-owned dependency environment resolution, locking, preparation, cache, doctor, and run-context handoff so domain packs declare needs but do not install or repair runtime dependencies inside renderer code.",
  "machine_boundary": "This MAS-tracked contract describes the target OPL substrate and MAS consumption boundary. It is not evidence that the OPL implementation is landed. MAS publication truth, figure quality verdicts, owner receipts, typed blockers, artifact authority, and study truth remain MAS-owned.",
  "external_learning_sources": [
    {
      "source_id": "renv_project_lock_restore",
      "url": "https://rstudio.github.io/renv/articles/renv.html",
      "inspected_on": "2026-06-21",
      "adopted_pattern": "R project libraries plus renv.lock-style package metadata and restore semantics."
    },
    {
      "source_id": "pak_system_requirements",
      "url": "https://pak.r-lib.org/reference/sysreqs.html",
      "inspected_on": "2026-06-21",
      "adopted_pattern": "Resolve and check R package system requirements separately from renderer code."
    },
    {
      "source_id": "bioconductor_versioned_containers",
      "url": "https://www.bioconductor.org/help/docker/",
      "inspected_on": "2026-06-21",
      "adopted_pattern": "Use versioned biomedical R container bases and prebuilt package ecosystems for reproducible and fast scientific environments."
    },
    {
      "source_id": "uv_lock_sync",
      "url": "https://docs.astral.sh/uv/concepts/projects/sync/",
      "inspected_on": "2026-06-21",
      "adopted_pattern": "Separate dependency locking from syncing and allow frozen or locked execution modes."
    },
    {
      "source_id": "conda_lock_explicit_specs",
      "url": "https://docs.conda.io/projects/conda/en/latest/user-guide/tasks/manage-environments.html",
      "inspected_on": "2026-06-21",
      "adopted_pattern": "Support multi-platform lockfiles and explicit package URL specs for exact environment recreation."
    },
    {
      "source_id": "docker_digest_pinning",
      "url": "https://docs.docker.com/build/building/best-practices/",
      "inspected_on": "2026-06-21",
      "adopted_pattern": "Pin container base images by digest when a reproducible publication environment is required."
    }
  ],
  "core_principles": {
    "domain_pack_declares_requirements_only": true,
    "opl_substrate_solves_locks_prepares_and_caches": true,
    "renderer_code_must_not_install_packages": true,
    "render_execution_consumes_prepared_run_context": true,
    "dependency_failure_is_opl_substrate_issue_not_template_bug": true,
    "locks_do_not_authorize_publication_readiness": true,
    "silent_dependency_upgrade_forbidden": true
  },
  "domain_requirement_surface": {
    "surface_id": "renderer_dependency_profile",
    "current_mas_ref": "display-packs/fenggaolab.org.medical-display-core/renderer_dependency_profile.json",
    "target_role": "Pack-local dependency intent declaration consumed by OPL Dependency Environment OS.",
    "required_fields": [
      "schema_version",
      "pack_id",
      "profiles[].profile_id",
      "profiles[].execution_mode",
      "profiles[].renderer_family",
      "profiles[].runtime_binaries",
      "profiles[].language_packages",
      "profiles[].system_requirements",
      "profiles[].template_ids_or_entrypoint_pattern",
      "profiles[].run_context_requirements"
    ],
    "forbidden_fields": [
      "install_script_to_run_inside_renderer",
      "publication_readiness_verdict",
      "study_truth_write",
      "artifact_mutation_authorization"
    ]
  },
  "opl_surfaces": [
    {
      "surface": "opl pack env resolve",
      "status": "target_planned",
      "input": "dependency intent refs plus target platform and policy",
      "output": "normalized dependency graph and resolver plan"
    },
    {
      "surface": "opl pack env lock",
      "status": "target_planned",
      "input": "resolver plan",
      "output": "dependency_environment_lock.json"
    },
    {
      "surface": "opl pack env prepare",
      "status": "target_planned",
      "input": "dependency_environment_lock.json",
      "output": "prepared environment prefix, container digest, cache refs, and dependency_environment_receipt.json"
    },
    {
      "surface": "opl pack env doctor",
      "status": "target_planned",
      "input": "dependency_environment_lock.json or prepared environment ref",
      "output": "diagnostic receipt with missing binary, package, system requirement, or permission class"
    },
    {
      "surface": "opl pack env run-context",
      "status": "target_planned",
      "input": "prepared environment receipt plus renderer profile ref",
      "output": "argv prefix, environment variables, binary paths, container runner ref, and execution fingerprint"
    },
    {
      "surface": "opl pack env cache",
      "status": "target_planned",
      "input": "lock hash and cache policy",
      "output": "cache hit, miss, eviction, and provenance receipt"
    }
  ],
  "lock_contract": {
    "path_pattern": "paper/build/dependency_environment_lock.json",
    "required_fields": [
      "schema_version",
      "lock_id",
      "target_platform",
      "manager",
      "source_requirement_refs",
      "language_runtime_versions",
      "package_records",
      "system_requirement_records",
      "container_image_ref",
      "container_image_digest",
      "resolver_version",
      "repository_or_channel_refs",
      "lock_sha256",
      "created_at"
    ],
    "manager_choices": [
      "renv",
      "pak_sysreqs",
      "uv",
      "conda_lock",
      "pixi_lock",
      "container_digest",
      "mixed_profile"
    ],
    "authority_boundary": "Environment lock proves a dependency graph was resolved. It does not prove scientific correctness, visual audit clearance, publication readiness, or study progress."
  },
  "prepare_receipt_contract": {
    "path_pattern": "paper/build/dependency_environment_receipt.json",
    "required_fields": [
      "schema_version",
      "lock_ref",
      "lock_sha256",
      "environment_ref",
      "cache_key",
      "prepared_at",
      "prepared_by",
      "target_platform",
      "binary_checks",
      "package_checks",
      "system_requirement_checks",
      "run_context_ref",
      "status",
      "failure_class"
    ],
    "allowed_status": [
      "prepared",
      "missing_dependency",
      "unsupported_platform",
      "permission_required",
      "resolver_failed",
      "cache_corrupt",
      "lock_stale"
    ],
    "failure_routes": {
      "missing_dependency": "opl_pack_substrate_issue",
      "unsupported_platform": "opl_pack_substrate_issue",
      "permission_required": "human_or_admin_gate_required",
      "resolver_failed": "opl_pack_substrate_issue",
      "cache_corrupt": "opl_pack_substrate_issue",
      "lock_stale": "dependency_lock_refresh_required"
    }
  },
  "mas_consumption_contract": {
    "ordinary_display_path_requires_prepared_receipt": true,
    "display_pack_preflight_must_report_dependency_receipt_status": true,
    "display_pack_render_must_consume_run_context_ref": true,
    "renderer_may_check_binaries_but_must_not_install": true,
    "missing_environment_must_stop_before_render_attempt": true,
    "allowed_mas_writes": [
      "dependency_environment_requirement_ref",
      "dependency_environment_lock_ref",
      "dependency_environment_receipt_ref",
      "display_pack_lock_ref",
      "render_attempt_ref",
      "visual_audit_receipt_ref",
      "typed_repair_route_ref"
    ],
    "forbidden_mas_claims": [
      "dependency_environment_receipt_means_publication_ready",
      "dependency_environment_lock_means_visual_audit_clear",
      "dependency_environment_prepared_means_scientific_correctness",
      "renderer_dependency_profile_can_write_study_truth"
    ]
  },
  "security_and_update_policy": {
    "install_scripts_from_domain_packs_allowed": false,
    "dependency_updates_require_explicit_lock_refresh": true,
    "system_package_install_requires_opl_policy_or_admin_gate": true,
    "container_digest_required_for_publication_reproducibility": true,
    "sbom_or_package_inventory_recommended": true,
    "stale_lock_is_repair_route_not_silent_upgrade": true
  },
  "landing_gates": [
    "OPL repo implements solve, lock, prepare, doctor, run-context, and cache surfaces with focused tests.",
    "MAS display-pack preflight consumes dependency_environment_receipt refs and fail-closes missing prepared environments before renderer execution.",
    "Display Pack lock and publication manifest preserve dependency lock and receipt refs without becoming publication authority.",
    "At least one R/ggplot2 evidence renderer path uses a prepared OPL run context and records R session/package versions in render receipts.",
    "Failure classes route to OPL substrate issue, dependency lock refresh, or human/admin gate rather than renderer-local installation."
  ]
}
