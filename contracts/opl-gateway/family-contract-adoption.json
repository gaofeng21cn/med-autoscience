{
  "contract_kind": "mas_opl_family_contract_adoption.v1",
  "domain_id": "med-autoscience",
  "domain_owner": "Med Auto Science",
  "opl_role": "family-level projection consumer only",
  "attempt_projection": {
    "source_surfaces": [
      "study_runtime_status",
      "runtime_watch",
      "controller_decisions/latest.json"
    ],
    "maps_to_opl_contract": "opl_family_runtime_attempt_contract.v1",
    "owner_boundary": "MAS owns study runtime truth and controller decisions"
  },
  "quality_projection": {
    "source_surfaces": [
      "study_charter",
      "evidence_ledger",
      "review_ledger",
      "publication_eval/latest.json"
    ],
    "maps_to_opl_contract": "opl_family_domain_quality_projection_contract.v1",
    "quality_gate_owner": "MAS medical publication gate",
    "claim_only_ready_forbidden": true
  },
  "incident_projection": {
    "source_surfaces": [
      "runtime_watch",
      "artifacts/autonomy/slo_status/latest.json",
      "artifacts/autonomy/ai_doctor_requests/*.json",
      "artifacts/autonomy/ai_doctor_diagnoses/*.json",
      "artifacts/autonomy/repair_actions/*.json",
      "autonomy incident records",
      "controller_decisions/latest.json"
    ],
    "maps_to_opl_contract": "opl_family_incident_learning_loop.v1",
    "closure_rule": "domain-specific failure requires MAS-owned closure ref",
    "ai_doctor_boundary": "OPL consumes runtime_slo_observer and ai_doctor_request projections only; MAS owns medical truth and repair closure"
  },
  "operator_projection": {
    "source_surfaces": [
      "product-entry-status",
      "workspace-cockpit",
      "study-progress",
      "build-product-entry.return_surface_contract"
    ],
    "maps_to_opl_contract": "opl_family_product_operator_projection.v1",
    "required_fields": [
      "source_refs",
      "freshness",
      "owner_split",
      "next_surface_ref",
      "human_gate_reason",
      "autonomy_slo",
      "ai_doctor_state",
      "repair_recommendation"
    ]
  },
  "domain_memory_projection": {
    "descriptor_surface": "product-entry-manifest.domain_memory_descriptor",
    "memory_ref_id": "mas_publication_route_memory",
    "memory_family": "publication_route_memory",
    "source_surfaces": [
      "docs/policies/study-workflow/publication_route_memory_policy.md",
      "docs/policies/study-workflow/study_archetypes.md",
      "stage_knowledge_packet",
      "stage_memory_closeout_packet",
      "memory_write_router_receipt",
      "stage_recall_index"
    ],
    "maps_to_opl_contract": "family-domain-memory-ref.v1",
    "authority_boundary": "OPL may index locator/freshness/receipt refs only; MAS owns memory content, retrieval, writeback accept/reject, publication route decision, evidence/review/controller truth, publication gate, and artifacts",
    "forbidden_opl_authority": [
      "memory_store_owner",
      "domain_truth_owner",
      "quality_verdict_owner",
      "artifact_authority",
      "publication_route_decision_owner",
      "publication_readiness_owner"
    ]
  },
  "persistence_lifecycle_owner_route_projection": {
    "adoption_surface_kind": "mas_opl_family_persistence_lifecycle_owner_route_adoption",
    "required_shape": [
      "refs",
      "payload"
    ],
    "source_surfaces": [
      "artifacts/runtime/runtime_lifecycle.sqlite",
      "study_macro_state/latest.json",
      "runtime_supervisor_owner_route",
      "runtime_supervisor_dispatch_receipt",
      "surface_refs",
      "runtime_watch/latest.json",
      "controller_decisions/latest.json"
    ],
    "sqlite_tables": [
      "lineage_nodes",
      "lineage_edges",
      "workspace_allocations",
      "runtime_snapshots",
      "snapshot_file_refs",
      "revision_diffs",
      "canvas_projection",
      "study_macro_state_snapshots",
      "owner_route_receipts",
      "dispatch_receipts",
      "surface_refs",
      "archive_refs",
      "report_index"
    ],
    "maps_to_opl_contracts": {
      "persistence": "opl_family_persistence_contract.v1",
      "lifecycle": "opl_family_lifecycle_contract.v1",
      "owner_route": "opl_family_owner_route_contract.v1"
    },
    "authority_boundary": "OPL may discover and index MAS refs/payload; MAS keeps study, publication, AI reviewer, and paper package authority",
    "forbidden_opl_authority_surfaces": [
      "publication_eval/latest.json",
      "AI reviewer workflow",
      "paper/manuscript/current_package",
      "current_package.zip"
    ]
  },
  "non_goals": [
    "OPL owns study truth",
    "OPL owns publication judgment",
    "OPL closes publication_eval",
    "generic persona QA",
    "claim-only ready"
  ]
}
