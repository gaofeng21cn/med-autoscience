{
  "surface_kind": "mas_paper_mission_run_contract",
  "version": "paper-mission-run.v1",
  "owner": "MedAutoScience",
  "state": "active_contract",
  "purpose": "Machine-readable contract for executor-first paper mission candidates before MAS authority consumption.",
  "machine_boundary": "PaperMissionRun records mission identity, objective, candidate artifact deltas, source refs, authority touchpoints, forbidden-write guard, consume result, and claim permissions. It cannot declare publication readiness, submission readiness, current package authority, owner receipt writes, typed blocker writes, human gate writes, controller decisions, publication eval writes, runtime queue writes, provider attempts, or Yang workspace changes.",
  "source_design_ref": "docs/active/mas_executor_first_rearchitecture_program.md",
  "required_fields": [
    "mission_id",
    "study_id",
    "objective",
    "mission_state",
    "artifact_delta_ledger",
    "source_refs",
    "authority_touchpoints",
    "forbidden_write_guard",
    "consume_result",
    "claim_permissions"
  ],
  "identity": {
    "canonical_id_field": "mission_id",
    "format": "paper-mission::<study_id>::<objective_slug>::<timestamp_or_run_ref>",
    "required_identity_fields": [
      "mission_id",
      "study_id",
      "objective"
    ],
    "single_current_mission_identity": true
  },
  "mission_state": {
    "allowed_values": [
      "planned",
      "running",
      "candidate_ready_for_consumption",
      "consumed",
      "route_back",
      "stable_blocker",
      "waiting_human_decision",
      "terminal_handoff"
    ],
    "candidate_state": "candidate_ready_for_consumption",
    "terminal_states": [
      "consumed",
      "route_back",
      "stable_blocker",
      "waiting_human_decision",
      "terminal_handoff"
    ]
  },
  "artifact_delta_ledger": {
    "role": "candidate artifact deltas proposed by the mission executor",
    "required_item_fields": [
      "delta_id",
      "artifact_ref",
      "delta_kind",
      "status"
    ],
    "non_authority_note": "Candidate deltas are not current_package and are not publication-ready until consumed by MAS authority."
  },
  "source_refs": {
    "role": "durable refs used to anchor candidate work to study/runtime/source truth without rewriting those truth surfaces",
    "required_item_fields": [
      "ref_id",
      "ref_kind",
      "uri"
    ]
  },
  "authority_touchpoints": {
    "role": "explicit record of MAS/OPL authority surfaces inspected or intentionally not touched by the mission run",
    "required_item_fields": [
      "touchpoint_id",
      "owner",
      "surface",
      "status"
    ],
    "allowed_statuses": [
      "not_touched",
      "read_only",
      "candidate_prepared",
      "consume_pending",
      "consume_recorded"
    ]
  },
  "forbidden_write_guard": {
    "required_fields": [
      "blocked_paths",
      "forbidden_claims",
      "candidate_writes_authority"
    ],
    "candidate_writes_authority_must_be": false,
    "blocked_paths_must_include": [
      "publication_eval/latest.json",
      "controller_decisions/latest.json",
      "current_package",
      "runtime queue/provider attempts",
      "/Users/gaofeng/workspace/Yang/**"
    ]
  },
  "consume_result": {
    "role": "MAS authority consume outcome for a candidate, or an explicit not-consumed/pending state",
    "required_fields": [
      "status"
    ],
    "allowed_statuses": [
      "not_consumed",
      "accepted",
      "rejected",
      "route_back",
      "typed_blocker",
      "human_gate"
    ],
    "authority_owner": "MedAutoScience"
  },
  "claim_permissions": {
    "allowed_true_claims": [
      "can_claim_artifact_delta",
      "can_claim_owner_handoff"
    ],
    "must_be_false": [
      "can_claim_publication_ready",
      "can_claim_current_package",
      "can_claim_owner_receipt_written"
    ]
  },
  "forbidden_authority_claims": [
    "publication_ready",
    "submission_ready",
    "current_package",
    "owner_receipt_written",
    "typed_blocker_written",
    "human_gate_written",
    "controller_decision_written",
    "publication_eval_written",
    "quality_verdict",
    "artifact_authority",
    "runtime_queue_written",
    "provider_attempt_written",
    "yang_workspace_written"
  ],
  "forbidden_write_surfaces": [
    "/Users/gaofeng/workspace/Yang/**",
    "publication_eval/latest.json",
    "controller_decisions/latest.json",
    "owner receipt",
    "typed blocker",
    "human gate",
    "current_package",
    "runtime queue/provider attempts"
  ],
  "validator": {
    "python_module": "med_autoscience.paper_mission_run",
    "class": "PaperMissionRun",
    "error_type": "PaperMissionContractError",
    "fail_closed": true
  }
}
