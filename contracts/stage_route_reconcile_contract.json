{
  "surface_kind": "mas_opl_stage_route_reconcile_contract",
  "version": "stage-route-reconcile.v1",
  "owner": "MedAutoScience / OPL Framework",
  "state": "active_contract",
  "purpose": "Machine-readable contract for the MAS/OPL stage-route reconcile handshake, currentness precedence, and anti-loop budget.",
  "machine_boundary": "This contract defines route/currentness/reconcile rules. It does not declare study truth, paper closure, publication readiness, submission readiness, quality verdicts, artifact mutation authority, current_package freshness, or production readiness.",
  "source_design_ref": "docs/runtime/designs/stage_route_reconcile_target.md",
  "related_contract_refs": [
    "contracts/stage_run_kernel_profile.json",
    "contracts/progress_first_safety_envelope.json",
    "contracts/foundry_agent_series.json",
    "contracts/agent_tool_arsenal.json",
    "contracts/stage_control_plane.json"
  ],
  "ordinary_planning_root": {
    "root": "current_owner_delta",
    "derived_operator_surfaces": [
      "current_work_unit",
      "current_execution_envelope",
      "current_executable_owner_action",
      "provider_admission_current_control"
    ],
    "audit_only_surfaces": [
      "raw_worklist",
      "OPL queue history",
      "attempt ledger",
      "stage artifact index",
      "sidecar advisory refs",
      "legacy owner_route_handoff",
      "runtime observability traces",
      "lineage refs"
    ],
    "forbidden_default_roots": [
      "active_run_id",
      "transport_status",
      "latest_json_mtime",
      "zero_open_worklist",
      "old_route_back_packet",
      "descriptor_ready",
      "advisory_score_or_ranking"
    ],
    "no_second_truth": true
  },
  "identity_policy": {
    "required_owner_identity_fields": [
      "study_id",
      "quest_id",
      "stage_id",
      "action_type",
      "work_unit_id",
      "work_unit_fingerprint",
      "idempotency_key",
      "target_surface",
      "currentness_basis",
      "route_identity_key",
      "attempt_idempotency_key"
    ],
    "provider_attempt_identity_fields": [
      "stage_attempt_id",
      "active_run_id",
      "active_workflow_id",
      "task_id",
      "dispatch_ref",
      "dispatch_path"
    ],
    "currentness_basis_fields": [
      "truth_epoch",
      "runtime_health_epoch",
      "source_eval_id",
      "source_fingerprint",
      "route_epoch"
    ],
    "minimum_match_for_provider_running": [
      "same_study_id",
      "same_action_type",
      "same_work_unit_id_or_fingerprint",
      "same_dispatch_ref_or_stage_attempt_id",
      "no_terminal_closeout_for_stage_attempt"
    ],
    "minimum_match_for_closeout_consumption": [
      "same_study_id",
      "same_stage_attempt_id_or_work_unit_identity",
      "same_action_type_when_present",
      "same_work_unit_fingerprint_when_present"
    ],
    "missing_identity_policy": "fail_closed_to_diagnostic_or_typed_blocker_candidate",
    "weak_label_match_can_authorize_route": false,
    "shared_identity_helper": {
      "surface": "stage_route_currentness_identity",
      "module": "src/med_autoscience/controllers/stage_route_currentness_identity.py",
      "applies_to": [
        "current_work_unit action selection",
        "domain_action_request_materializer currentness preemption",
        "domain_owner_action_dispatch fresh typed-blocker gate",
        "study_progress current owner action projection reconcile"
      ],
      "canonical_match_fields": [
        "action_type",
        "work_unit_id",
        "work_unit_fingerprint",
        "action_fingerprint",
        "owner_route.source_refs.owner_route_currentness_basis"
      ],
      "repair_followup_requires_shared_fingerprint": true,
      "same_action_without_work_unit_or_fingerprint_authorizes_route": false,
      "missing_strong_identity_policy": "fail_closed_to_currentness_diagnostic"
    },
    "provider_admission_identity_contract": {
      "required_fields": [
        "study_id",
        "action_type",
        "work_unit_id",
        "work_unit_fingerprint",
        "dispatch_path_or_ref",
        "currentness_basis",
        "route_identity_key",
        "attempt_idempotency_key"
      ],
      "currentness_basis_required_fields": [
        "work_unit_id",
        "work_unit_fingerprint",
        "truth_epoch",
        "runtime_health_epoch_or_source_eval_id"
      ],
      "weak_identity_decision": "weak_provider_admission_identity",
      "weak_identity_effect": "suppress_provider_admission_pending",
      "fingerprintless_stop_loss_closeout_match": "requires_same_source_eval_truth_or_runtime_health_epoch",
      "action_id_role": "action_family_only_not_route_or_attempt_identity"
    },
    "progress_current_owner_ticket_contract": {
      "synthetic_fingerprint_prefix_forbidden": "study-progress-current-owner-ticket::",
      "required_strong_identity_any": [
        "owner_route.source_refs.owner_route_currentness_basis",
        "current_executable_owner_action.source_fingerprint",
        "current_executable_owner_action.work_unit_fingerprint",
        "current_executable_owner_action.action_fingerprint",
        "current_executable_owner_action.source_eval_id",
        "current_work_unit.work_unit_fingerprint",
        "current_owner_ticket.work_unit.work_unit_fingerprint"
      ],
      "weak_identity_signal": "weak_fresh_progress_current_owner_ticket_identity",
      "weak_identity_effect": "diagnostic_only_no_default_executor_dispatch",
      "weak_identity_reason": "fresh_progress_current_owner_ticket_requires_strong_currentness_identity",
      "route_generation_policy": "do_not_generate_owner_route_from_generated_at_or_source_ref_only"
    }
  },
  "lifecycle_state_machine": {
    "main_chain": [
      "DesiredOwnerDelta",
      "ProviderAdmissionRequested",
      "OPLStageRunAdmitted",
      "ProviderRunning",
      "ProviderTerminalCloseoutObserved",
      "MASCloseoutConsumed",
      "DomainAcceptedOrTypedBlocked",
      "NextOwnerDeltaProjected"
    ],
    "exception_states": [
      "HumanGateWaiting",
      "RetryScheduled",
      "DeadLettered",
      "InfrastructureCrashed",
      "StaleObservationIgnored",
      "NoProgressBudgetExhausted",
      "SupervisorOnlyRunningWatch"
    ],
    "transition_authority": {
      "DesiredOwnerDelta": "MAS current_owner_delta reducer",
      "ProviderAdmissionRequested": "MAS provider admission identity bound to current owner delta",
      "OPLStageRunAdmitted": "OPL StageRun Kernel",
      "ProviderRunning": "OPL liveness plus MAS identity match and no terminal closeout",
      "ProviderTerminalCloseoutObserved": "OPL/default-executor closeout packet",
      "MASCloseoutConsumed": "domain-health-diagnostic apply or equivalent MAS authority consumer",
      "DomainAcceptedOrTypedBlocked": "MAS owner receipt, quality gate receipt, stable typed blocker, human gate, or route-back evidence",
      "NextOwnerDeltaProjected": "MAS current_owner_delta/current_work_unit projection"
    },
    "provider_completion_counts_as_domain_accepted": false,
    "queue_completion_counts_as_next_owner_delta": false,
    "active_run_id_counts_as_paper_progress": false
  },
  "currentness_precedence": [
    {
      "rank": 1,
      "signal": "weak_provider_admission_identity",
      "effect": "suppress_provider_admission_pending",
      "required_match": [
        "missing_provider_admission_identity_required_field",
        "missing_strong_currentness_basis"
      ],
      "allowed_output": "currentness_diagnostic"
    },
    {
      "rank": 2,
      "signal": "terminal_closeout_for_same_stage_attempt",
      "effect": "suppress_running_projection",
      "required_match": [
        "study_id",
        "stage_attempt_id"
      ],
      "allowed_output": "terminal_closeout_diagnostic_or_closeout_consumption_candidate"
    },
    {
      "rank": 3,
      "signal": "strict_live_provider_attempt_for_current_identity",
      "effect": "project_running_provider_attempt",
      "required_match": [
        "study_id",
        "action_type",
        "work_unit_id_or_fingerprint",
        "dispatch_ref_or_stage_attempt_id"
      ],
      "allowed_output": "running_provider_attempt"
    },
    {
      "rank": 4,
      "signal": "same_work_unit_stop_loss_terminal_stage",
      "effect": "project_typed_blocker_and_suppress_provider_admission",
      "required_match": [
        "study_id",
        "action_type",
        "work_unit_id_or_fingerprint"
      ],
      "allowed_output": "typed_blocker",
      "default_blocker": "anti_loop_budget_exhausted"
    },
    {
      "rank": 5,
      "signal": "accepted_typed_closeout_for_same_identity",
      "effect": "consume_provider_admission_pending",
      "required_match": [
        "study_id",
        "stage_attempt_id_or_work_unit_identity"
      ],
      "allowed_output": "typed_blocker_or_next_owner_projection"
    },
    {
      "rank": 6,
      "signal": "weak_fresh_progress_current_owner_ticket_identity",
      "effect": "diagnostic_only_no_default_executor_dispatch",
      "required_match": [
        "current_owner_ticket_or_current_action_present",
        "missing_strong_currentness_identity"
      ],
      "allowed_output": "ignored_diagnostic"
    },
    {
      "rank": 7,
      "signal": "fresh_current_owner_action",
      "effect": "project_executable_owner_action",
      "required_match": [
        "currentness_basis",
        "allowed_action",
        "work_unit_identity"
      ],
      "allowed_output": "executable_owner_action"
    },
    {
      "rank": 8,
      "signal": "stable_typed_blocker_for_current_identity",
      "effect": "project_typed_blocker",
      "required_match": [
        "study_id",
        "work_unit_identity_or_currentness_basis"
      ],
      "allowed_output": "typed_blocker"
    },
    {
      "rank": 9,
      "signal": "stale_or_unmatched_runtime_residue",
      "effect": "audit_only",
      "required_match": [],
      "allowed_output": "ignored_diagnostic"
    }
  ],
  "closeout_handshake": {
    "required_sequence": [
      "OPL attempt reaches terminal state",
      "terminal closeout packet exists for the same stage attempt or work-unit identity",
      "MAS consumes closeout through domain-health-diagnostic apply or equivalent authority consumer",
      "fresh study progress/read-model is regenerated",
      "if provider_admission_pending remains for a new identity, OPL scoped tick/hydrate may start the next attempt",
      "if the same identity remains pending, classify as closeout consumption/currentness bug"
    ],
    "dry_run_semantics": {
      "starts_llm_or_provider": false,
      "observe_only_for_runtime_execution": true,
      "may_refresh_diagnostic_evidence": true,
      "must_not_be_called_no_write": false
    },
    "terminal_closeout_status_prefixes": [
      "blocked",
      "closed",
      "completed",
      "executed",
      "failed",
      "materialized_record",
      "owner_output_already_current",
      "progress_delta",
      "record_materialized",
      "record_only_archive",
      "repeat_suppressed",
      "succeeded",
      "terminal",
      "typed_blocker",
      "typed_blocked"
    ],
    "non_terminal_statuses": [
      "admitted",
      "checkpointed",
      "created",
      "human_gate",
      "hydrated",
      "in_progress",
      "pending",
      "queued",
      "running",
      "started",
      "starting"
    ]
  },
  "anti_loop_policy": {
    "surface_kind": "mas_opl_stage_route_anti_loop_policy",
    "budget_scope": "study_id + action_type + work_unit_id + work_unit_fingerprint + source_eval_id",
    "max_same_identity_terminal_without_progress": 2,
    "max_same_identity_noop_or_owner_output_current": 1,
    "max_same_identity_provider_admission_echo": 1,
    "progress_resets_budget_when_any_present": [
      "OwnerReceipt",
      "quality_gate_receipt",
      "stable TypedBlocker with new blocker identity",
      "human_gate_ref",
      "route_back_evidence_ref",
      "canonical paper/artifact delta ref",
      "reviewer/auditor record ref for current artifact digest",
      "new current_owner_delta identity"
    ],
    "no_progress_signals": [
      "same_work_unit_terminal_closeout_without_domain_consumption",
      "same_work_unit_repeat_suppressed_terminal_stage",
      "provider_admission_pending_for_consumed_identity",
      "idempotent_noop_without_new_owner_delta",
      "owner_output_already_current_without_next_owner_delta",
      "repeated_gate_replay_same_blockers",
      "stale_route_back_replayed_as_current",
      "advisory_refs_only_without_owner_consumption",
      "queue_dead_letter_without_mas_typed_blocker_or_next_owner"
    ],
    "classifications": [
      "stale_running_projection",
      "closeout_unconsumed",
      "same_work_unit_no_delta",
      "provider_admission_echo",
      "repeated_noop_route",
      "advisory_only_loop",
      "dead_letter_unconsumed"
    ],
    "budget_exhaustion_action": "stop_redrive_and_emit_mas_typed_blocker_candidate_or_route_back_evidence",
    "automatic_redrive_after_budget_exhaustion_allowed": false
  },
  "stage_route_arbiter_surface": {
    "surface_kind": "mas_opl_stage_route_arbiter",
    "schema_version": 1,
    "producer": "domain-health-diagnostic.provider_admission_current_control",
    "ordinary_planning_root": "current_owner_delta",
    "purpose": "Explain, in one machine-readable place, why each provider-admission identity is retained as pending or suppressed by strict live/terminal evidence.",
    "decision_kinds": [
      {
        "decision": "weak_provider_admission_identity",
        "effect": "suppress_provider_admission_pending",
        "required_match": [
          "missing_study_action_work_unit_or_fingerprint",
          "missing_dispatch_path_or_ref",
          "missing_currentness_basis"
        ]
      },
      {
        "decision": "terminal_closeout_precedes_live_projection",
        "effect": "suppress_provider_admission_pending",
        "required_match": [
          "study_id",
          "stage_attempt_id_or_run_id",
          "accepted_typed_closeout_or_executed_typed_blocker",
          "same_provider_identity"
        ]
      },
      {
        "decision": "running_identity_observed",
        "effect": "suppress_provider_admission_pending",
        "required_match": [
          "study_id",
          "action_type",
          "work_unit_id_or_fingerprint",
          "dispatch_ref_or_stage_attempt_id"
        ]
      },
      {
        "decision": "accepted_closeout_consumed_pending",
        "effect": "suppress_provider_admission_pending",
        "required_match": [
          "study_id",
          "stage_attempt_id_or_work_unit_identity",
          "accepted_typed_closeout_or_executed_typed_blocker"
        ]
      },
      {
        "decision": "current_typed_blocker_precedes_provider_admission",
        "effect": "suppress_provider_admission_pending",
        "required_match": [
          "study_id",
          "action_type_or_work_unit_id",
          "current_work_unit_or_execution_envelope_typed_blocker"
        ]
      },
      {
        "decision": "pending_provider_admission",
        "effect": "retain_provider_admission_pending",
        "required_match": [
          "current_owner_delta_identity",
          "no_matching_live_attempt",
          "no_matching_accepted_closeout"
        ]
      }
    ],
    "required_identity_fields": [
      "study_id",
      "action_type",
      "work_unit_id",
      "work_unit_fingerprint",
      "dispatch_path_or_ref",
      "currentness_basis",
      "route_identity_key",
      "attempt_idempotency_key"
    ],
    "carrier_self_identity_policy": {
      "current_control_action_can_self_authorize": false,
      "fallback_allowed_only_when_canonical_status_has_no_current_identity_requirement": true,
      "canonical_identity_sources": [
        "current_owner_delta",
        "current_work_unit",
        "current_executable_owner_action",
        "current_execution_envelope"
      ],
      "missing_canonical_identity_effect": "suppress_provider_admission_candidate",
      "action_id_role": "action_family_only_not_dedupe_or_route_identity",
      "weak_identity_effect": "weak_provider_admission_identity"
    },
    "authority_boundary": {
      "arbiter_surface": "currentness_projection_only",
      "can_write_domain_truth": false,
      "can_authorize_publication_ready": false,
      "provider_completion_is_domain_ready": false
    },
    "must_be_written_with_current_control": true,
    "pending_provider_admission_required_match": [
      "strong_provider_admission_identity",
      "no_weak_provider_admission_identity",
      "no_matching_live_attempt",
      "no_matching_accepted_closeout",
      "no_current_typed_blocker_for_same_action_or_work_unit",
      "no_same_currentness_basis_fingerprintless_stop_loss_closeout"
    ],
    "scoped_scan_unscanned_retention_policy": {
      "retention_semantics": "audit_only",
      "active_queue_semantics": "scanned_studies_only",
      "unscanned_study_action_queue_effect": "remove_from_active_action_queue_and_keep_under_unscanned_action_queue_retained_for_audit",
      "history_field": "unscanned_active_action_suppressed_count",
      "can_increment_provider_admission_pending_count": false
    }
  },
  "owner_action_dispatch_authority_policy": {
    "surface_kind": "mas_owner_action_dispatch_authority_policy",
    "scope": [
      "domain_action_request_materializer",
      "domain_owner_action_dispatch"
    ],
    "typed_blocker_can_self_authorize_owner_action": false,
    "blocker_only_effect": "suppress_stale_transition_queue_or_dispatch_and_emit_diagnostic",
    "readiness_dispatch_requires_any": [
      "explicit_current_executable_owner_action",
      "stage_native_workspace_next_action_with_authority_binding",
      "terminal_closeout_owner_answer_dispatch"
    ],
    "readiness_blocker_only_forbidden_basis": [
      "current_work_unit.typed_blocker",
      "current_execution_envelope.typed_blocker",
      "stale_default_executor_dispatch_owner_route",
      "source_ref_or_fingerprint_match_without_executable_owner_action"
    ],
    "allowed_readiness_dispatch_effect": "execute_or_handoff_owner_action",
    "forbidden_readiness_dispatch_effect": "blocker_only_executes_complete_medical_paper_readiness_surface",
    "stage_native_next_action_policy": {
      "dispatch_requires_any": [
        "canonical_current_work_unit_binding",
        "owner_route_match_with_allowed_action",
        "shared_currentness_identity_with_fingerprint"
      ],
      "stale_or_unbound_effect": "diagnostic_only_no_default_executor_dispatch",
      "blocked_reason": "stage_native_workspace_next_action_requires_current_work_unit_currentness_match",
      "readiness_barrier_derived_repair_requires": [
        "fresh_action.reason == medical_paper_readiness_missing",
        "current_work_unit.status == typed_blocker or current_work_unit.state.state_kind == typed_blocker",
        "current_work_unit.work_unit_id == complete_medical_paper_readiness_surface or missing",
        "current_work_unit.state.stale_queue_or_handoff_can_override != true",
        "stage_native_next_action_has_authority_binding"
      ],
      "readiness_barrier_stale_or_unbound_effect": "diagnostic_only_no_default_executor_dispatch",
      "readiness_barrier_forbidden_basis": [
        "current_execution_envelope_typed_blocker_without_current_work_unit_readiness_identity",
        "stale_queue_or_handoff_can_override_true",
        "old_queue_or_handoff_readiness_residue",
        "readiness_typed_blocker_for_non_current_work_unit"
      ]
    },
    "default_dispatch_allowed_false_effect": "ignored_diagnostic_no_request_task_no_default_executor_dispatch",
    "terminal_closeout_owner_answer_dispatch_policy": {
      "requires_any": [
        "closeout_ref_or_source_ref_points_to_dispatch",
        "typed_blocker_ref_points_to_dispatch",
        "shared_currentness_identity_with_fingerprint"
      ],
      "same_action_and_work_unit_without_ref_or_fingerprint_effect": "reject_dispatch_as_stale_identity"
    },
    "authority_boundary": {
      "can_write_domain_truth": false,
      "can_authorize_publication_ready": false,
      "can_convert_blocker_to_owner_receipt": false,
      "explicit_owner_action_required": true
    }
  },
  "stage_log_minimum_viability": {
    "surface_kind": "mas_opl_stage_log_minimum_viability_policy",
    "canonical_domain_log_field": "paper_stage_log",
    "accepted_aliases": [
      "paper_stage_log",
      "user_stage_log",
      "stage_log_summary"
    ],
    "required_domain_fields": [
      "stage_name",
      "problem_summary",
      "stage_goal",
      "stage_work_done",
      "paper_work_done",
      "changed_stage_surfaces",
      "changed_paper_surfaces",
      "outcome",
      "remaining_blockers",
      "duration",
      "token_usage",
      "cost",
      "usage_refs",
      "cost_refs",
      "progress_delta_classification",
      "deliverable_progress_delta",
      "paper_progress_delta",
      "platform_repair_delta",
      "next_forced_delta",
      "evidence_refs"
    ],
    "empty_lists_are_explicit_complete_values_for": [
      "changed_stage_surfaces",
      "changed_paper_surfaces",
      "remaining_blockers",
      "usage_refs",
      "cost_refs",
      "evidence_refs"
    ],
    "missing_domain_fields_effect": "consume_terminal_closeout_as_typed_blocker",
    "typed_blocker_reason": "domain_closeout_provided_incomplete_user_stage_log",
    "paper_progress_credit_allowed_when_incomplete": false,
    "automatic_redrive_allowed_when_incomplete": false,
    "workbench_projection": {
      "field": "stage_log_workbench_summary",
      "surface_kind": "mas_stage_log_workbench_summary",
      "read_model": "stage_log_minimum_viability_workbench_projection",
      "projection_scope": "agent_operator_workbench_summary",
      "source_log_field": "paper_stage_log",
      "body_policy": "refs_only_body_free",
      "required_summary_fields": [
        "stage_goal",
        "actual_work",
        "paper_delta",
        "deliverable_delta",
        "platform_delta",
        "observability",
        "evidence_refs",
        "next_forced_delta",
        "missing_domain_fields",
        "source_refs",
        "authority_boundary"
      ],
      "field_presence_shape": {
        "status": "present_or_missing",
        "item_count": "integer",
        "refs": "refs_only",
        "body_included": false
      },
      "observability_shape": {
        "duration": "observed_or_missing",
        "token_usage": "observed_or_missing",
        "cost": "observed_or_missing"
      },
      "forbidden_body_fields": [
        "stage_goal_body",
        "stage_work_done",
        "paper_work_done",
        "paper_body",
        "artifact_body",
        "memory_body",
        "publication_verdict_body",
        "transcript_body"
      ],
      "authority_boundary": {
        "refs_only": true,
        "body_free": true,
        "observability_only": true,
        "can_mark_domain_ready": false,
        "can_write_paper_truth": false,
        "can_authorize_quality_verdict": false,
        "can_block_provider_admission": false
      }
    },
    "authority_boundary": {
      "mas_consumes_as_domain_typed_blocker": true,
      "opl_projects_missing_fields_only": true,
      "provider_completion_is_domain_progress": false,
      "can_write_paper_body": false,
      "can_authorize_quality_or_submission": false
    }
  },
  "opl_substrate_optimization": {
    "opl_owns": [
      "StageRun Kernel",
      "durable queue",
      "retry and dead-letter",
      "provider liveness query",
      "human gate transport",
      "state index",
      "route reconciler transport",
      "observability",
      "workbench shell"
    ],
