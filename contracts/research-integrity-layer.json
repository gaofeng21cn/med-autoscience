      ],
      "status_values": [
        "verified",
        "needs_review",
        "unresolved",
        "contradicted",
        "retracted"
      ],
      "hard_gate_status_values": [
        "contradicted",
        "retracted"
      ],
      "review_status_values": [
        "needs_review",
        "unresolved"
      ]
    },
    {
      "surface_kind": "claim_citation_support_matrix_v2",
      "producer": "MAS research_integrity.claim_citation_support_v2 pure builder",
      "inputs": [
        "claim spans",
        "citation refs",
        "evidence refs",
        "reference verification attestation refs and statuses"
      ],
      "required_output_fields": [
        "surface_kind",
        "schema_version",
        "claims",
        "citation_links",
        "blocker_candidates",
        "authority_boundary"
      ],
      "support_grade_values": [
        "direct_support",
        "partial_support",
        "background_only",
        "unsupported",
        "contradicted"
      ],
      "hard_gate_grade_values": [
        "unsupported",
        "contradicted"
      ],
      "hard_gate_reference_status_values": [
        "unresolved",
        "contradicted",
        "retracted"
      ]
    },
    {
      "surface_kind": "manuscript_consistency_meta_review",
      "producer": "MAS research_integrity.manuscript_consistency pure builder",
      "inputs": [
        "manuscript section facts",
        "numeric facts from abstract, results, tables, and figures",
        "display-to-claim fact refs",
        "reporting guideline checklist expectations"
      ],
      "required_output_fields": [
        "surface_kind",
        "schema_version",
        "status",
        "findings",
        "blocker_candidates",
        "authority_boundary"
      ],
      "status_values": [
        "clear",
        "needs_review",
        "blocked"
      ],
      "finding_families": [
        "numeric_fact_inconsistency",
        "unit_population_window_mismatch",
        "display_to_claim_mismatch",
        "section_logic_contradiction",
        "reporting_guideline_gap"
      ]
    },
    {
      "surface_kind": "research_integrity_gate_input_bundle",
      "producer": "MAS research_integrity.gate_bundle pure builder",
      "callable_entry": "MedAutoScienceDomainEntry.dispatch command research-integrity-gate-input",
      "action_catalog_descriptor": "research_integrity_gate_input",
      "inputs": [
        "reference_checks or reference/references with provider_evidence from OPL/provider lookup",
        "provider_receipts with provider_evidence, references[].provider_evidence, or opl_connect_reference_verification.provider_evidence from OPL Connect",
        "claim_spans or claim/claims with citation and evidence refs",
        "citation_refs, evidence_refs, and reference_attestation_refs",
        "manuscript_sections or manuscript payload",
        "numeric_facts, display_facts, and reporting_checklist_expectations"
      ],
      "required_output_fields": [
        "surface_kind",
        "schema_version",
        "status",
        "surfaces",
        "blocker_candidates",
        "review_candidates",
        "authority_boundary"
      ],
      "status_values": [
        "clear",
        "needs_review",
        "blocked"
      ],
      "authority": "gate_input_only_no_publication_authority"
    }
  ],
