  "implementation_contract": {
    "provider_lookup_target": {
      "owner": "OPL connector substrate",
      "provider_lookup_mode": "transition_only_receipt_first",
      "receipt_first": true,
      "live_provider_authority_claimed": false,
      "authoritative_provider_truth_owner": "OPL Connect provider receipts",
      "mas_first_slice": "thin provider client may pull Crossref/PubMed/OpenAlex/Semantic Scholar evidence, Crossmark metadata signals, or explicit publisher-connector-required fallback evidence and pass it as provider_evidence only as a transition/dev/test first slice; it is not authoritative live citation verification",
      "provider_receipt_consumption": "research-integrity-reference-verification accepts OPL Connect provider_receipts, normalizes provider_evidence from receipt root, receipt references[], and opl_connect_reference_verification into existing gate input evidence, preserves provider_receipt_refs and source_refs, and falls back to MAS thin provider lookup only when no evidence is present; OPL receipts remain the provider truth owner",
      "stage_hook": "review/publication gate can call research-integrity-review-publication-gate-stage-hook, which triggers research-integrity-reference-verification before returning research-integrity-gate-input",
      "forbidden_side_effects": [
