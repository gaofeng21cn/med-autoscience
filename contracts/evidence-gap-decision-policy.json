{
  "surface_kind": "mas_evidence_gap_decision_policy",
  "version": "evidence-gap-decision-policy.v1",
  "owner": "MedAutoScience",
  "state": "active_contract",
  "purpose": "Machine-readable policy for classifying evidence gaps so progress-first execution can continue through soft gaps while hard gates still fail closed.",
  "machine_boundary": "This contract defines EvidenceGapDecision classification, typed blocker eligibility, claim boundaries, and examples. It does not declare paper progress, live runtime readiness, publication readiness, submission readiness, production readiness, provider liveness, owner receipt closure, or quality verdicts.",
  "schema_ref": "contracts/schemas/evidence-gap-decision.schema.json",
  "examples_ref": "contracts/evidence-gap-decision-examples.json",
  "source_design_ref": "docs/runtime/designs/progress_first_evidence_gap_policy.md",
  "applies_to": [
    "current_owner_delta",
    "paper_autonomy_obligation",
    "paper_recovery_state",
    "DomainProgressTransitionRuntime policy result",
    "owner receipt / typed blocker / human gate intake",
    "live-runtime evidence tails and completion audits"
  ],
  "gap_classes": {
    "authority_gate": {
      "role": "hard_gate_missing_domain_or_runtime_authority",
      "blocks_current_owner_action": true,
      "typed_blocker_countable": true,
      "allowed_decisions": [
        "materialize_typed_blocker"
      ],
      "required_evidence_ref_families": [
        "source_data_or_evidence",
        "owner_route_identity",
        "forbidden_write_boundary",
        "irreversible_mutation_authorization",
        "publication_gate",
        "mas_hard_gate"
      ],
      "cannot_be_satisfied_by": [
        "docs_updated",
        "contract_landed",
        "focused_tests_passed",
        "queue_empty",
        "read_model_currentness",
        "provider_completion"
      ]
    },
    "human_gate": {
      "role": "hard_gate_requiring_human_or_operator_answer",
      "blocks_current_owner_action": true,
      "typed_blocker_countable": true,
      "allowed_decisions": [
        "open_human_gate",
        "materialize_typed_blocker"
      ],
      "required_evidence_ref_families": [
        "human_gate_ref",
        "owner_gate_decision_ref",
        "operator_decision_ref",
        "resume_token_ref"
      ],
      "cannot_be_satisfied_by": [
        "agent_inference",
        "self_review",
        "queue_empty",
        "projection_clean"
      ]
    },
    "proceed_with_assumption": {
      "role": "bounded_assumption_that_allows_current_owner_action_to_continue",
      "blocks_current_owner_action": false,
      "typed_blocker_countable": false,
      "allowed_decisions": [
        "proceed_with_recorded_assumption"
      ],
      "requires": [
        "assumption_ref",
        "revisit_trigger",
        "scope_boundary"
      ],
      "cannot_be_reported_as": [
        "owner_receipt",
        "paper_progress",
        "quality_verdict",
        "readiness_evidence"
      ]
    },
    "soft_quality_gap": {
      "role": "quality_followup_that_does_not_block_current_nonterminal_progress",
      "blocks_current_owner_action": false,
      "typed_blocker_countable": false,
      "allowed_decisions": [
        "continue_with_quality_followup"
      ],
      "requires": [
        "followup_work_order_ref",
        "owner_or_reviewer_scope",
        "acceptance_signal_for_future_repair"
      ],
      "cannot_be_reported_as": [
        "typed_blocker_count",
        "publication_gate_failure",
        "paper_progress",
        "quality_verdict"
      ]
    },
    "observability_backlog": {
      "role": "diagnostic_or_monitoring_followup_without_current_owner_blocking_power",
      "blocks_current_owner_action": false,
      "typed_blocker_countable": false,
      "allowed_decisions": [
        "continue_with_observability_followup"
      ],
      "requires": [
        "followup_work_order_ref",
        "diagnostic_scope",
        "nonblocking_boundary"
      ],
      "cannot_be_reported_as": [
        "typed_blocker_count",
        "runtime_readiness",
        "provider_running",
        "paper_progress"
      ]
    },
    "evidence_tail": {
      "role": "open_evidence_required_before_completion_or_readiness_claim",
      "blocks_current_owner_action": false,
      "blocks_completion_or_readiness_claim": true,
      "typed_blocker_countable": false,
      "allowed_decisions": [
        "record_evidence_tail"
      ],
      "requires": [
        "accepted_evidence_ref_family",
        "next_owner",
        "forbidden_substitutes",
        "claim_boundary"
      ],
      "cannot_be_reported_as": [
        "typed_blocker_count",
        "current_owner_action_blocked",
        "live_runtime_ready",
        "paper_progress"
      ]
    }
  },
  "typed_blocker_materialization_policy": {
    "typed_blocker_countable_gap_classes": [
      "authority_gate",
      "human_gate"
    ],
    "allowed_materialization_reasons": [
      "authority_gate",
      "human_gate",
      "forbidden_write_boundary",
      "stop_loss_materialized"
    ],
    "forbidden_gap_classes_for_typed_blocker_count": [
      "proceed_with_assumption",
      "soft_quality_gap",
      "observability_backlog",
      "evidence_tail"
    ],
    "forbidden_write_boundary_can_materialize_typed_blocker": true,
    "stop_loss_materialized_can_materialize_typed_blocker": true,
    "soft_gap_materialization_policy": "record_followup_or_tail_without_incrementing_typed_blocker_count",
    "typed_blocker_count_source": "EvidenceGapDecision.typed_blocker_policy.typed_blocker_countable"
  },
  "claim_boundary": {
    "paper_progress_claim_allowed": false,
    "live_runtime_readiness_claim_allowed": false,
    "publication_readiness_claim_allowed": false,
    "production_readiness_claim_allowed": false,
    "contract_landed_can_claim_ready": false,
    "docs_updated_can_claim_ready": false,
    "focused_tests_passed_can_claim_ready": false
  },
  "forbidden_claim_terms": [
    "live_runtime_ready",
    "paper_progress",
    "publication_ready",
    "submission_ready",
    "production_ready",
    "provider_running",
    "owner_receipt_closed",
    "quality_verdict",
    "domain_ready",
    "current_package_fresh"
  ],
  "forbidden_completion_interpretations": [
    "docs_updated",
    "contract_landed",
    "focused_tests_passed",
    "evidence_gap_policy_landed",
    "evidence_tail_recorded",
    "queue_empty",
    "projection_clean",
    "read_model_currentness",
    "provider_completion",
    "DHD_dry_run",
    "DHD_observe_only"
  ],
  "non_claims": [
    "This policy landing does not start providers.",
    "This policy landing does not run DHD apply, hydrate, tick, or redrive.",
    "This policy landing does not write study truth, publication_eval/latest.json, controller_decisions/latest.json, owner receipts, typed blockers, paper body, or Yang runtime artifacts.",
    "This policy landing does not close live evidence tails."
  ]
}
