  "pack_id": "fenggaolab.org.medical-display-core",
  "owner": "MedAutoScience",
  "purpose": "Define the compact current medical-display template surface by medical figure intent and visual grammar. Data-evidence figures are R/ggplot2 first; duplicate input-schema variants are aliases or retired presets, not current templates.",
  "machine_boundary": "This catalog controls Display Pack default recommendation, registry and gallery visibility. It is not source truth, statistical truth, artifact authority, visual-audit replacement, or publication-readiness authority.",
  "default_surface_policy": {
    "agent_recommendations_use_canonical_templates_by_default": true,
    "gallery_shows_current_r_ggplot2_evidence_templates": true,
    "evidence_figures_default_to_r_ggplot2": true,
    "python_evidence_figures_not_retained_without_advantage_proof": true,
    "python_illustration_shells_may_be_default_visible": true,
    "data_evidence_figures_require_programmatic_renderer": true,
    "design_and_flow_shells_may_use_svg_or_imagegen_assisted_composition": true,
    "template_analysis_responsibility_required": true,
    "raw_analysis_inputs_must_match_computed_workflow_templates": true,
    "validated_summary_templates_fail_closed_on_raw_analysis_requests": true,
    "migrated_aliases_are_not_default_visible": true,
    "explicit_alias_requests_may_be_migrated_to_canonical_template": true,
    "medical_figure_family_mapping_required": true,
    "starter_recipe_profile_required": true,
    "style_palette_qa_profile_required": true
  },
  "analysis_responsibility_policy": {
    "computed_in_template": "The template accepts raw analysis input for a bounded workflow and records renderer-side analysis provenance.",
    "validated_summary_required": "The template renders locked statistics, curves, matrices, scores, calls, or explanation values from an upstream analysis pipeline.",
    "illustration_shell": "The template is a design or flow shell and cannot carry statistical evidence authority.",
    "table_shell": "The template renders reviewed table values and cannot infer analysis results from raw study data."
  },
  "external_learning_refs": {
    "nature_final_submission": "https://www.nature.com/nature/for-authors/final-submission",
    "nature_formatting_guide": "https://www.nature.com/nature/for-authors/formatting-guide",
