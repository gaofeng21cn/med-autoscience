    "colorspace_palettes": "https://colorspace.r-forge.r-project.org/",
    "viridis_palette": "https://sjmgarnier.github.io/viridis/",
    "complexheatmap_oncoprint": "https://jokergoo.github.io/ComplexHeatmap-reference/book/oncoprint.html",
    "survminer_km_reference": "https://rpkgs.datanovia.com/survminer/reference/ggsurvplot.html",
    "landed_patterns": [
      "intent-first template families",
      "single semantic article palette",
      "vector-first export discipline",
