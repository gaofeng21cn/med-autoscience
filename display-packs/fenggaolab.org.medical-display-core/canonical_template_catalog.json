  "owner": "MedAutoScience",
  "purpose": "Define the small default figure-family surface exposed to agents and human galleries while retaining migrated template ids as aliases for intake and traceability.",
  "machine_boundary": "This catalog controls Display Pack recommendation and gallery visibility. It is not source truth, statistical truth, artifact authority, visual-audit replacement, or publication-readiness authority.",
  "default_surface_policy": {
    "agent_recommendations_use_canonical_templates_by_default": true,
    "gallery_shows_canonical_families_by_default": true,
    "evidence_figures_default_to_r_ggplot2": true,
    "python_evidence_figures_require_explicit_justification_before_default_visibility": true,
    "python_illustration_shells_may_be_default_visible": true,
    "data_evidence_figures_require_programmatic_renderer": true,
    "design_and_flow_shells_may_use_svg_or_imagegen_assisted_composition": true,
    "migrated_aliases_are_not_default_visible": true,
    "explicit_alias_requests_may_be_migrated_to_canonical_template": true
  },
  "external_learning_refs": {
    "nature_skills_project": "https://github.com/Yuan1z0825/nature-skills",
