    "nature_skills_observed_date": "2026-06-19",
    "landed_patterns": [
      "backend-exclusive render and QA",
      "archetype-first figure families",
      "shared legend or dedicated legend strategy",
      "semantic palette reuse across panels",
      "vector-first export discipline"
    ]
  },
