{
  "schema_version": 1,
  "surface_kind": "opl_dependency_requirement_profile",
  "pack_id": "fenggaolab.org.medical-display-core",
  "profile_owner": "MedAutoScience Display Pack",
  "canonical_substrate_owner": "OPL Framework",
