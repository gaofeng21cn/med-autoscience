#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd -P)"

repo_root=""

resolve_repo_root() {
  local candidate="${1}"
  if [[ -z "${candidate}" ]]; then
    return 1
  fi
  if [[ -x "${candidate}/scripts/run-python-clean.sh" && -f "${candidate}/src/med_autoscience/mcp_server.py" ]]; then
    cd "${candidate}" && pwd -P
    return 0
  fi
  return 1
}

try_repo_root() {
  local candidate="${1}"
  if [[ -n "${repo_root}" ]]; then
    return 0
  fi
  if resolved="$(resolve_repo_root "${candidate}" 2>/dev/null)"; then
    repo_root="${resolved}"
  fi
}

try_plugin_source() {
  local plugin_path="${1}"
  if [[ -n "${repo_root}" || ! -e "${plugin_path}" ]]; then
    return 0
  fi
  local plugin_root
  plugin_root="$(cd "${plugin_path}" && pwd -P)"
  try_repo_root "${plugin_root}/../.."
}

try_repo_root "${MAS_REPO_ROOT:-}"
try_repo_root "${MEDAUTOSCI_REPO_ROOT:-}"
try_repo_root "${script_dir}/../../.."
try_plugin_source "${HOME:-}/Library/Application Support/OPL/state/codex-plugin-marketplaces/mas-local/plugins/mas"
try_repo_root "${HOME:-}/workspace/med-autoscience"

if [[ -z "${repo_root}" ]]; then
  echo "medautosci-mcp: could not locate MedAutoScience repo root; set MAS_REPO_ROOT or refresh OPL mas-local marketplace." >&2
  exit 127
fi

export MAS_CLEAN_RUNNER_ANALYSIS_EXTRA=1
exec "${repo_root}/scripts/run-python-clean.sh" -m med_autoscience.mcp_server "$@"
